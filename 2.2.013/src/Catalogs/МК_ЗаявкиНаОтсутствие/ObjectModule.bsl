
&НаСервере                   
Процедура ПередЗаписью(Отказ)       
	Если ОбменДанными.Загрузка Тогда
    	Возврат;
	КонецЕсли;
	Если (ЭтотОбъект.ПометкаУдаления) И (НЕ Ссылка.ПометкаУдаления) Тогда
        // Пометка на удаление устанавливается
        Набор = РегистрыСведений.МК_МоиЗадания.СоздатьНаборЗаписей();
		Набор.Отбор.Заявка.Установить(Ссылка);	
		Набор.Записать();  
		Сообщить("Связанные задания пользователям удалены");
	КонецЕсли;		
КонецПроцедуры

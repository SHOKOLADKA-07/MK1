&НаКлиенте
Процедура Отклонить(Команда)  
	ОписаниеОповещения = Новый ОписаниеОповещения("ПричинаОтклонения", ЭтотОбъект);
	ПоказатьВводСтроки(ОписаниеОповещения, "", "Укажите причину", , Истина); // Истина - многострочный   
КонецПроцедуры	

&НаКлиенте
Процедура ПричинаОтклонения(мПричина, ДополнительныеПараметры) Экспорт
	Если мПричина = Неопределено Тогда     
		ПоказатьПредупреждение(,"Причину нужно указать обязательно");  	
	Иначе	
    	мЗ = Объект.Ссылка;	  		
		мРез = ОтклонитьНаСервере(мПричина);   
		Если мРез.Результат Тогда
			ПоказатьПредупреждение(,"Отклонение выполнено успешно");  	
		Иначе	
			ПоказатьПредупреждение(,мРез.ТекстОшибки);  	
		КонецЕсли;		                
		ПоказатьКнопки();  
		ЭтаФорма.ОбновитьОтображениеДанных();  	 		
		ОповеститьОбИзменении(мЗ);               	
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура СсылкаНаДокументМК(Команда)
	ЗапуститьПриложение(ЭтаФорма.СсылкаНаДокументМК);
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	мАдрес = ВычислитьАдресСсылки();
	ЭтаФорма.СсылкаНаДокументМК = мАдрес;  
	ЭтаФорма.СоздаватьЭЦПНаСервере = Константы.СоздаватьЭлектронныеПодписиНаСервере.Получить(); 
КонецПроцедуры

&НаСервере
Функция ВычислитьАдресСсылки()
	мНаим = Константы.МК_Сервер.Получить();
	Если Прав(мНаим, 1) = "/" Тогда
		мНаим = Лев(мНаим, СтрДлина(мНаим)-1);
	КонецЕсли;	
	мНаим = мНаим + "/edms/documents/"+Формат(Объект.МК_КодДокумента, "ЧГ=0");
	Возврат мНаим;
КонецФункции	

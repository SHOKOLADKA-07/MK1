			мНомерУчастника = мСтр.Номер;
			мНашел = Истина;
			Прервать;
		КонецЕсли;	
	КонецЦикла;	     
	Если мНашел Тогда
		мПараметры = Новый Структура("НомерУчастника, Причина",мНомерУчастника, мПричина) ; 				

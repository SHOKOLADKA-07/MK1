Функция МК_ОтправитьJSON(мДокументы)     Экспорт      // Отправлять будем сведения из добавленного элемента справочника "МК_ДокументыКЭДО"   
	мРезультат = Истина;
	ОО = Обработки.МК_НастройкаВыгрузки.Создать();             // Получили доступ к обработке, в которой находятся служебные функции
	мСеанс = ОО.СоздатьСеансСвязи(Истина);
	Если мСеанс = Неопределено Тогда
		// Надо сообщить, что отправка не удалась.  
		Возврат Ложь;
	Иначе	
		Выгрузка = Новый Структура; 
		Выгрузка.Вставить("Documents",Новый Массив);		
		Для Каждого мСсылка из мДокументы Цикл    
			//УниверсальноеВремя(ТекущаяДатаСеанса(), ) 
			мДокКЭДО = мСсылка.ПолучитьОбъект();
			мОписание = Новый Структура;
			мОписание.Вставить("doc_id",СокрЛП(мСсылка.УникальныйИдентификатор()));
			мОписание.Вставить("doctype_id", мДокКЭДО.КодТипаДокумента); 
			мОписание.Вставить("doc_date", СокрЛП(мДокКЭДО.ДатаДокумента));
			мОписание.Вставить("company",СокрЛП(мДокКЭДО.ОрганизацияСсылка.УникальныйИдентификатор()));
			мОписание.Вставить("doc_number",СокрЛП(мДокКЭДО.НомерДокумента));
			//мОписание.Вставить("doc_date",Формат(мДокКЭДО.ДатаДокумента,"ДЛФ=D"));
			мОписание.Вставить("route",ОО.МК_ТипМаршрута(мДокКЭДО.МаршрутПодписания,1));
			мОписание.Вставить("deadline",Формат(мДокКЭДО.КрайнийСрокПодписания,"ДЛФ=D")); 
			мОписание.Вставить("head",СокрЛП(мДокКЭДО.Руководитель.УникальныйИдентификатор()));  
			мОписание.Вставить("head_individual",СокрЛП(мДокКЭДО.РуководительФЛ.УникальныйИдентификатор()));  
			мОписание.Вставить("filename",СокрЛП(мДокКЭДО.ИмяФайлаДокумента)); 
			Если ЗначениеЗаполнено(мДокКЭДО.ИмяФайлаПодписи) Тогда
				мОписание.Вставить("signature",СокрЛП(мДокКЭДО.ИмяФайлаПодписи)); 
				мОписание.Вставить("signature_date",СокрЛП(мДокКЭДО.ДатаПодписи)); 
				мОписание.Вставить("signature_owner",СокрЛП(мДокКЭДО.ВладелецЭЦП.УникальныйИдентификатор()));
			КонецЕсли;	

			мЧерновик = Ложь;
			Если мДокКЭДО.СтатусДокумента = Перечисления.МК_СтатусыДокументов.С1 Тогда   
				мЧерновик = Истина;
			КонецЕсли;	
			мОписание.Вставить("draft", мЧерновик);
			// Тут надо добавить сотрудников   
			мСписСотр = Новый Массив;
			Для Каждого мСотр ИЗ мДокКЭДО.СотрудникиДокумента Цикл     
				// 10.02.2025 Меняем в выгрузке документа сотрудника на физлицо
				//мСписСотр.Добавить(СокрЛП(мСотр.СотрудникСсылка.УникальныйИдентификатор()));
				мСписСотр.Добавить(СокрЛП(мСотр.СотрудникСсылка.ФизическоеЛицо.УникальныйИдентификатор()));
			КонецЦикла;	                                
			мОписание.Вставить("employees",мСписСотр);
			Выгрузка.Documents.Добавить(мОписание);
		КонецЦикла;
	КонецЕсли;	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
			
	Попытка
		ЗаписатьJSON(ЗаписьJSON, Выгрузка);	
		ТекстJSON = ЗаписьJSON.Закрыть();
	Исключение
		Сообщить(ЗначениеВСтрокуВнутр(Выгрузка));
		ВызватьИсключение(ОписаниеОшибки());
	КонецПопытки;
			
	hЗапрос = ОО.СоздатьHTTPЗапрос("api/1c-exchange/edms/documents", мСеанс);
	hЗапрос.УстановитьТелоИзСтроки(ТекстJSON);   
	hЗапрос.Заголовки.Вставить("Source","1C Enterprise MK");
	hОтвет = мСеанс.Соединение.ВызватьHTTPМетод("POST", hЗапрос);
	мОтвет = ОО.ПроверитьОтвет(hОтвет,"Документы КЭДО",Истина); 
	Если мОтвет Тогда   // Если отправка случилась успешно, запишем, что документы отправлены.   
		Для Каждого мСсылка из мДокументы Цикл
			мДокКЭДО = мСсылка.ПолучитьОбъект();
			мДокКэдо.Отправлен = Истина;    
			// Статус поменять!!!   
			Если мДокКЭДО.СтатусДокумента = Перечисления.МК_СтатусыДокументов.С1 Тогда;  // Черновик 
				мДокКЭДО.СтатусЧислом = 3;
			Иначе	                      
				мДокКЭДО.СтатусЧислом = 4;
			КонецЕсли;	
			мДокКэдо.Записать();
		КонецЦикла;	
	КонецЕсли;
	Возврат мОтвет;
КонецФункции	            


&НаСервере
Функция ОтправитьСписокДокументов(мСписок)                      
	ОО = Обработки.МК_НастройкаВыгрузки.Создать();             // Получили доступ к обработке, в которой находятся служебные функции  
	мСеанс = ОО.СоздатьСеансСвязи(Истина); 	
	Если мСеанс = Неопределено Тогда
		// Ошибка авторизации. Ничего не делаем.
	Иначе         
		мРезультат = Истина;    // Пока эта истина говорит о том, что сеанс создан (получен токен). 
		
		мВыгрузка = Новый Структура;  
		мВыгрузка.Вставить("Document_Ids",мСписок);
		
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
	    ЗаписатьJSON(ЗаписьJSON, мВыгрузка);	
		ТекстJSON = ЗаписьJSON.Закрыть();   	  	                                          
		hЗапрос = ОО.СоздатьHTTPЗапрос("api/1c-exchange/edms/documents/mark-exported", мСеанс);    
		hЗапрос.Заголовки.Вставить("Source","1C Enterprise MK");
		hЗапрос.УстановитьТелоИзСтроки(ТекстJSON);
		hОтвет = мСеанс.Соединение.ВызватьHTTPМетод("POST", hЗапрос);  
		ТекстОтвет = hОтвет.ПолучитьТелоКакСтроку();
		Попытка
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(ТекстОтвет);
			СтрОтвет = ПрочитатьJSON(ЧтениеJSON); 
			Если ТипЗнч(СтрОтвет) <> Тип("Структура") ИЛИ НЕ СтрОтвет.Свойство("data") Тогда
			//	// Тут какая-то беда. Или структура не получена, или она неправильная  
			Иначе     
				мВозврат = СтрОтвет.Data.Status;	
			КонецЕсли;	
			мВозврат = СтрОтвет;
		Исключение   
			мОшибка = "Ошибка отправки списка записанных документов. Не удалось преобразовать строку HTTP-ответа в json: "+ТекстОтвет;  
			Сообщить(мОшибка);
		КонецПопытки; 						
	КонецЕсли;	
	Возврат мВозврат;
КонецФункции

&НаСервере
Функция ПолучитьСписокДелегатов(мНомерУчастника)      Экспорт    
	// GET /api/1c-exchange/edms/documents/delegate/users-list

	мУспех = Ложь;
	// 
	ОО = Обработки.МК_НастройкаВыгрузки.Создать();             // Получили доступ к обработке, в которой находятся служебные функции  
	мСеанс = ОО.СоздатьСеансСвязи(Истина);                            
	мВозврат = Новый Структура("Результат,ТекстОшибки,Подписанты,НомерУчастника", Ложь);   
	
	//мСтр = Новый Структура("approval_id",мНомерУчастника);
	мЗапрос = "/api/1c-exchange/edms/documents/delegate/users-list?approval_id="+Строка(мНомерУчастника); 
	Если мСеанс = Неопределено Тогда
		// Ошибка авторизации. Ничего не делаем.		
		мОшибка = "Ошибка соединения";
	Иначе         
		мРезультат = Истина;    // Пока эта истина говорит о том, что сеанс создан (получен токен). 
		hЗапрос = ОО.СоздатьHTTPЗапрос(мЗапрос, мСеанс);    		
		hЗапрос.Заголовки.Вставить("Source","1C Enterprise MK");  
		hОтвет = мСеанс.Соединение.ВызватьHTTPМетод("GET", hЗапрос);  
		ТекстОтвет = hОтвет.ПолучитьТелоКакСтроку();
		Попытка
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(ТекстОтвет);
			СтрОтвет = ПрочитатьJSON(ЧтениеJSON); 
			Если ТипЗнч(СтрОтвет) <> Тип("Структура") ИЛИ НЕ СтрОтвет.Свойство("data") Тогда
				// Тут какая-то беда. Или структура не получена, или она неправильная    
				мОшибка = "Неверная структура ответа от МК";
			Иначе     	
				Если СтрОтвет.data.status = "success" Тогда 
					мВозврат.Результат = Истина;  
					мВозврат.Подписанты = СтрОтвет.data.users;                     
					мВозврат.НомерУчастника = мНомерУчастника;
				Иначе                                                
					мОшибка = "";
					Для Каждого тОшибка Из СтрОтвет.data.error Цикл
						мОшибка = мОшибка + тОшибка;
					КонецЦикла;	                                 
					мВозврат.ТекстОшибки = мОшибка;
				КонецЕсли;	 		
			КонецЕсли;	
		Исключение         
			мВозврат.Результат = Ложь;
			мОшибка = "Ошибка получения списка делегатов. Не удалось преобразовать строку HTTP-ответа в json: "+ТекстОтвет;  		
		КонецПопытки; 						
	КонецЕсли;	 
	мВозврат.ТекстОшибки = мОшибка;
	Возврат мВозврат;
КонецФункции	


&НаСервере
Функция ОтправитьДелегата(мПарам)      Экспорт    
	// POST/api/1c-exchange/edms/documents/delegate
	мУспех = Ложь;     
	мОшибка = "";
	// 
	ОО = Обработки.МК_НастройкаВыгрузки.Создать();             // Получили доступ к обработке, в которой находятся служебные функции  
	мСеанс = ОО.СоздатьСеансСвязи(Истина);                            
	мВозврат = Новый Структура("Результат,ТекстОшибки,Подписанты,Статус", Ложь);   
	
	мСтр = Новый Структура("approval_id, user_id",Формат(мПарам.НомерУчастника, "ЧГ=0")  , Формат(мПарам.НомерДелегата, "ЧГ=0"));
	
	Если мСеанс = Неопределено Тогда
		// Ошибка авторизации. Ничего не делаем.		
		мОшибка = "Ошибка соединения";
	Иначе         
		мРезультат = Истина;    // Пока эта истина говорит о том, что сеанс создан (получен токен).  
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
	    ЗаписатьJSON(ЗаписьJSON, мСтр);	
		ТекстJSON = ЗаписьJSON.Закрыть();  	
		hЗапрос = ОО.СоздатьHTTPЗапрос("/api/1c-exchange/edms/documents/delegate", мСеанс);    		
		hЗапрос.УстановитьТелоИзСтроки(ТекстJSON);   
		hЗапрос.Заголовки.Вставить("Content-Type","application/json");
		hЗапрос.Заголовки.Вставить("Source","1C Enterprise MK");  
		hОтвет = мСеанс.Соединение.ВызватьHTTPМетод("POST", hЗапрос);  
		ТекстОтвет = hОтвет.ПолучитьТелоКакСтроку();
		Попытка
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(ТекстОтвет);
			СтрОтвет = ПрочитатьJSON(ЧтениеJSON); 
			Если ТипЗнч(СтрОтвет) <> Тип("Структура") ИЛИ НЕ СтрОтвет.Свойство("data") Тогда
				// Тут какая-то беда. Или структура не получена, или она неправильная  
				мОшибка = "Неверная структура ответа от МК";
			Иначе     					
				Если СтрОтвет.data.status = "success" Тогда 
					мВозврат.Результат = Истина;   
				Иначе                                                
					мОшибка = "";
					Для Каждого тОшибка Из СтрОтвет.data.error Цикл
						мОшибка = мОшибка + тОшибка;
					КонецЦикла;	                                 
				КонецЕсли;		   			
				мВозврат.Подписанты = СтрОтвет.data.document.approvals;
				мВозврат.Статус = СтрОтвет.data.document.status; 				
			КонецЕсли;	
		Исключение   
			мОшибка = "Ошибка получения ответа на делегирование. Не удалось преобразовать строку HTTP-ответа в json: "+ТекстОтвет;  		
		КонецПопытки; 						
	КонецЕсли;	    
	мВозврат.ТекстОшибки = мОшибка;
	Возврат мВозврат;
КонецФункции	


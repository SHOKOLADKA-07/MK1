Функция ПолучитьСписокНезавершенных() Экспорт
	мВозврат = Новый Массив;
	Выборка = Справочники.МК_ДокументыКЭДО.Выбрать();
	Пока Выборка.Следующий() Цикл  
		//Если Выборка.Отправлен И НЕ (Выборка.СтатусДокумента = Перечисления.МК_СтатусыДокументов.С6 ИЛИ
		Если НЕ (Выборка.СтатусДокумента = Перечисления.МК_СтатусыДокументов.С6 ИЛИ
				 Выборка.СтатусДокумента = Перечисления.МК_СтатусыДокументов.С5 ИЛИ 
			  	Выборка.СтатусДокумента = Перечисления.МК_СтатусыДокументов.С4) Тогда
			мВозврат.Добавить(СокрЛП(Выборка.Ссылка.УникальныйИдентификатор()));
		КонецЕсли;
	КонецЦикла;	                                                                
	Возврат мВозврат;
КонецФункции	

Функция ЗаполнитьСтатусы(мСпис) Экспорт
	мКолво = 0;
	Для Каждого мЭлемент Из мСпис Цикл
		мКод = Строка(мЭлемент.ID);
		мДокСсылка = Справочники.МК_ДокументыКЭДО.ПолучитьСсылку(Новый УникальныйИдентификатор(мКод)); 
		Если Не мДокСсылка.Пустая() Тогда   
			мДок = мДокСсылка.ПолучитьОбъект();   
			мСтатус = ПереводСтатусов(мЭлемент.status);
			Если мСтатус <> Неопределено Тогда
				Если мДок.СтатусДокумента <> мСтатус Тогда
					мДок.СтатусДокумента = мСтатус;
					мДок.Записать();   
					мСтатусМассив = Справочники.МК_ДокументыКЭДО.ОпределитьСтатус(мДокСсылка); //   0 элемент - строка, 1 - число.
					мДок.СтатусЧислом = мСтатусМассив[1];
					мДок.Записать();    
					Справочники.МК_ДокументыКЭДО.ОтразитьВРегистре(мДок.ДокументОснование,мДокСсылка,мДок.КодТипаДокумента,мДок.СтатусДокумента,мДок.СтатусЧислом);
				КонецЕсли;	
			КонецЕсли;			
		КонецЕсли;	
	КонецЦикла;		
	Возврат мКолво;   
КонецФункции    

Функция ПереводСтатусов(мКод)  // Тут перевод из выражений МК в перечисления 1С
	мВозврат = Неопределено;
	Если мКод = "draft" Тогда
		мВозврат = Перечисления.МК_СтатусыДокументов.С1
	ИначеЕсли мКод = "signing" Тогда
		мВозврат = Перечисления.МК_СтатусыДокументов.С2
	ИначеЕсли мКод = "expired" Тогда
		мВозврат = Перечисления.МК_СтатусыДокументов.С3	
	ИначеЕсли мКод = "completed" Тогда
		мВозврат = Перечисления.МК_СтатусыДокументов.С4	
	ИначеЕсли мКод = "rejected" Тогда
		мВозврат = Перечисления.МК_СтатусыДокументов.С5
	ИначеЕсли мКод = "invalid" Тогда
		мВозврат = Перечисления.МК_СтатусыДокументов.С6	
	КонецЕсли;
	Возврат мВозврат;     
КонецФункции	

Функция ПолучитьСтатусПодписанияДокумента(мКод) Экспорт
	мВозврат = Неопределено;
	Если мКод = "signing" Тогда
		мВозврат = Перечисления.МК_СтатусыПодписанияДокументов.НаПодписании;
	ИначеЕсли мКод = "completed" Тогда
		мВозврат = Перечисления.МК_СтатусыПодписанияДокументов.Подписан;
	ИначеЕсли мКод = "rejected" Тогда
		мВозврат = Перечисления.МК_СтатусыПодписанияДокументов.Отклонен;		
	ИначеЕсли мКод = "waiting" Тогда
		мВозврат = Перечисления.МК_СтатусыПодписанияДокументов.ВОжидании;		
	КонецЕсли;
	Возврат мВозврат;
КонецФункции	   



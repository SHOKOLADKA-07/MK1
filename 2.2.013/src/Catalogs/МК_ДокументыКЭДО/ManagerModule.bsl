&НаСервере
Функция ОбновитьДокумент(мПарам)      Экспорт 
	// мПарам - структура: ДокСсылка, Статус, Подписанты
	ОО = Обработки.МК_НастройкаВыгрузки.Создать();             // Получили доступ к обработке, в которой находятся служебные функции  
	мДок = мПарам.ДокСсылка.ПолучитьОбъект();   
	мДок.СтатусДокумента = ПереводСтатусов(мПарам.Статус);
	мДок.Подписанты.Очистить();				
		
	// Структура подписанта: "Номер, Имя, ТипПодписи, Статус, ТекущийПодписант, ДатаПодписания, Физлицо"      
	//      approval_id   + - Идентификатор подписанта в маршруте
    //      user_id       + - Идентификатор сотрудника
    //      user_individual_id + - Идентификатор физического лица
    //      user_name     + - Фамилия и имя сотрудника
    //      status        + - Статус подписания
    //      date_sign     + - Дата подписания 
	Для Каждого мПодписант Из мПарам.Подписанты Цикл
		мНоваяСтрока = мДок.Подписанты.Добавить();			
		мНоваяСтрока.Номер = мПодписант.approval_id;            
		мФИО = Неопределено;
		мФЛ = ОО.НайтиФЛ(мПодписант.user_individual_id); 
		Если НЕ (мФЛ = Неопределено) Тогда
			мФИО = мФЛ.Фамилия + " " + мФЛ.Инициалы; 
		Иначе
			мФио = "[" + мПодписант.user_name + "]";  
		КонецЕсли;	                      
		мНоваяСтрока.Имя = мФИО;
		Если мПодписант.pointer Тогда
			мДок.ОчередьПодписания = мФИО;            
			мДок.ТекущийПодписант = мФЛ;   
		КонецЕсли;			            
				
		Если мПодписант.type_signature = "qes" Тогда
			мНоваяСтрока.ТипПодписи = "УКЭП";
		ИначеЕсли мПодписант.type_signature = "nqes" Тогда
			мНоваяСтрока.ТипПодписи = "УНЭП";	
		ИначеЕсли мПодписант.type_signature = "none" Тогда
			мНоваяСтрока.ТипПодписи = "Без подписи";
		КонецЕсли;	
		мНоваяСтрока.Статус = ПолучитьСтатусПодписанияДокумента(мПодписант.status);			
		мНоваяСтрока.ТекущийПодписант = мПодписант.pointer;
		мНоваяСтрока.ДатаПодписания = мДата1(мПодписант.date_sign);
	КонецЦикла;
	Если мДок.ОчередьПодписания = "" Тогда // Это значит, что уже нет действующих подписантов, все завершилось. Ставят задачу показать последнего 
		Если мДок.Подписанты.Количество() > 0 Тогда
			мИндекс = мДок.Подписанты.Количество() - 1;
			мПоследний = мДок.Подписанты[мИндекс];
			мДок.ОчередьПодписания = мПоследний.Имя;
		КонецЕсли;
	КонецЕсли;	
	Попытка
		мДок.Записать(); 			
	Исключение 		
	КонецПопытки;
КонецФункции


#Если Не ВнешнееСоединение Тогда   
	                                                       
&НаСервере
Функция ПолучитьИОбработатьДокументыИзМК()    Экспорт   
	мСписокНезавершенных = ПолучитьСписокНезавершенных();
	мЗапрос = ЗапросДокументовИзМК(мСписокНезавершенных,1);
	Если мЗапрос.Результат Тогда 
		мСписок = мЗапрос.СписокДокументов;
		мколвоСтр = мЗапрос.Страницы.totalPages; 	 
		мИндекс = 0;
		//мСписокКОтправке = Новый Массив;          
		мСписокКОтправке = Новый Соответствие;
		мСписокСсылок = Новый Массив;
		Пока мИндекс < мКолвоСтр Цикл
			Если мИндекс > 0 Тогда
				мЗапрос = ЗапросДокументовИзМК(мСписокНезавершенных,мИндекс+1);     
				мСписок = мЗапрос.СписокДокументов;
			КонецЕсли;	
			Для Каждого мЭлемент Из мСписок Цикл
				// Первая задача - разобрать мЭлемент по реквизитам, каждый - определить в 1С и если все хорошо, записать событие в 
				// справочник МК_ДокументыКЭДО
				мРез = РазобратьДокумент(мЭлемент); 
				Если Не (мРез = Неопределено) И Не мРез.Ссылка = Неопределено Тогда  
					мСписокСсылок.Добавить(мРез.Ссылка);				
					Если мРез.Новый Тогда
						мСписокКОтправке.Вставить(Строка(мРез.КодМК),СокрЛП(мРез.Ссылка.УникальныйИдентификатор()));
					КонецЕсли;	
				КонецЕсли;	
			КонецЦикла;	  
			мИндекс = мИндекс + 1;
		КонецЦикла;
		Если мСписокКОтправке.Количество() > 0 Тогда
			ОтправитьСписокДокументов(мСписокКОтправке);
			//ОтразитьВРегистре(мСписокСсылок);
		КонецЕсли;	 
	КонецЕсли;
	Возврат мЗапрос;
КонецФункции

&НаСервере
Функция ЗапросДокументовИзМК(мСписокНезавершенных, мСтраница)                   
	ОО = Обработки.МК_НастройкаВыгрузки.Создать();             // Получили доступ к обработке, в которой находятся служебные функции  
	мСеанс = ОО.СоздатьСеансСвязи(Истина); 
	мВозврат = Новый Структура("Результат,СписокДокументов,Страницы,ТекстОшибки",Ложь);   
	мТело = Новый Структура;       	
	мТело.Вставить("Ids",мСписокНезавершенных);
	мТело.Вставить("page", мСтраница);
	//мТело.Вставить("perPage", 4);
	Если мСеанс = Неопределено Тогда
		// Ошибка авторизации. Ничего не делаем.
	Иначе         
		мРезультат = Истина;    // Пока эта истина говорит о том, что сеанс создан (получен токен). 
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
	    ЗаписатьJSON(ЗаписьJSON, мТело);	
		ТекстJSON = ЗаписьJSON.Закрыть();  
		
		hЗапрос = ОО.СоздатьHTTPЗапрос("/api/1c-exchange/edms/documents-list", мСеанс);    		
		hЗапрос.УстановитьТелоИзСтроки(ТекстJSON);
		hЗапрос.Заголовки.Вставить("Source","1C Enterprise MK");  
		hОтвет = мСеанс.Соединение.ВызватьHTTPМетод("POST", hЗапрос);  
		ТекстОтвет = hОтвет.ПолучитьТелоКакСтроку();
		Попытка
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(ТекстОтвет);
			СтрОтвет = ПрочитатьJSON(ЧтениеJSON); 
			
			Если ТипЗнч(СтрОтвет) <> Тип("Структура") ИЛИ НЕ СтрОтвет.Свойство("data") Тогда
				// Тут какая-то беда. Или структура не получена, или она неправильная    
				мОшибка = "Неверная структура ответа от МК";
			Иначе     	
				Если СтрОтвет.data.status = "success" Тогда 
					мВозврат.Результат = Истина;                    
					мВозврат.СписокДокументов = СтрОтвет.Data.Items;	
					мВозврат.Страницы = СтрОтвет.Data.pagination;       		                
				Иначе                                                
					мОшибка = "";
					Для Каждого тОшибка Из СтрОтвет.data.error Цикл
						мОшибка = мОшибка + тОшибка;
					КонецЦикла;	                                 
					мВозврат.ТекстОшибки = мОшибка;
				КонецЕсли;	 		
			КонецЕсли;				
		Исключение   
			мОшибка = "Ошибка получения документов. Не удалось преобразовать строку HTTP-ответа в json: "+ТекстОтвет;  
		КонецПопытки; 						
	КонецЕсли;	
	Возврат мВозврат;
КонецФункции   

Функция РазобратьДокумент(мЭлемент) 
	// Что должно быть в документе.
	// document_id        + - Код документа из МК   
	// ext_id             + - Идентификатор ссылки в 1С   
	// name               + - Название документа
    // number             + - Номер документа   
	// type_id            + - Идентификатор типа документа
    // status             + - Статус подписания
    // division_id        + - Идентификатор организации/юрлица
    // date_created       + - Дата создания
    // date_deadline      + - Срок подписания   
	// employee           + - Сотрудник (структура)
	//      user_id       + - ID сотрудника
	//      user_individual_id + - Идентификатор физического лица
    // initiator:         + - Инициатор документа - структура
    //      id:           + - Идентификатор сотрудника
    //      individual_id + - Идентификатор физического лица
    //      name          + - Фамилия и имя сотрудника
    // file_path          + - Путь до файла документа
	// approvals          + - Подписанты (массив)
    //      approval_id   + - Идентификатор подписанта в маршруте
    //      user_id       + - Идентификатор сотрудника
    //      user_individual_id + - Идентификатор физического лица
    //      user_name     + - Фамилия и имя сотрудника
    //      status        + - Статус подписания
    //      date_sign     + - Дата подписания     	
		
	// Возвращаем: если все нормально определилось - IDДокументаМК, иначе- Неопределено. 
	мВозврат = Неопределено;
	мОшибка = Ложь;          
	ОО = Обработки.МК_НастройкаВыгрузки.Создать();             // Получили доступ к обработке, в которой находятся служебные функции  
	мСтрока = Новый Структура("Сотрудник, Организация, МК_КодДокумента, ДатаСоздания,
				              | НазваниеДокумента,НомерДокумента,ТипДокументаМК,СтатусДокумента,					
							  | КрайнийСрокПодписания, Инициатор, ПутьКФайлу, Подписанты, ДокСсылка1С");
	//Временно попробую определять сотрудника по ID именно сотрудника, потому что ID организаций пока не прилетают.
	
	//Если мЭлемент.Свойство("employee") Тогда   
	//	мЕмпл = мЭлемент.employee;
	//	Если Не (мЕмпл.user_id = Неопределено) Тогда
	//		мСтрока.Сотрудник = ОО.НайтиСотрудника(мЕмпл.user_id);   
	//		Если мСтрока.Сотрудник = Неопределено Тогда
	//			мОшибка = Истина;
	//		КонецЕсли
	//	Иначе	
	//		мОшибка = Истина;
	//	КонецЕсли;		
	//Иначе          
	//	мОшибка = Истина;
	//КонецЕсли;	
	//Если мОшибка = Ложь Тогда //  И мЭлемент.Свойство("division_id") Тогда
		//Если Не (мЭлемент.division_id = Неопределено) Тогда
		//	мСтрока.Организация = НайтиОрганизацию(мЭлемент.division_id);   
		//	Если мСтрока.Организация = Справочники.Организации.ПустаяСсылка() Тогда
		//		мОшибка = Истина;
		//	КонецЕсли;
		//Иначе	                 
		//	мОшибка = Истина;
		//КонецЕсли;
	//	мСтрока.Организация = мСтрока.Сотрудник.ГоловнаяОрганизация;  // Пока не смотрим на организацию из МК.
	//Иначе                
	//	мОшибка = Истина;
	//КонецЕсли;	     
	
	// Сотрудника теперь определяем по новым правилам: у нас есть ID физлица и ID организации. По ним надо найти сотрудника
	// Поэтому сначала определим организацию:      	
	
	Если мЭлемент.Свойство("division_id") Тогда
		Если Не (мЭлемент.division_id = Неопределено) И НЕ ПустаяСтрока(мЭлемент.division_id) Тогда			
			мСтрока.Организация = Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор(мЭлемент.division_id)); 
			Если мСтрока.Организация = Справочники.Организации.ПустаяСсылка() Тогда
				мОшибка = Истина;
			КонецЕсли;
		Иначе	                 
			мОшибка = Истина;
		КонецЕсли;		
	Иначе                
		мОшибка = Истина;
	КонецЕсли;	                                            

	Если мОшибка = Ложь И мЭлемент.Свойство("employee") Тогда   
		мЕмпл = мЭлемент.employee;
		Если Не (мЕмпл.user_individual_id = Неопределено) И НЕ ПустаяСтрока(мЕмпл.user_individual_id) Тогда
			мФЛ = ОО.НайтиФЛ(мЕмпл.user_individual_id);   
			Если мФЛ = Неопределено Тогда
				мОшибка = Истина;
			Иначе
				мСотр = Неопределено;
				мСписСотр = ОО.СписокСотрудниковПоФизлицу(мСтрока.Организация,мФЛ);  // В этой функции подбираются только основные сотрудники или внешние
				Если мСписСотр.Следующий() Тогда                                     // совместители. Если все хорошо, вернется одна запись. Если больше - нас не волнует,
					мСотр = мСписСотр.СотрудникСсылка;                               // возьмем первого.
				КонецЕсли;		
				Если мСотр = Неопределено Тогда
					мОшибка = Истина;
				Иначе     
					мСтрока.Сотрудник = мСотр; 
				КонецЕсли;	
			КонецЕсли
		Иначе	
			мОшибка = Истина;
		КонецЕсли;		
	Иначе          
		мОшибка = Истина;
	КонецЕсли;	   
	                           
	Если мОшибка = Ложь И мЭлемент.Свойство("document_id") Тогда
		мСтрока.МК_КодДокумента = мЭлемент.document_id; 
	Иначе                
		мОшибка = Истина;
	КонецЕсли;	   
	Если мОшибка = Ложь И мЭлемент.Свойство("number") Тогда
		мСтрока.НомерДокумента = мЭлемент.number; 
	Иначе                
		мОшибка = Истина;
	КонецЕсли;	 
	Если мОшибка = Ложь И мЭлемент.Свойство("name") Тогда
		мСтрока.НазваниеДокумента = мЭлемент.name; 
	Иначе                
		мОшибка = Истина;
	КонецЕсли;                                           
	Если мОшибка = Ложь И мЭлемент.Свойство("ext_id") Тогда
		мСтрока.ДокСсылка1С = мЭлемент.ext_id; 
	Иначе                
		мОшибка = Истина;
	КонецЕсли;                                           	
	Если мОшибка = Ложь И мЭлемент.Свойство("type_id") Тогда		
		мСтрока.ТипДокументаМК = Справочники.МК_ВидыДокументовМояКоманда.НайтиПоРеквизиту("ID", Строка(мЭлемент.type_id));
	Иначе                
		мОшибка = Истина;
	КонецЕсли;	
	Если мОшибка = Ложь И мЭлемент.Свойство("status") Тогда
		мСтрока.СтатусДокумента = ПереводСтатусов(мЭлемент.status); 
		Если мСтрока.СтатусДокумента = Неопределено Тогда
			мОшибка = Истина;
		КонецЕсли;	
	Иначе                
		мОшибка = Истина;
	КонецЕсли;	

	Если мОшибка = Ложь И мЭлемент.Свойство("date_created") Тогда
		мСтрока.ДатаСоздания = мДата1(мЭлемент.date_created);
	Иначе                
		мОшибка = Истина;
	КонецЕсли;	                                             
	
	Если мОшибка = Ложь И мЭлемент.Свойство("date_deadline") Тогда
		мСтрока.КрайнийСрокПодписания = мДата(мЭлемент.date_deadline);
	Иначе                
		мОшибка = Истина;
	КонецЕсли;	                                             
	
	Если мОшибка = Ложь И мЭлемент.Свойство("initiator") Тогда   
		// Сначала поищем инициатора как сотрудника? Наверное хватит и физлица.  
		мФИО = Неопределено;
		мИни = мЭлемент.initiator;
		Если Не (мИни.user_individual_id = Неопределено) И НЕ ПустаяСтрока(мИни.user_individual_id) Тогда   
			мФЛ = ОО.НайтиФЛ(мИни.user_individual_id); 
			Если НЕ мФЛ = Неопределено Тогда
				мФИО = мФЛ.Фамилия + " " + мФЛ.Инициалы; 
			КонецЕсли;	                               
		КонецЕсли;
		Если мФИО = Неопределено Тогда
			// Физлицо не найдено. Нужно достать ФИО из другого массива.						
			мФИО = "[" + мИни.name + "]";    
		КонецЕсли;
		мСтрока.Инициатор = мФИО;
	Иначе                
		мОшибка = Истина;
	КонецЕсли; 
	Если мОшибка = Ложь И мЭлемент.Свойство("file_path") Тогда
		мСтрока.ПутьКФайлу = мЭлемент.file_path;	
	КонецЕсли;
		
	Если мОшибка = Ложь И мЭлемент.Свойство("approvals") Тогда  
		мСписок = мЭлемент.approvals;
		мСтрока.Подписанты = Новый Массив;
		Для Каждого мПодписант Из мСписок Цикл
			мНовый = Новый Структура("Номер, Имя, ТипПодписи, Статус, ТекущийПодписант, ДатаПодписания, Физлицо");
			мНовый.Номер = мПодписант.approval_id;
			мНовый.Имя = мПодписант.user_name;			
			мНовый.ТипПодписи = мПодписант.type_signature; 
			//мНовый.СоставРоли = мПодписант.user_ids;
			мНовый.Статус = мПодписант.status;    
			мНовый.ТекущийПодписант = мПодписант.pointer;  
			мНовый.ДатаПодписания = мДата1(мПодписант.date_sign);
			мНовый.Физлицо = мПодписант.user_individual_id;
			мСтрока.Подписанты.Добавить(мНовый);
		КонецЦикла;	
	Иначе                
		мОшибка = Истина;
	КонецЕсли;  

	
	Если мОшибка = Ложь  Тогда    // Все определилось хорошо
		// Теперь - записать документ в справочник.
		мВозврат = ЗаписатьДокумент(мСтрока,1,Неопределено);  
	КонецЕсли;	
	Возврат мВозврат;
КонецФункции

Функция ЗаписатьДокумент(мДокумент, мРежим, мЗ)  Экспорт    // мРежим: 1 - массовое получение заявлений, 2 - обработка ответа по изменяемому заявлению
	мВозврат = Новый Структура("КодМК, Ссылка, Новый");
	мНовый = Ложь;
	мРез = Неопределено;
	ОО = Обработки.МК_НастройкаВыгрузки.Создать();             // Получили доступ к обработке, в которой находятся служебные функции  	
	Если мРежим = 1 Тогда 	     
		мСсылка = Неопределено;   
		// Прилетает такая структура : +Сотрудник, +Организация, +МК_КодДокумента, +ДатаСоздания,
		//		              | +НазваниеДокумента,+НомерДокумента,+ТипДокументаМК,+СтатусДокумента,					
		//					  | +КрайнийСрокПодписания, +Инициатор, +ПутьКФайлу, Подписанты, ДокСсылка1С");
		Если Не (мДокумент.ДокСсылка1С = Неопределено) Тогда
			мСсылка = Справочники.МК_ДокументыКЭДО.ПолучитьСсылку(Новый УникальныйИдентификатор(мДокумент.ДокСсылка1С)); 
		КонецЕсли;	

		Если мСсылка = Неопределено ИЛИ мСсылка.Пустая() Или мСсылка.ПометкаУдаления = Истина ИЛИ СтрНачинаетсяС(Строка(мСсылка),"<Объект не найден>")  Тогда   //  Не нашли, можно добавлять
			НовыйЭлемент = Справочники.МК_ДокументыКЭДО.СоздатьЭлемент(); 
			мСсылка = НовыйЭлемент.Ссылка;
			мНовый = Истина;  
			мВозврат.Новый = Истина;
		Иначе        
			НовыйЭлемент = мСсылка.ПолучитьОбъект();
			мВозврат.Новый = Ложь;
		КонецЕсли;			     
		мВозврат.КодМК = мДокумент.МК_КодДокумента;	
		
		НовыйЭлемент.Сотрудник = мДокумент.Сотрудник;  
		НовыйЭлемент.ОрганизацияСсылка = мДокумент.Организация;      
		НовыйЭлемент.МК_КодДокумента = мДокумент.МК_КодДокумента;
		НовыйЭлемент.ТипДокументаМК = мДокумент.ТипДокументаМК;
		НовыйЭлемент.ДатаДокумента = мДокумент.ДатаСоздания; 	
		НовыйЭлемент.Инициатор = мДокумент.Инициатор;
		НовыйЭлемент.ПутьДоФайлаДокумента = мДокумент.ПутьКФайлу;  
		НовыйЭлемент.СтатусДокумента = мДокумент.СтатусДокумента;       
		НовыйЭлемент.Наименование = мДокумент.НазваниеДокумента;  
		НовыйЭлемент.НомерДокумента = мДокумент.НомерДокумента;   
		НовыйЭлемент.КрайнийСрокПодписания = мДокумент.КрайнийСрокПодписания;
		
	Иначе     
		//НовыйЭлемент = мЗ.ПолучитьОбъект();                       
		//НовыйЭлемент.СтатусЗаявления = мЗаявление.СтатусЗаявления;
	КонецЕсли;	
		Если не мНовый Тогда  // Очистим табличную часть
			НовыйЭлемент.Подписанты.Очистить();				
		КонецЕсли;	                                          
		// Структура подписанта: "Номер, Имя, ТипПодписи, Статус, ТекущийПодписант, ДатаПодписания, Физлицо"
		Для Каждого мПодписант Из мДокумент.Подписанты Цикл
			мНоваяСтрока = НовыйЭлемент.Подписанты.Добавить();			
			мНоваяСтрока.Номер = мПодписант.Номер;            
			мФИО = Неопределено;
			мФЛ = ОО.НайтиФЛ(мПодписант.Физлицо); 
			Если НЕ (мФЛ = Неопределено) Тогда
				мФИО = мФЛ.Фамилия + " " + мФЛ.Инициалы; 
			Иначе
				мФио = "[" + мПодписант.Имя + "]";  
			КонецЕсли;	                      
			мНоваяСтрока.Имя = мФИО;
			Если мПодписант.ТекущийПодписант Тогда
				НовыйЭлемент.ОчередьПодписания = мФИО;            
				НовыйЭлемент.ТекущийПодписант = мФЛ;   
			КонецЕсли;			            
					
			Если мПодписант.ТипПодписи = "qes" Тогда
				мНоваяСтрока.ТипПодписи = "УКЭП";
			ИначеЕсли мПодписант.ТипПодписи = "nqes" Тогда
				мНоваяСтрока.ТипПодписи = "УНЭП";	
			ИначеЕсли мПодписант.ТипПодписи = "none" Тогда
				мНоваяСтрока.ТипПодписи = "Без подписи";
			КонецЕсли;	
			мНоваяСтрока.Статус = ПолучитьСтатусПодписанияДокумента(мПодписант.Статус);			
			мНоваяСтрока.ТекущийПодписант = мПодписант.ТекущийПодписант;
			мНоваяСтрока.ДатаПодписания = мПодписант.ДатаПодписания;
		КонецЦикла;
		Если НовыйЭлемент.ОчередьПодписания = "" Тогда // Это значит, что уже нет действующих подписантов, все завершилось. Ставят задачу показать последнего 
			Если НовыйЭлемент.Подписанты.Количество() > 0 Тогда
				мИндекс = НовыйЭлемент.Подписанты.Количество() - 1;
				мПоследний = НовыйЭлемент.Подписанты[мИндекс];
				НовыйЭлемент.ОчередьПодписания = мПоследний.Имя;
			КонецЕсли;
		КонецЕсли;	

		Попытка
			НовыйЭлемент.Записать(); 
			мВозврат.Ссылка = НовыйЭлемент.Ссылка;
		Исключение    		
			
		КонецПопытки;	               
	Возврат мВозврат;
КонецФункции	    


Функция мДата(мСтрока) 
	мСтр = СтроковыеФункцииКлиентСервер.СтрокаВДату(мСтрока, "ДФ='Д.М.Г'");
	Возврат Дата(мСтр);
КонецФункции

Функция мДата1(мСтрока) 
	//мСтр = СтроковыеФункцииКлиентСервер.СтрокаВДату(мСтрока, "ДФ='Д.М.Г Ч:М:C'"); // Не работает с временем.
	// Сначала надо найти часы и проверить: если два символа, хорошо. Иначе добавить ведущий ноль
	// Найдем первый пробел  
	мСтр1 = Неопределено;
	Если Не (мСтрока = Неопределено) Тогда
		мИндекс = СтрНайти(мСтрока, " "); // строки индексируются с единицы
		мИндекс1 = СтрНайти(мСтрока,":");
		мЧасы = Сред(мСтрока, мИндекс+1, мИндекс1- (мИндекс+1));
		Если СтрДлина(мЧасы)= 1 Тогда
			мЧасы = "0"+мЧасы;
		КонецЕсли;	
		мСтр1 = Лев(мСтрока,мИндекс-1)+ мЧасы + Прав(мСтрока, СтрДлина(мСтрока) - мИндекс1);
		мСтр1 = СтрЗаменить(мСтр1,"-","");  
		мСтр1 = СтрЗаменить(мСтр1,".","");
		мСтр1 = СтрЗаменить(мСтр1,":","");
		мСтр1 =  Дата(мСтр1);
	КонецЕсли;	
	Возврат мСтр1;
КонецФункции


Функция ПолучитьИмяФайла(мПутьКФайлу)  Экспорт     	
	// Из МК приходит полное имя с указанием сервера и т.д. А мне нужно имя начиная с "/storage/edms/documents/" и т.д.
	// Поэтому нужно откусить начало. 
	мДлина = СтрДлина(мПутьКФайлу);
	мИндекс = СтрНайти(мПутьКФайлу, "/storage/edms/documents/"); 
	Возврат Прав(мПутьКФайлу, мДлина - мИндекс+1);
КонецФункции  


&НаСервере
Процедура ОтразитьВРегистре(мСсылкаДокОсн,мСсылкаДокКЭДО,МК_Код,мСтатус,мКодСтатуса) Экспорт
	Если ЗначениеЗаполнено(мСсылкаДокОсн) Тогда
		НаборЗаписей = РегистрыСведений.МК_СостояниеДокументовКЭДО.СоздатьМенеджерЗаписи(); 
		НаборЗаписей.СсылкаНаДокумент = мСсылкаДокОсн;  
		НаборЗаписей.Прочитать();
		Если Не НаборЗаписей.Выбран() Тогда  
			НаборЗаписей.СсылкаНаДокумент = мСсылкаДокОсн; 
		КонецЕсли;	
		Если МК_Код = "195" Тогда       // 195 - код трудового договора
    		НаборЗаписей.СсылкаНаДоговор = мСсылкаДокКЭДО; 
			НаборЗаписей.СтатусДоговора = мСтатус;
			НаборЗаписей.КодСтатуса1 = мКодСтатуса;
		Иначе       	
			НаборЗаписей.СсылкаНаПриказ = мСсылкаДокКЭДО; 
	   		НаборЗаписей.СтатусПриказа = мСтатус;
	   		НаборЗаписей.КодСтатуса2 = мКодСтатуса;		
		КонецЕсли;   	
		НаборЗаписей.Записать();   
	КонецЕсли;	
КонецПроцедуры	

Процедура СоздатьЗаписиРегистраДокКЭДО() Экспорт
	Выборка = Справочники.МК_ДокументыКЭДО.Выбрать(); 
	Пока Выборка.Следующий() Цикл;                                                                          
		мСт = ОпределитьСтатус(Выборка.Ссылка);
		// В справочник тоже надо записать
		ОтразитьВРегистре(Выборка.ДокументОснование,Выборка.Ссылка,Выборка.КодТипаДокумента,мСт[0],мСт[1]); 
	КонецЦикла;	                  
КонецПроцедуры	     

Процедура ОтразитьСостояниеЗаписиВРегистре(мСсылка) Экспорт	
	//мДок = мСсылка.ПолучитьОбъект();    
	мСт = ОпределитьСтатус(мСсылка);
	ОтразитьВРегистре(мСсылка.ДокументОснование,мСсылка,мСсылка.КодТипаДокумента,мСт[0],мСт[1]);	
КонецПроцедуры

Функция ОпределитьСтатус(мДокКЭДО)  Экспорт 
	мСт = Новый Массив;
	Если мДокКЭДО.Отправлен Тогда
		Если мДокКЭДО.СтатусДокумента = Перечисления.МК_СтатусыДокументов.С1 Тогда  // Черновик			
			//Если Не ЗначениеЗаполнено(мДокКЭДО.ИмяФайлаПодписи) Тогда  // Черновик не может быть подписан
				мСтатус = "Отправлен как черновик";   
				мКодСтатуса = 3;
			//КонецЕсли;	
		ИначеЕсли мДокКЭДО.СтатусДокумента = Перечисления.МК_СтатусыДокументов.С2 Тогда
			//Если Не ЗначениеЗаполнено(мДокКЭДО.ИмяФайлаПодписи) ТОгда				
				мСтатус = "На подписании";                
				мКодСтатуса = 4;
			//КонецЕсли;
		ИначеЕсли мДокКЭДО.СтатусДокумента = Перечисления.МК_СтатусыДокументов.С3 Тогда
			мСтатус = "Просрочен";                
			мКодСтатуса = 5;
		ИначеЕсли мДокКЭДО.СтатусДокумента = Перечисления.МК_СтатусыДокументов.С4 Тогда
			мСтатус = "Выполнен";                
			мКодСтатуса = 7;  
		ИначеЕсли мДокКЭДО.СтатусДокумента = Перечисления.МК_СтатусыДокументов.С5 Тогда
			мСтатус = "Отклонен";                
			мКодСтатуса = 6;
	    ИначеЕсли мДокКЭДО.СтатусДокумента = Перечисления.МК_СтатусыДокументов.С6 Тогда
			мСтатус = "Недействителен";                
			мКодСтатуса = 8;  	
		КонецЕсли;
	Иначе   
		Если мДокКЭДО.СтатусДокумента = Перечисления.МК_СтатусыДокументов.С6 Тогда
			мСтатус = "Недействителен";                
			мКодСтатуса = 8; 
		ИначеЕсли Не ЗначениеЗаполнено(мДокКЭДО.ИмяФайлаПодписи) ТОгда
			мСтатус = "Не отправлен";
			мКодСтатуса = 1;
		Иначе	                     
			мСтатус = "Подписан, не отправлен";
			мКодСтатуса = 2;
		КонецЕсли;
	КонецЕсли;	
	мСт.Добавить(мСтатус);
	мСт.Добавить(мКодСтатуса);
	Возврат мСт;
КонецФункции	    	

&НаСервере
Функция ЗапросСтатусовДокументовКЭДО(мСписДок)       Экспорт                      
	// Если отправить пустрой массив, вернется все, что изменилось с прошлого раза
	// Если список конкретных документов - то статусы по ним.
	ОО = Обработки.МК_НастройкаВыгрузки.Создать();             // Получили доступ к обработке, в которой находятся служебные функции  
	мСеанс = ОО.СоздатьСеансСвязи(Истина); 
	мВозврат = Новый Массив; 
	мТело = Новый Структура;       	
	мТело.Вставить("Ids",мСписДок);
	Если мСеанс = Неопределено Тогда
		// Ошибка авторизации. Ничего не делаем.
	Иначе         
		мРезультат = Истина;    // Пока эта истина говорит о том, что сеанс создан (получен токен). 		
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
	    ЗаписатьJSON(ЗаписьJSON, мТело);	
		ТекстJSON = ЗаписьJSON.Закрыть();   	
		
		hЗапрос = ОО.СоздатьHTTPЗапрос("/api/1c-exchange/edms/documents-statuses", мСеанс);    
		hЗапрос.Заголовки.Вставить("Source","1C Enterprise MK");
		hЗапрос.УстановитьТелоИзСтроки(ТекстJSON);
		hОтвет = мСеанс.Соединение.ВызватьHTTPМетод("POST", hЗапрос);  
		ТекстОтвет = hОтвет.ПолучитьТелоКакСтроку();
		Попытка
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(ТекстОтвет);
			СтрОтвет = ПрочитатьJSON(ЧтениеJSON); 
			Если ТипЗнч(СтрОтвет) <> Тип("Структура") ИЛИ НЕ СтрОтвет.Свойство("data") Тогда
				// Тут какая-то беда. Или структура не получена, или она неправильная  
			Иначе     
				мВозврат = СтрОтвет.Data.Items;	
			КонецЕсли;	
		Исключение   
			мОшибка = "Ошибка получения справочника. Не удалось преобразовать строку HTTP-ответа в json: "+ТекстОтвет;  
			Сообщить(мОшибка);
		КонецПопытки; 						
	КонецЕсли;	
	Возврат мВозврат;
КонецФункции


	Для Каждого мЭлемент Из мВО Цикл
		мИзменение = Ложь;
		мНаим = мЭлемент.Наименование;
		мСсылка = Справочники.МК_ВыгружаемыеОбъекты.НайтиПоНаименованию(мНаим);     
		Если Не мСсылка.Пустая() Тогда   
			мОбъект = мСсылка.ПолучитьОбъект();
			Если мОбъект.Метод <> мЭлемент.Метод Тогда
				мОбъект.Метод = мЭлемент.Метод;
                мИзменение = Истина;
			КонецЕсли;
		Иначе     
			мОбъект = Справочники.МК_ВыгружаемыеОбъекты.СоздатьЭлемент();
			мОбъект.Наименование = мЭлемент.Наименование;
			мОбъект.Метод = мЭлемент.Метод;
			мИзменение = Истина;
		КонецЕсли;
		Если мИзменение Тогда
			мОбъект.Записать();
		КонецЕсли;			
	КонецЦикла;	

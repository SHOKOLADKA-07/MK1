


&НаСервере
Функция ОбновитьНаСервере()
	// Надо получить список заявлений.
	мРез = Справочники.МК_ЗаявленияСотрудников.ПолучитьИОбработатьЗаявленияИзМК();
	Возврат мРез;
КонецФункции

&НаКлиенте
Процедура Обновить(Команда)
	мРез = ОбновитьНаСервере(); 
	Если мРез.Результат Тогда
		Элементы.Список.Обновить();  
	Иначе	
		ПоказатьПредупреждение(,"Операция не удалась: " + мРез.ТекстОшибки);
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура Согласовать(Команда)
	ИсполнитьОтклонить(1);	
КонецПроцедуры

&НаКлиенте
Процедура Отклонить(Команда)
	ИсполнитьОтклонить(2); 
КонецПроцедуры  

&НаКлиенте
Процедура ИсполнитьОтклонить(мРежим) 
	//Здесь остановился!
	// Надо определить - действительно этот пользователь должен что-то сделать?
	мПользователь = ЭтаФорма.Пользователь;  
	мЗ = Элементы.Список.ТекущаяСтрока;	
	
	мРез = ИсполнитьОтклонитьСервер(мРежим, мПользователь, мЗ);  
	ОповеститьОбИзменении(мЗ);
	//Элементы.Подписанты.Обновить();
	//ЭтаФорма.ОбновитьОтображениеДанных(); 
	Если Не мРез.Результат Тогда             
		ПоказатьПредупреждение(,"Операция не удалась: " + мРез.ТекстОшибки);
	КонецЕсли;	
КонецПроцедуры

Функция ИсполнитьОтклонитьСервер(мРежим, мПользователь, мЗ)     
	мНашел = Ложь;   
	мРез = Новый Структура("Результат,ТекстОшибки", Ложь, "Не ваша очередь для действий");
	мТЗ = мЗ.СоставРоли;
	Для Каждого мСтр Из мТЗ Цикл
		Если мСтр.Подписант = мПользователь Тогда
			мНомерУчастника = мСтр.Номер;
			мНашел = Истина;
			Прервать;
		КонецЕсли;	
	КонецЦикла;	     
	Если мНашел Тогда
		мМК_КодЗаявления = мЗ.МК_КодЗаявления;
		мДокумент1С = мЗ.Документ1С;    
		мРез = Справочники.МК_ЗаявленияСотрудников.ИсполнитьОтклонитьНаСервере(мРежим, мПользователь, мМК_КодЗаявления, мНомерУчастника, мДокумент1С);   
		Если мРез.Результат Тогда
			мЭлемент = мРез.Подписанты;
			мСтрока = Новый Структура("СтатусЗаявления, Подписанты");
	
			мСтрока.СтатусЗаявления = Справочники.МК_ЗаявленияСотрудников.ПолучитьСтатусЗаявления(мЭлемент.status); 
	
			мСписок = мЭлемент.approvals;
			мСтрока.Подписанты = Новый Массив;
			Для Каждого мПодписант Из мСписок Цикл
				мНовый = Новый Структура("Номер, Имя, Тип, ТипПодписи, СоставРоли, Статус, ТекущийПодписант, МассивИмен");
				мНовый.Номер = мПодписант.id;
				мНовый.Имя = мПодписант.name;
				мНовый.Тип = мПодписант.type;
				мНовый.ТипПодписи = мПодписант.type_signature; 
				мНовый.СоставРоли = мПодписант.user_ids;
				мНовый.Статус = мПодписант.status;    
				мНовый.ТекущийПодписант = мПодписант.pointer;  
				Если мПодписант.Свойство("user_names") Тогда   
					мНовый.МассивИмен = мПодписант.user_names;
				КонецЕсли;	
				мСтрока.Подписанты.Добавить(мНовый);
			КонецЦикла;	                                                     
			мЗаявление = Справочники.МК_ЗаявленияСотрудников.ЗаписатьЗаявление(мСтрока,2,мЗ);  			
		КонецЕсли;		
	КонецЕсли;	
	Возврат мРез;     
КонецФункции  



&НаСервере
Процедура ПрименятьОрганизациюПриИзмененииНаСервере()
	Список.Отбор.Элементы.Очистить();
	мПоказОрг = ЭтаФорма.ПрименятьОрганизацию;		
	мОрг = ЭтаФорма.Организация;
	Если мПоказОрг И ЗначениеЗаполнено(мОрг) Тогда       	
		ЭлементОтбора = Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	    ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Организация");
	    ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	    ЭлементОтбора.Использование = Истина;
	    ЭлементОтбора.ПравоеЗначение = мОрг; 
	КонецЕсли;	
	мПоказСотр = ЭтаФорма.ПрименятьСотрудника;		
	мСотр = ЭтаФорма.Сотрудник;
	Если мПоказСотр И ЗначениеЗаполнено(мСотр) Тогда       	
		ЭлементОтбора = Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	    ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Сотрудник");
	    ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	    ЭлементОтбора.Использование = Истина;
	    ЭлементОтбора.ПравоеЗначение = мСотр; 
	КонецЕсли;  
	мПоказСтатус = ЭтаФорма.ПрименятьСтатусЗаявления;		
	мСтатус = ЭтаФорма.СтатусЗаявления;
	Если мПоказСтатус И ЗначениеЗаполнено(мСтатус) Тогда       	
		ЭлементОтбора = Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	    ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("СтатусЗаявления");
	    ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	    ЭлементОтбора.Использование = Истина;
	    ЭлементОтбора.ПравоеЗначение = мСтатус; 
	КонецЕсли;
    мПоказТип = ЭтаФорма.ПрименятьТипДокументаМК;		
	мТип = ЭтаФорма.ТипДокументаМК;
	Если мПоказТип И ЗначениеЗаполнено(мТип) Тогда       	
		ЭлементОтбора = Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	    ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ВидДокументаМК");
	    ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	    ЭлементОтбора.Использование = Истина;
	    ЭлементОтбора.ПравоеЗначение = мТип; 
	КонецЕсли;   
	мПоказДаты = ЭтаФорма.ПрименятьДату;		
	мДата = ЭтаФорма.ДатаСоздания;
	Если мПоказДаты И ЗначениеЗаполнено(мДата) Тогда       	
		ЭлементОтбора = Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	    ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ДатаСоздания");
	    ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	    ЭлементОтбора.Использование = Истина;
	    ЭлементОтбора.ПравоеЗначение = мДата; 
	КонецЕсли; 
КонецПроцедуры


&НаКлиенте
Процедура ОбновитьФильтр(Элемент)
	ПрименятьОрганизациюПриИзмененииНаСервере();
	Элементы.Список.Обновить();
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	// Надо определить текущего пользователя, как физлицо
	мПользователь = Пользователи.ТекущийПользователь().ФизическоеЛицо;  
	Если ЗначениеЗаполнено(мПользователь) Тогда
		ЭтотОбъект.Пользователь = мПользователь;
	Иначе
		Сообщить("Внимание! Не указано физическое лицо в справочнике пользователей ЗУП для текущего пользователя. Активные действия будут невозможны.")
	КонецЕсли;	
КонецПроцедуры




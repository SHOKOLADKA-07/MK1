

&НаКлиенте
Процедура ПосмотретьФайл(Команда)	
	мФайл = ЭтаФорма.Объект.МК_ПутьКФайлу;    
	мPDF = ПолучитьФайл(мФайл); 
	Если НЕ (мPDF = Неопределено) Тогда
		мPDF.Показать("Заявление"); 
	КонецЕсли;  
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьФайл(мФайл) 
	Возврат Справочники.МК_ЗаявленияСотрудников.СкачатьФайлНаСервере(мФайл,1);  
КонецФункции


&НаСервере
Функция СоздатьДокументНаСервере()
	мВозврат = Новый Массив;	
	мИмяФормы = Неопределено;                 
    	
	мЗначения = Новый Структура("Организация, Сотрудник", Объект.Организация, Объект.Сотрудник);
	ДанныеОтсутствия = Неопределено;   
	мВидОтсутствия = Объект.ТипДокумента1С;

	Если ТипЗнч(мВидОтсутствия) = Тип("ПеречислениеСсылка.МК_ОбрабатываемыеВидыДокументовПоЗаявлениям") Тогда  // Предопределенные элементы   
		мПараметры = Новый Структура;
		Если мВидОтсутствия = Перечисления.МК_ОбрабатываемыеВидыДокументовПоЗаявлениям.Командировка Тогда     
			мИмяФормы = "Документ.Командировка.Форма.ФормаДокумента";    
			мЗначения.Вставить("ДатаНачала", Объект.ДатаНачала);
			мЗначения.Вставить("ДатаОкончания", Объект.ДатаОкончания);
			мЗначения.Вставить("ДатаКомандировки", Объект.ДатаНачала);
			мЗначения.Вставить("ДатаНачалаСобытия", Объект.ДатаНачала);
		    //мЗначения.Вставить("ВнутрисменнаяКомандировка", НЕ мОбъект.Целосменный);
			//мЗначения.Вставить("ОплачиватьЧасов", мОбъект.КолвоЧасовОтсутствия);    
			мЗначения.Вставить("Действие", "Заполнить"); 
			мЗначения.Вставить("ЗаполнитьПоПараметрамЗаполнения", Истина);    
			мПараметры.Вставить("Основание", мЗначения);
		ИначеЕсли мВидОтсутствия = Перечисления.МК_ОбрабатываемыеВидыДокументовПоЗаявлениям.Отгул Тогда    
			мИмяФормы = "Документ.Отгул.Форма.ФормаДокумента";    
			мЗначения.Вставить("ДатаНачала", Объект.ДатаНачала);
			мЗначения.Вставить("ДатаОкончания", Объект.ДатаОкончания);
			//мЗначения.Вставить("ДатаОтсутствия", Объект.ДатаНачала);			
		    //мЗначения.Вставить("ВнутрисменнаяКомандировка", НЕ мОбъект.Целосменный);
			//мЗначения.Вставить("ОплачиватьЧасов", мОбъект.КолвоЧасовОтсутствия);    
			мЗначения.Вставить("Действие", "Заполнить"); 
			мЗначения.Вставить("ЗаполнитьПоПараметрамЗаполнения", Истина);    
			мПараметры.Вставить("Основание", мЗначения);

		//ИначеЕсли мВидОтсутствия.Объект1С = "Отпуск по беременности и родам" Тогда	
		ИначеЕсли мВидОтсутствия = Перечисления.МК_ОбрабатываемыеВидыДокументовПоЗаявлениям.ОтпускПоУходуЗаРебенком Тогда	 
			мИмяФормы = "Документ.ОтпускПоУходуЗаРебенком.Форма.ФормаДокумента";    
			мЗначения.Вставить("ДатаНачала", Объект.ДатаНачала);
			мЗначения.Вставить("ДатаОкончания", Объект.ДатаОкончания);
			мЗначения.Вставить("ДатаНачалаПФР", Объект.ДатаНачала);
			мЗначения.Вставить("ОсновнойСотрудник", Объект.Сотрудник);     
			мЗначения.Вставить("Сотрудник", Объект.Сотрудник.ФизическоеЛицо);

			
		    //мЗначения.Вставить("ВнутрисменнаяКомандировка", НЕ мОбъект.Целосменный);
			//мЗначения.Вставить("ОплачиватьЧасов", мОбъект.КолвоЧасовОтсутствия);    
			мЗначения.Вставить("Действие", "ЗаполнитьПоПараметрамЗаполнения"); 
			//мЗначения.Вставить("ЗаполнитьПоПараметрамЗаполнения", Истина);    
			мПараметры.Вставить("Основание", мЗначения);     
		ИначеЕсли мВидОтсутствия = Перечисления.МК_ОбрабатываемыеВидыДокументовПоЗаявлениям.ОтсутствиеССохранениемОплаты Тогда	 
			мИмяФормы = "Документ.ОплатаПоСреднемуЗаработку.Форма.ФормаДокумента";    
			мЗначения.Вставить("ДатаНачала", Объект.ДатаНачала);
			мЗначения.Вставить("ДатаОкончания", Объект.ДатаОкончания);
			мЗначения.Вставить("ВидВремени",Объект.МК_ВидЗаявления.ВидВремени);	
		    //мЗначения.Вставить("ВнутрисменнаяКомандировка", НЕ мОбъект.Целосменный);
			//мЗначения.Вставить("ОплачиватьЧасов", мОбъект.КолвоЧасовОтсутствия);    
			мЗначения.Вставить("Действие", "Заполнить"); 
			мЗначения.Вставить("ЗаполнитьПоПараметрамЗаполнения", Истина);    
			мПараметры.Вставить("Основание", мЗначения); 
			
		ИначеЕсли мВидОтсутствия = Перечисления.МК_ОбрабатываемыеВидыДокументовПоЗаявлениям.Увольнение Тогда	 
			мИмяФормы = "Документ.Увольнение.Форма.ФормаДокумента";    
			мЗначения.Вставить("ДатаУвольнения", Объект.ДатаНачала);
			//мЗначения.Вставить("ДатаОкончания", Объект.ДатаОкончания);
			//мЗначения.Вставить("ВидВремени",Объект.МК_ВидЗаявления.ВидВремени);	
		    //мЗначения.Вставить("ВнутрисменнаяКомандировка", НЕ мОбъект.Целосменный);
			//мЗначения.Вставить("ОплачиватьЧасов", мОбъект.КолвоЧасовОтсутствия);    
			мЗначения.Вставить("Действие", "Заполнить"); 
			мЗначения.Вставить("ЗаполнитьПоПараметрамЗаполнения", Истина);    
			мПараметры.Вставить("Основание", мЗначения); 
	
		//ИначеЕсли мВидОтсутствия.Объект1С = "Больничный лист" Тогда	   
		//	мПозицияСелектора = 0;  // Больничный
		//	мИмяФормы = "Документ.ПрогулНеявка.Форма.ФормаДокумента";    
		//	мЗначения.Вставить("ДатаНачала", мОбъект.ДатаНачалаОтсутствия);
		//	мЗначения.Вставить("ДатаОкончания", мОбъект.ДатаЗавершенияОтсутствия);		    			
		//	мЗначения.Вставить("Действие", "ЗаполнитьПоПараметрамЗаполнения");  		 
		//	мЗначения.Вставить("СостояниеСотрудника", Перечисления.СостоянияСотрудника.Болезнь);
		//	мПараметры.Вставить("Основание", мЗначения);
		КонецЕсли;			
	Иначе                  // Отпуска.                            
		мПараметры = Новый Структура("Основание,ОсновнойОтпуск",,Ложь);
		мВидОтпуска = мВидОтсутствия;		 
    
		Если мВидОтпуска.ОтпускБезОплаты = Истина Тогда   // Создаем документ "Отпуск без оплаты"    
			мИмяФормы = "Документ.ОтпускБезСохраненияОплаты.Форма.ФормаДокумента";   			
			ДанныеОтсутствия = ДанныеОтпусков(мВидОтпуска, мЗначения.Сотрудник, Объект); //мОбъект);    
			//мЗначения.Вставить("ОтсутствиеВТечениеЧастиСмены", Не мОбъект.Целосменный);      
			//мЗначения.Вставить("ЧасовОтпуска",мОбъект.КолвоЧасовОтсутствия);
		ИначеЕсли мВидОтпуска.ОтпускЯвляетсяЕжегодным Тогда                             // Тут - обычный отпуск     
			мИмяФормы = "Документ.Отпуск.Форма.ФормаДокумента";    
			Если ПолучитьФункциональнуюОпцию("ИспользоватьОбщийПериодОтпускаВДокументах") Тогда
				мПараметры.ОсновнойОтпуск = Истина;
				мПараметры.Вставить("НачалоОтпуска", Объект.ДатаНачала);
				мПараметры.Вставить("ОкончаниеОтпуска", Объект.ДатаОкончания);
			Иначе
				мПараметры.ОсновнойОтпуск = Истина;
				ДанныеОтсутствия = ДанныеОтпусков(Справочники.ВидыОтпусков.Основной, мЗначения.Сотрудник, Объект);
			КонецЕсли;   
			мЗначения.Вставить("ДатаНачалаОсновногоОтпуска",Объект.ДатаНачала);
			мЗначения.Вставить("ДатаОкончанияОсновногоОтпуска",Объект.ДатаОкончания);    
			мЗначения.Вставить("УчитыватьМРОТПриОплатеПоСреднемуЗаработку",Истина);   
		Иначе
			мИмяФормы = "Документ.Отпуск.Форма.ФормаДокумента";    
			ДанныеОтсутствия = ДанныеОтпусков(мВидОтпуска, мЗначения.Сотрудник, Объект);				
		КонецЕсли;	                     
		
		мЗначения.Вставить("Ссылка", Неопределено);
		мЗначения.Вставить("Действие", "Заполнить");  
		
		ДанныеОтсутствий = Новый Массив;
		Если ЗначениеЗаполнено(ДанныеОтсутствия) Тогда
			ДанныеОтсутствий.Добавить(ДанныеОтсутствия);
		КонецЕсли;
	    мЗначения.Вставить("ДанныеОтпусков", ДанныеОтсутствий);
		мПараметры.Основание = мЗначения;
	КонецЕсли;			
	
	мВозврат.Добавить(мИмяФормы);
	мВозврат.Добавить(мПараметры);
	мВозврат.Добавить(0);
	Возврат мВозврат;

КонецФункции


&НаСервере
Функция ДанныеОтпусков(ВидОтпуска, Сотрудник, мОбъект)
	
	ВидОтпускаРеквизиты = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ВидОтпуска, "СпособРасчетаОтпуска, ОтпускЯвляетсяЕжегодным");
	
	ДанныеОтпуска = НовыйДанныеОтпуска();
	ДанныеОтпуска.ВидОтпуска = ВидОтпуска; 
	ДанныеОтпуска.ДатаНачала = мОбъект.ДатаНачала;
	ДанныеОтпуска.ДатаОкончания = мОбъект.ДатаОкончания;
	//ДанныеОтпуска.КоличествоДней = мОбъект.КолвоДнейОтсутствия;
	ДанныеОтпуска.КоличествоДней = 0;
	ПоКалендарнымДням = (ВидОтпускаРеквизиты.СпособРасчетаОтпуска = Перечисления.СпособыРасчетаОтпуска.ВКалендарныхДнях);   
	Если ДанныеОтпуска.КоличествоДней = 0 Тогда
		ДанныеОтпуска.КоличествоДней = 
			УчетРабочегоВремениРасширенный.ДлительностьИнтервала(Сотрудник, мОбъект.ДатаНачала,
															 мОбъект.ДатаОкончания, ПоКалендарнымДням, 
															 ВидОтпускаРеквизиты.ОтпускЯвляетсяЕжегодным);
	КонецЕсли;														 

	Возврат ДанныеОтпуска;
	
КонецФункции  

&НаКлиентеНаСервереБезКонтекста
Функция НовыйДанныеОтпуска()
		
	СтруктураОтпуска = Новый Структура;
		
	СтруктураОтпуска.Вставить("ВидОтпуска");
	СтруктураОтпуска.Вставить("ДатаНачала", Дата(1, 1, 1, 0, 0, 0));
	СтруктураОтпуска.Вставить("ДатаОкончания", Дата(1, 1, 1, 0, 0, 0));
	СтруктураОтпуска.Вставить("КоличествоДней");
	СтруктураОтпуска.Вставить("КоличествоДнейКомпенсации", 0);
	//СтруктураОтпуска.Вставить("НачалоПериодаЗаКоторыйПредоставляетсяОтпуск", '00010101');
	//СтруктураОтпуска.Вставить("КонецПериодаЗаКоторыйПредоставляетсяОтпуск", '00010101');
	СтруктураОтпуска.Вставить("Основание", "");
	СтруктураОтпуска.Вставить("ВидОтпускаПрежний", Неопределено);
	СтруктураОтпуска.Вставить("ИндексСтрокиДокумента", Неопределено);
	
	Возврат СтруктураОтпуска;
	
КонецФункции


&НаКлиенте
Процедура СоздатьДокумент(Команда)
	мРезультат = СоздатьДокументНаСервере();   
	мИмяФормы = мРезультат[0];
	Если мИмяФормы = Неопределено Тогда
		Сообщить("Такой вид документа пока не может быть создан");
	Иначе	
		мПараметры = мРезультат[1];     
		ОткрытьФорму(мИмяФормы, мПараметры, ЭтаФорма, Истина);		
	КонецЕсли;	
КонецПроцедуры      


&НаСервереБезКонтекста
Функция ПолучитьСотрудникаИДаты(мСсылка)	
	мВозврат = Новый Структура("Сотрудник, ДатаНачала",мСсылка.Сотрудник,мСсылка.ДатаНачала);
	Возврат мВозврат;
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьСотрудникаИДатуУвольнения(мСсылка)	
	мВозврат = Новый Структура("Сотрудник, ДатаУвольнения",мСсылка.Сотрудник,мСсылка.ДатаУвольнения);
	Возврат мВозврат;
КонецФункции


&НаКлиенте
Процедура ПриОткрытии(Отказ)
	мИмяФайла = СокрЛП(ЭтаФорма.Объект.МК_ПутьКФайлу); 
	мДлина = СтрДлина(мИмяФайла);            
	мИндекс = СтрНайти(мИмяФайла, "/", НаправлениеПоиска.СКонца); 
	мИмяФайла = Прав(мИмяФайла, мДлина - мИндекс);   
	ЭтаФорма.Элементы.ПосмотретьФайл.Заголовок = мИмяФайла;  
	мДок1С = ЭтаФорма.Объект.Документ1С;
		
	ЭтаФорма.Элементы.ПросмотрСсылкиНаЗаявлениеМК.Заголовок = ЭтаФорма.СсылкаНаЗаявлениеМК;
	
	// Надо прописать видимость кнопок        	
	Если НЕ ЗначениеЗаполнено(Объект.ТипДокумента1С) ИЛИ ЗначениеЗаполнено(мДок1С) ИЛИ     
		 Объект.СтатусЗаявления = ПредопределенноеЗначение("Перечисление.МК_СтатусыЗаявлений.Недействителен") ИЛИ
		 Объект.СтатусЗаявления = ПредопределенноеЗначение("Перечисление.МК_СтатусыЗаявлений.Отклонен") Тогда
		Элементы.СоздатьДокумент.Видимость = Ложь;
	КонецЕсли;	 
	
	// Надо определить, есть ли текущий пользователь (физлицо) в списке
	// текущих подписантов (исполнителей). Искать в табличной части "СоставРоли".
	// Если есть, нужно кнопки "Исполнить" и "Отклонить" сделать видимыми.
	мТаб = Объект.СоставРоли;
	мФЛ = ЭтаФорма.ВладелецФормы.Родитель.Пользователь;	
	мЕсть = Ложь;
	Для Каждого мСтр Из мТаб Цикл
		Если мСтр.Подписант = мФЛ Тогда
			мЕсть = Истина;  
			ЭтаФорма.НомерУчастника = мСтр.Номер;
			Прервать;
		КонецЕсли;	
	КонецЦикла;	     
	Если мЕсть Тогда 
		Элементы.Исполнить.Видимость = Истина;	
		Элементы.Отклонить.Видимость = Истина;	
	КонецЕсли;	
КонецПроцедуры



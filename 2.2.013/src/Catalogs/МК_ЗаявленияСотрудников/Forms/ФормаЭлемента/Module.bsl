&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	// Параметр - ссылка на документ. Надо прописать ее в заявление, если документ записан  
	мНашеОповещение = Ложь;     
	мНаимДок = "";
	Если (ИмяСобытия = "ЗаписанДокументОтпуск" ИЛИ 
		ИмяСобытия = "ЗаписанДокументОтпускБезСохраненияОплаты") 
		И Источник.ВладелецФормы = ЭтаФорма Тогда
		//ЗаполнитьОтсутствияПоДругимМестамРаботы();		
		ОбработатьЗаявление(Параметр);  
		мНашеОповещение = Истина;
	ИначеЕсли ИмяСобытия = "ЗаписьДокументаКомандировка"  И Источник = ЭтаФорма Тогда 
		ОбработатьЗаявление(Параметр.Ссылка);   	
		мНашеОповещение = Истина;   
	ИначеЕсли ИмяСобытия = "ЗаписьДокументаОплатаПоСреднемуЗаработку"  И Источник = ЭтаФорма Тогда 
		ОбработатьЗаявление(Параметр.Ссылка);   	
		мНашеОповещение = Истина;   		
	ИначеЕсли ИмяСобытия = "Запись_Отгул"  Тогда 
		мСтр = ПолучитьСотрудникаИДаты(Источник);
		Если мСтр.Сотрудник = Объект.Сотрудник И мСтр.ДатаНачала = Объект.ДатаНачала Тогда
			мНашеОповещение = Истина;
			ОбработатьЗаявление(Источник);
			мНаимДок = "Отгул";
		КонецЕсли;	
	ИначеЕсли ИмяСобытия = "Запись_Увольнение"  Тогда 
		мСтр = ПолучитьСотрудникаИДатуУвольнения(Источник);
		Если мСтр.Сотрудник = Объект.Сотрудник И мСтр.ДатаУвольнения = Объект.ДатаНачала Тогда
			мНашеОповещение = Истина;
			ОбработатьЗаявление(Источник);
			мНаимДок = "Увольнение";
		КонецЕсли;		
	ИначеЕсли ИмяСобытия = "Запись_ПрогулНеявка" Тогда    
		// Почему-то в параметрах оповещения для прогула/неявки нет ссылки на форму-владельца. Сделаем проверку по реквизитам документа: если сотрудник
		// и дата начала события совпадают, будем считать, что это наш документ.
		мСтр = ПолучитьСотрудникаИДаты(Источник);
		Если мСтр.Сотрудник = ЭтаФорма.Запись.Сотрудник И мСтр.ДатаНачала = ЭтаФорма.Запись.ДатаНачала Тогда
			мНашеОповещение = Истина;
			ОбработатьЗаявление(Источник);
			мНаимДок = "Прогул/неявка";
		КонецЕсли;	
	ИначеЕсли ИмяСобытия = "Запись_ОтпускПоУходуЗаРебенком"  Тогда 
		мСтр = ПолучитьСотрудникаИДаты(Источник);
		Если мСтр.Сотрудник =  ФизЛицоСотрудника(Объект.Сотрудник) И мСтр.ДатаНачала = Объект.ДатаНачала Тогда
			мНашеОповещение = Истина;
			ОбработатьЗаявление(Источник);
			мНаимДок = "ОтпускПоУходуЗаРебенком";
		КонецЕсли;	
	КонецЕсли;	
	Если мНашеОповещение Тогда				
		ЭтаФорма.Элементы.СоздатьДокумент.Видимость = Ложь;     	   
		ЭтаФорма.ОбновитьОтображениеДанных();    		
		ЭтаФорма.ВладелецФормы.Родитель.Элементы.Список.Обновить();    
		ОтправитьСообщениеОСозданииДокументаВМК()
	КонецЕсли;		
КонецПроцедуры

&НаСервереБезКонтекста 
Функция ФизЛицоСотрудника(мСсылка)
	Возврат мСсылка.ФизическоеЛицо;
КонецФункции	

&НаСервере 
Функция мПредставление(мДок)                
	мНаим = "Документ";
	ОбъектОписания = Метаданные.НайтиПоТипу(ТипЗнч(мДок)); 
	Если ОбъектОписания <> Неопределено Тогда 
   		мВозврат = ОбъектОписания.Имя + " " + мДок.Номер + " от " + Формат(мДок.Дата, "ДФ=dd.MM.yyyy"); 	
	КонецЕсли;
	Возврат мВозврат;
КонецФункции	


&НаСервере
Процедура ПерерисоватьПодписантов(мСтр) 
	мСписокПодписантов = "";       // Это не совсем теперь состав роли. При параллельном подписании сюда надо включать всех, кто еще текущий. в т.ч. это могут быть и роли
	// Изменим статус заявления 
	Объект.СтатусЗаявления = Справочники.МК_ЗаявленияСотрудников.ПолучитьСтатусЗаявления(мСтр.status);      
	ОО = Обработки.МК_НастройкаВыгрузки.Создать();             // Получили доступ к обработке, в которой находятся служебные функции  
	// Очистим табличную часть
	Объект.Подписанты.Очистить();	
	Объект.СоставРоли.Очистить();	
	Для Каждого мПодписант Из мСтр.approvals Цикл
		мНоваяСтрока = Объект.Подписанты.Добавить();
		мНоваяСтрока.Имя = мПодписант.name;
		мНоваяСтрока.Номер = мПодписант.id;            
		Если мПодписант.type = "role" Тогда
			мНоваяСтрока.Тип = "Роль";
			мСоставРоли = "";       
			мИндекс = 0;
			Для Каждого мУчастник Из мПодписант.user_ids Цикл   
				мФИО = Неопределено;
				Если Не (мУчастник = Неопределено) Тогда   
					мФЛ = ОО.НайтиФЛ(мУчастник); 
					Если НЕ мФЛ = Неопределено Тогда
						мФИО = мФЛ.Фамилия + " " + мФЛ.Инициалы; 
					КонецЕсли;	                               
				КонецЕсли;
				Если мФИО = Неопределено И НЕ (мПодписант.user_names = Неопределено) Тогда
				  	// Физлицо не найдено. Нужно достать ФИО из другого массива.						
					мФИО = "[" + мПодписант.user_names[мИндекс] + "]";     
				ИначеЕсли мПодписант.pointer Тогда					// Сохранять будем только текущих подписантов. Нужны реально только они.
					мНоваяРоль = Объект.СоставРоли.Добавить();
					мНоваяРоль.Номер = мПодписант.id;
					мНоваяРоль.Подписант = мФЛ;
				КонецЕсли;	                                                          					
				Если НЕ ПустаяСтрока(мСоставРоли) Тогда
					мСоставРоли = мСоставРоли + ", " ;
				КонецЕсли;							
				мСоставРоли = мСоставРоли + мФИО;
				мИндекс = мИндекс + 1;
			КонецЦикла;	                              
			мНоваяСтрока.СоставРоли = мСоставРоли;
			Если мПодписант.pointer Тогда	
				Если НЕ ПустаяСтрока(мСписокПодписантов) Тогда
					мСписокПодписантов = мСписокПодписантов + ", " ;
				КонецЕсли;							                 
				мСписокПодписантов = мСписокПодписантов + мСоставРоли;
				Объект.Роль = мСписокПодписантов;
			КонецЕсли;	
		Иначе	                      
			мНоваяСтрока.Тип = "";    
			Если мПодписант.pointer Тогда
				мФЛ = ОО.НайтиФЛ(мПодписант.user_ids[0]); 
				Если мФЛ = Неопределено Тогда
					мФИО = "[" + мПодписант.Name + "]";  
					мНоваяСтрока.Имя = мФИО;
				Иначе
					мФИО = мФЛ.Фамилия + " " + мФЛ.Инициалы;        
					мНоваяРоль = Объект.СоставРоли.Добавить();
					мНоваяРоль.Номер = мПодписант.id;
					мНоваяРоль.Подписант = мФЛ;                     
				КонецЕсли;
				Если НЕ ПустаяСтрока(мСписокПодписантов) Тогда
					мСписокПодписантов = мСписокПодписантов + ", " ;
				КонецЕсли;							  
				мСписокПодписантов = мСписокПодписантов + мФИО;
				Объект.Роль = мСписокПодписантов;
                Объект.ТекущийПодписант = мФЛ;				
			КонецЕсли;	
		КонецЕсли;   
		Если мСписокПодписантов = "" Тогда // Это значит, что уже нет действующих подписантов, все завершилось. Ставят задачу показать последнего  
			мИндекс = Объект.Подписанты.Количество() - 1;
			мПоследний = Объект.Подписанты[мИндекс];
			Если мПоследний.Тип = "Роль" Тогда 
				Объект.Роль = мПоследний.СоставРоли;
			Иначе                                         
				Объект.Роль = мПоследний.Имя;
			КонецЕсли;	
		КонецЕсли;
		Если мПодписант.type_signature = "qes" Тогда
			мНоваяСтрока.ТипПодписи = "УКЭП";
		ИначеЕсли мПодписант.type_signature = "nqes" Тогда
			мНоваяСтрока.ТипПодписи = "УНЭП";	
		ИначеЕсли мПодписант.type_signature = "none" Тогда
			мНоваяСтрока.ТипПодписи = "Без подписи";
		КонецЕсли;	
		мНоваяСтрока.Статус = Справочники.МК_ЗаявленияСотрудников.ПолучитьСтатусПодписания(мПодписант.status);			
		мНоваяСтрока.ТекущийПодписант = мПодписант.pointer;     		
	КонецЦикла;  	                                            
	ЭтаФорма.Записать();
КонецПроцедуры	

&НаКлиенте
Процедура ИсполнитьОтклонить(мРежим)                             
	мПользователь = ЭтаФорма.ВладелецФормы.Родитель.Пользователь;  
	мНомерУчастника = ЭтаФорма.НомерУчастника;                                                          
	мМК_КодЗаявления = Объект.МК_КодЗаявления;
	мДокумент1С = Объект.Документ1С;
	мРез = ИсполнитьОтклонитьСервер(мРежим, мПользователь,мМК_КодЗаявления, мНомерУчастника, мДокумент1С); 
	// После исполнения нужно по новой вычислить - является ли текущий пользователь сейчас подписантом. Чаще всего это не так.
	// Если является, надо вычислить следующий номер подписанта и зафиксировать в переменной "НомерУчастника" на этой форме.
	// Если не является, надо сделать кнопки Исполнить/Отклонить невидимыми.  
	Если мРез.Результат Тогда
		мНашел = Ложь;
		мТЗ = Объект.СоставРоли;
		Для Каждого мСтр Из мТЗ Цикл
			Если мСтр.Подписант = мПользователь Тогда
				мНомерУчастника = мСтр.Номер;
				мНашел = Истина;
				Прервать;
			КонецЕсли;	
		КонецЦикла;	  
		Если мНашел Тогда
			ЭтаФорма.НомерУчастника = мНомерУчастника;
		Иначе
			Элементы.Исполнить.Видимость = Ложь;
			Элементы.Отклонить.Видимость = Ложь;
		КонецЕсли;	
	
		ЭтаФорма.ОбновитьОтображениеДанных(); 
		ОповеститьОбИзменении(Объект.Ссылка);
	Иначе             
		ПоказатьПредупреждение(,"Операция не удалась: " + мРез.ТекстОшибки);
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Функция ИсполнитьОтклонитьСервер(мРежим, мПользователь,мМК_КодЗаявления, мНомерУчастника, мДокумент1С)
    мРез = Справочники.МК_ЗаявленияСотрудников.ИсполнитьОтклонитьНаСервере(мРежим, мПользователь,мМК_КодЗаявления, мНомерУчастника, мДокумент1С);
	//Если мРез.Результат Тогда
	ПерерисоватьПодписантов(мРез.Подписанты);  // Перерисовать надо в любом случае.
	//КонецЕсли;	
	Возврат мРез;
КонецФункции

&НаКлиенте
Процедура Исполнить(Команда)  
	ИсполнитьОтклонить(1);
КонецПроцедуры

&НаКлиенте
Процедура Отклонить(Команда)                                     
	ИсполнитьОтклонить(2);
КонецПроцедуры


&НаСервере
Функция ВычислитьАдресСсылки()
	мНаим = Константы.МК_Сервер.Получить();
	Если Прав(мНаим, 1) = "/" Тогда
		мНаим = Лев(мНаим, СтрДлина(мНаим)-1);
	КонецЕсли;	
	мНаим = мНаим + "/edms/applications/"+Формат(Объект.МК_КодЗаявления, "ЧГ=0");
	Возврат мНаим;
КонецФункции	


&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	мАдрес = ВычислитьАдресСсылки();
	ЭтаФорма.СсылкаНаЗаявлениеМК = мАдрес;
КонецПроцедуры


&НаКлиенте
Процедура СсылкаНаЗаявлениеМК(Команда)
	ЗапуститьПриложение(ЭтаФорма.СсылкаНаЗаявлениеМК);
КонецПроцедуры

&НаКлиенте
Функция ОтправитьСообщениеОСозданииДокументаВМК()  
	ИсполнитьОтклонить(3);
КонецФункции	
	ТабДок = Новый ТабличныйДокумент;
	ТабДок.АвтоМасштаб = Истина;

	РасчетныйЛисток = Неопределено;
		
	Попытка
		мДанныеДляРЛ = ЗарплатаКадрыОтчеты.ДанныеРасчетныхЛистков(Сотрудник.ФизическоеЛицо, мОрг, ДатаНачМес, ДатаНачМес);   // Эта функция кроме готового расчетного листка возвращает еще и
		                                                                                                                     // таблицу значений с данными для расчетного листка.
		ТабДок.Вывести(мДанныеДляРЛ.ДокументРезультат); 
		Если ТабДок.Области.Количество()= 0 Тогда
			МожемСоздать = Ложь;
		КонецЕсли;	
	Исключение
		МожемСоздать = Ложь;
	КонецПопытки;	
						              
		
	Если МожемСоздать Тогда 
		// Имена файлов договорились делать неслучайные. Имя будет состоять из id сотрудника + год и месяц листка.
		Если мВыгрузкаРЛ Тогда
			ИмяPDF = СокрЛП(Сотрудник.УникальныйИдентификатор())+"_"+Формат(ДатаНачМес, "ДФ=гггг")+"_"+Формат(ДатаНачМес, "ДФ=ММ")+".pdf";   
			ТабДок.Записать(мДир+ИмяPDF, ТипФайлаТабличногоДокумента.PDF);  
			// мВозврат = Новый Массив;
			мВозврат[0] = ИмяPDF;
		КонецЕсли;
		// Теперь список начислений/удержаний по сотруднику.
		Если мВыгрузкаЗП Тогда
			мТабРЛ = мДанныеДляРЛ.ДанныеРасчетныхЛистков.ДанныеРасчетныхЛистков;    			 
			мДанныеРЛ = Новый Массив;    
			// Тут будем заполнять массив начислений/удержаний по сотруднику и отправлять в вызывающую процедуру.
			// Там уже будут добавляться сведения по сотруднику и подсчитываться итоги.
			Для Каждого мСтрокаРЛ Из мТабРЛ Цикл
				Если мСтрокаРЛ.Группа = Перечисления.ГруппыНачисленияУдержанияВыплаты.Начислено Или мСтрокаРЛ.Группа = Перечисления.ГруппыНачисленияУдержанияВыплаты.Удержано Тогда    
					мСтр = Новый Структура;
					мСтр.Вставить("summa",мСтрокаРЛ.Сумма);  
					// Год и месяц определим по полю "ПериодДействия". Там - дата начала месяца.
					мСтр.Вставить("year",Год(мСтрокаРЛ.ПериодДействия));
					мСтр.Вставить("month",Месяц(мСтрокаРЛ.ПериодДействия));				
					Если мСтрокаРЛ.Группа = Перечисления.ГруппыНачисленияУдержанияВыплаты.Начислено Тогда  
						мСтр.Вставить("vid", 1);	
						мСтр.Вставить("time",мСтрокаРЛ.ОплаченныеДниЧасы);
						Если ТипЗнч(мСтрокаРЛ.ВидРасчета) = Тип("ПланВидовРасчетаСсылка.Начисления") Тогда
							мСтр.Вставить("tip",СокрЛП(мСтрокаРЛ.ВидРасчета.Ссылка.УникальныйИдентификатор()));
						ИначеЕсли ТипЗнч(мСтрокаРЛ.ВидРасчета) = Тип("ПеречислениеСсылка.ВидыОсобыхНачисленийИУдержаний") Тогда
							мУИД = Справочники.МК_ОсобыеНачисленияУдержания.МК_ДобавитьВернутьОсобое(мСтрокаРЛ.ВидРасчета, 1);
							Если мУИД <> Неопределено Тогда
								мСтр.Вставить("tip",СокрЛП(мУИД));
							Иначе	 // Тут надо бы сообщить о беде
							КонецЕсли;	
						Иначе
							Сообщить("Неизвестный тип");
						КонецЕсли;	
					Иначе  // Тут могут быть только удержания 
						мСтр.Вставить("vid", 2);	
						Если ТипЗнч(мСтрокаРЛ.ВидРасчета) = Тип("ПланВидовРасчетаСсылка.Удержания") Тогда
							мСтр.Вставить("tip",СокрЛП(мСтрокаРЛ.ВидРасчета.Ссылка.УникальныйИдентификатор()));
						ИначеЕсли ТипЗнч(мСтрокаРЛ.ВидРасчета) = Тип("ПеречислениеСсылка.ВидыОсобыхНачисленийИУдержаний") Тогда
							мУИД = Справочники.МК_ОсобыеНачисленияУдержания.МК_ДобавитьВернутьОсобое(мСтрокаРЛ.ВидРасчета, 2);         
							Если мУИД <> Неопределено Тогда
								мСтр.Вставить("tip",СокрЛП(мУИД));
							Иначе	 // Тут надо бы сообщить о беде
							КонецЕсли;	
						Иначе
							Сообщить("Неизвестный тип");	
						КонецЕсли;  
					КонецЕсли;	
					мДанныеРЛ.Добавить(мСтр);   			
				КонецЕсли;				
			КонецЦикла;	    
			мВозврат[1] = мДанныеРЛ;
		КонецЕсли;	
	КонецЕсли;
		
	Возврат мВозврат;
КонецФункции

		|   ЕСТЬNULL(ДокументыФЛ2.Серия, """") КАК Документ2Серия,
		|   ЕСТЬNULL(ДокументыФЛ2.Номер, """") КАК Документ2Номер,
		|   ЕСТЬNULL(ДокументыФЛ2.ДатаВыдачи, """") КАК Документ2ДатаВыдачи, 
		|   ЕСТЬNULL(ДокументыФЛ2.СрокДействия, """") КАК Документ2СрокДействия,
		|   ЕСТЬNULL(ДокументыФЛ2.КемВыдан, """") КАК Документ2КемВыдан,
		|   ЕСТЬNULL(ДокументыФЛ2.КодПодразделения, """") КАК Документ2КодПодразделения,    
		|   ЕСТЬNULL(ДокументыФЛ2.СтранаВыдачи, """") КАК Документ2СтранаВыдачи,
		|   ЕСТЬNULL(ДокументыФЛ3.ВидДокумента, """") КАК Документ3ВидДокумента,
		|   ЕСТЬNULL(ДокументыФЛ3.Серия, """") КАК Документ3Серия,
		|   ЕСТЬNULL(ДокументыФЛ3.Номер, """") КАК Документ3Номер,
		|   ЕСТЬNULL(ДокументыФЛ3.ДатаВыдачи, """") КАК Документ3ДатаВыдачи, 
		|   ЕСТЬNULL(ДокументыФЛ3.СрокДействия, """") КАК Документ3СрокДействия,
		|   ЕСТЬNULL(ДокументыФЛ3.КемВыдан, """") КАК Документ3КемВыдан,
		|   ЕСТЬNULL(ДокументыФЛ3.КодПодразделения, """") КАК Документ3КодПодразделения,    
		|   ЕСТЬNULL(ДокументыФЛ3.СтранаВыдачи, """") КАК Документ3СтранаВыдачи,   
		|   ДанныеДоговоров.ДатаДоговораКонтракта Как ДатаДоговораКонтракта,
		|   ДанныеДоговоров.НомерДоговораКонтракта Как НомерДоговораКонтракта,
		|   Гражданство.Страна Как ГражданствоСтрана,
		|   Гражданство.ИНН Как ГражданствоИНН,
		|   Графики.ГрафикРаботы КАК ГрафикРаботы,  
		|   ЕСТЬNULL(ДистанционнаяРабота.РаботаетДистанционно, ЛОЖЬ) КАК РаботаетДистанционно,
		|	ФизическиеЛица.КонтактнаяИнформация.(
		|		Тип КАК Тип,
		|		Вид КАК Вид,
		|		Представление КАК Представление,
		|		ЗначенияПолей КАК ЗначенияПолей
		|	) КАК КонтактнаяИнформация,
		|	СправочникСотрудники.ДополнительныеРеквизиты.(
		|		Свойство КАК Свойство,
		|		Свойство.Имя КАК Имя,
		|		Значение КАК Значение
		|	) КАК ДополнительныеРеквизиты,    
		//|СклоненияПредставленийОбъектов.ХешПредставления КАК Хеш,
		//|	СклоненияПредставленийОбъектов.ИменительныйПадеж КАК Именительный,
		//|	СклоненияПредставленийОбъектов.РодительныйПадеж КАК Родительный,
		//|	СклоненияПредставленийОбъектов.ДательныйПадеж КАК Дательный,
		//|	СклоненияПредставленийОбъектов.ВинительныйПадеж КАК Винительный,
		//|	СклоненияПредставленийОбъектов.ТворительныйПадеж КАК Творительный,
		//|	СклоненияПредставленийОбъектов.ПредложныйПадеж КАК Предложный,
		|	ЕСТЬNULL(ДопСведВерсияДанных.Значение, """") КАК ВерсияДанныхСотрудника,
		|   ДатыИзменения.Период КАК ДатаИзмененияДП
		|ИЗ
		|	СрезДанных КАК СрезДанных
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеДляПодбораСотрудников КАК ДанныеДляПодбора
		|		ПО СрезДанных.Сотрудник = ДанныеДляПодбора.Сотрудник
		|			И СрезДанных.Начало = ДанныеДляПодбора.Начало
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК СправочникСотрудники
		|		ПО (ДанныеДляПодбора.Сотрудник = СправочникСотрудники.Ссылка)
		|			И (ДанныеДляПодбора.Наименование = СправочникСотрудники.Наименование)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ТекущиеКадровыеДанныеСотрудников КАК ТекущиеКадровыеДанныеСотрудников
		|		ПО (ДанныеДляПодбора.Сотрудник = ТекущиеКадровыеДанныеСотрудников.Сотрудник)
		|			И (ДанныеДляПодбора.ФизическоеЛицо = ТекущиеКадровыеДанныеСотрудников.ФизическоеЛицо)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФИОФизическихЛиц.СрезПоследних КАК ФИОФизическихЛицСрезПоследних
		|		ПО (ДанныеДляПодбора.ФизическоеЛицо = ФИОФизическихЛицСрезПоследних.ФизическоеЛицо)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизическиеЛица
		|		ПО (ДанныеДляПодбора.ФизическоеЛицо = ФизическиеЛица.Ссылка)		
		|       ЛЕВОЕ СОЕДИНЕНИЕ ВТДокументыУЛ КАК ВТДокументыУЛ
		|       ПО СрезДанных.Сотрудник = ВТДокументыУЛ.Сотрудник 
		|       ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДокументыФизическихЛиц.СрезПоследних Как Документы
		|       ПО (Документы.Физлицо = ДанныеДляПодбора.ФизическоеЛицо И Документы.ЯвляетсяДокументомУдостоверяющимЛичность 
		|		И Документы.Период = ВТДокументыУЛ.Период)		
		|       ЛЕВОЕ СОЕДИНЕНИЕ ВТДокументыФЛ1 КАК ВТДокументыФЛ1
		|       ПО СрезДанных.Сотрудник = ВТДокументыФЛ1.Сотрудник 
		|       ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДокументыФизическихЛиц.СрезПоследних Как ДокументыФЛ1
		|       ПО (ДокументыФЛ1.Физлицо = ДанныеДляПодбора.ФизическоеЛицо И ДокументыФЛ1.ВидДокумента = (&Документ1)
		|		И ДокументыФЛ1.Период = ВТДокументыФЛ1.Период)	
		|       ЛЕВОЕ СОЕДИНЕНИЕ ВТДокументыФЛ2 КАК ВТДокументыФЛ2
		|       ПО СрезДанных.Сотрудник = ВТДокументыФЛ2.Сотрудник 
		|       ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДокументыФизическихЛиц.СрезПоследних Как ДокументыФЛ2
		|       ПО (ДокументыФЛ2.Физлицо = ДанныеДляПодбора.ФизическоеЛицо И ДокументыФЛ2.ВидДокумента = (&Документ2)
		|		И ДокументыФЛ2.Период = ВТДокументыФЛ2.Период)	  
		|       ЛЕВОЕ СОЕДИНЕНИЕ ВТДокументыФЛ3 КАК ВТДокументыФЛ3
		|       ПО СрезДанных.Сотрудник = ВТДокументыФЛ3.Сотрудник 
		|       ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДокументыФизическихЛиц.СрезПоследних Как ДокументыФЛ3
		|       ПО (ДокументыФЛ3.Физлицо = ДанныеДляПодбора.ФизическоеЛицо И ДокументыФЛ3.ВидДокумента = (&Документ3)
		|		И ДокументыФЛ3.Период = ВТДокументыФЛ3.Период)	 
		|       ЛЕВОЕ СОЕДИНЕНИЕ ВТВидыЗанятости КАК ВТВидыЗанятости
		|       ПО СрезДанных.Сотрудник = ВТВидыЗанятости.Сотрудник 
		|       ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ВидыЗанятостиСотрудников.СрезПоследних Как ВидыЗанятости
		|       ПО (ВидыЗанятости.Сотрудник = ДанныеДляПодбора.Сотрудник 
		|		И ВидыЗанятости.Период = ВТВидыЗанятости.Период)	
		|       ЛЕВОЕ СОЕДИНЕНИЕ ВТДанныеДоговоров КАК ВТДанныеДоговоров
		|       ПО СрезДанных.Сотрудник = ВТДанныеДоговоров.Сотрудник 
		|       ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОсновныеДанныеКонтрактаДоговораСотрудника.СрезПоследних Как ДанныеДоговоров
		|       ПО (ДанныеДоговоров.сотрудник = ДанныеДляПодбора.Сотрудник)
		|		И (ДанныеДоговоров.Период = ВТДанныеДоговоров.Период)	
		|       ЛЕВОЕ СОЕДИНЕНИЕ ВТГражданство КАК ВТГражданство
		|       ПО СрезДанных.Сотрудник = ВТГражданство.Сотрудник 
		|       ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГражданствоФизическихЛиц.СрезПоследних Как Гражданство
		|       ПО (Гражданство.ФизическоеЛицо = ДанныеДляПодбора.ФизическоеЛицо 
		|		И Гражданство.Период = ВТГражданство.Период)	  
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДопСведВерсияДанных
		|		ПО (ДопСведВерсияДанных.Свойство = &СвойствоХэш)
		|			И (ДопСведВерсияДанных.Объект = ДанныеДляПодбора.Сотрудник)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДатыИзменения КАК ДатыИзменения
		|		ПО СрезДанных.Сотрудник = ДатыИзменения.Сотрудник
		|       ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГрафикРаботыСотрудников.СрезПоследних Как Графики
		|       ПО (СрезДанных.Сотрудник = Графики.Сотрудник)   
		|       ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДистанционнаяРаботаСотрудников.СрезПоследних Как ДистанционнаяРабота
		|       ПО (СрезДанных.Сотрудник = ДистанционнаяРабота.Сотрудник)";

     // Тут надо добавить условия по сотрудникам, видам занятости, подразделениям и должностям, если они есть.   
	 мТекст = "";
	 Если мПарам.ФильтрСотрудники[0] <> "0" Тогда          
		 мЗапрос.УстановитьПараметр("Сотрудники",мПарам.ФильтрСотрудники[1]);	
		 Если мПарам.ФильтрСотрудники[0] = "1" Тогда  // Учитываем, выгружаем.
			 мТекст = "   И ДанныеДляПодбора.Сотрудник В (&Сотрудники)";
	     Иначе
		     мТекст = "   И НЕ (ДанныеДляПодбора.Сотрудник В (&Сотрудники))";
		 КонецЕсли;	                                                       		   
	 КонецЕсли;	       
	  Если мПарам.ФильтрДолжности[0] <> "0" Тогда          
		 мЗапрос.УстановитьПараметр("Должности",мПарам.ФильтрДолжности[1]);	
		 Если НЕ ПустаяСтрока(мТекст) Тогда
			 мТекст = мТекст + Символы.ПС; 
		 КонецЕсли;	 
		 Если мПарам.ФильтрДолжности[0] = "1" Тогда  // Учитываем, выгружаем.
			 мТекст = мТекст + "    И ДанныеДляПодбора.Должность В (&Должности)";
	     Иначе
		     мТекст = мТекст + "    И НЕ (ДанныеДляПодбора.Должность В (&Должности))";
		 КонецЕсли;			   
	 КонецЕсли;                                         
	 Если мПарам.ФильтрВидыЗанятости[2] = "2" Тогда   // Это про ГПХ. Тут "выгружать ГПХ" не означает, что всех остальных выгружать не надо
		 Если НЕ ПустаяСтрока(мТекст) Тогда    // Поэтому интересует только факт невыгрузки 
			 мТекст = мТекст + Символы.ПС; 
		 КонецЕсли;	 
		 мТекст = мТекст + "    И НЕ ДанныеДляПодбора.ПоДоговоруГПХ"
	 КонецЕсли;	 
	 Если мПарам.ФильтрВидыЗанятости[0] <> "0" Тогда          
		 мЗапрос.УстановитьПараметр("ВидыЗанятости",мПарам.ФильтрВидыЗанятости[1]);	
		 Если НЕ ПустаяСтрока(мТекст) Тогда
			 мТекст = мТекст + Символы.ПС; 
		 КонецЕсли;	 
		 Если мПарам.ФильтрВидыЗанятости[0] = "1" Тогда  // Учитываем, выгружаем.
			Если мПарам.ФильтрВидыЗанятости[2] <> "2" Тогда
			 	мТекст = мТекст + "    И (ДанныеДляПодбора.ВидЗанятости В (&ВидыЗанятости) ИЛИ ДанныеДляПодбора.ПоДоговоруГПХ)";
			Иначе	
				мТекст = мТекст + "    И ДанныеДляПодбора.ВидЗанятости В (&ВидыЗанятости)";
			КонецЕсли;	
	     Иначе
		     мТекст = мТекст + "    И НЕ (ДанныеДляПодбора.ВидЗанятости В (&ВидыЗанятости))";
		 КонецЕсли;			   
	 КонецЕсли;   
	 Если мПарам.ФильтрПодразделения[0] <> "0" Тогда          
		 мЗапрос.УстановитьПараметр("Подразделения",мПарам.ФильтрПодразделения[1]);	
		 Если НЕ ПустаяСтрока(мТекст) Тогда
			 мТекст = мТекст + Символы.ПС; 
		 КонецЕсли;	 
		 Если мПарам.ФильтрПодразделения[0] = "1" Тогда  // Учитываем, выгружаем.
			 мТекст = мТекст + "    И ДанныеДляПодбора.Подразделение В Иерархии(&Подразделения)";
	     Иначе
		     мТекст = мТекст + "    И НЕ (ДанныеДляПодбора.Подразделение В Иерархии(&Подразделения))";
		 КонецЕсли;			   
	 КонецЕсли;                                               
	 Если мПарам.ФильтрСтруктуры[0] <> "0" Тогда          
		 мЗапрос.УстановитьПараметр("МестаВСтруктуре",мПарам.ФильтрСтруктуры[1]);	
		 Если НЕ ПустаяСтрока(мТекст) Тогда
			 мТекст = мТекст + Символы.ПС; 
		 КонецЕсли;	 
		 Если мПарам.ФильтрСтруктуры[0] = "1" Тогда  // Учитываем, выгружаем.
			 мТекст = мТекст + "    И ДанныеДляПодбора.МестоВСтруктуреПредприятия В Иерархии(&МестаВСтруктуре)";
	     Иначе
		     мТекст = мТекст + "    И НЕ (ДанныеДляПодбора.МестоВСтруктуреПредприятия В Иерархии(&МестаВСтруктуре))";
		 КонецЕсли;			   
	 КонецЕсли;     


	 мЗапрос.Текст = СтрЗаменить(мЗапрос.Текст, "&УсловияФильтров",мТекст);   
	 
	 // Изменение в определении даты последнего назначения (изменения должности или подразделения): теперь нужно смотреть настройку
	 // выгрузки должности и подразделения: если выгружаются оба реквизита, то оба и проверяем. Иначе - только тот, что выгружается.
 	// Подразделение - мНВИ[3], Должность - мНВИ[4]
	мТекст = "И (КадроваяИсторияСотрудников.Должность <> ДанныеПоСотрудникам.Должность 	ИЛИ КадроваяИсторияСотрудников.Подразделение <> ДанныеПоСотрудникам.Подразделение)";
	Если мПарам.мВыгружатьПодразделения И мПарам.мНВИ[4] = "0" Тогда		
		мТекст = "	И КадроваяИсторияСотрудников.Подразделение <> ДанныеПоСотрудникам.Подразделение";
	ИначеЕсли (Не мПарам.мВыгружатьПодразделения) И мПарам.мНВИ[4] = "1" Тогда			
		мТекст = "	И КадроваяИсторияСотрудников.Должность <> ДанныеПоСотрудникам.Должность";
	КонецЕсли;	
	мЗапрос.Текст = СтрЗаменить(мЗапрос.Текст, "&УсловиеОпределенияДатыПоследнегоНазначения",мТекст);

	 	
	РезультатЗапроса = мЗапрос.ВыполнитьПакет();
	Выборка = РезультатЗапроса[12].Выгрузить();
	Возврат Выборка;
КонецФункции


Функция СписокОрганизацийПолный(мСписокОрганизаций,СвойствоХэшОрг) Экспорт  
	
	
	// Нужны расширенные сведения по организациям. В запросе будем получать сведения по списку
	// переданных организаций.      
	//мСписок = Новый Массив();
	мДатаСреза = ТекущаяДата();
	мЗапрос = Новый Запрос;
	мЗапрос.УстановитьПараметр("ДатаСреза",мДатаСреза);
	мЗапрос.УстановитьПараметр("СписокОрганизаций",мСписокОрганизаций);
	мЗапрос.УстановитьПараметр("СвойствоХэш",СвойствоХэшОрг);
	мЗапрос.Текст = 
	"ВЫБРАТЬ
	|	Организации.Ссылка КАК Ссылка,
	|	Организации.НаименованиеПолное КАК НаименованиеПолное,
	|	Организации.НаименованиеСокращенное КАК НаименованиеСокращенное,
	|	Организации.ИНН КАК ИНН, 	
	|	ЕСТЬNULL(Организации.РегистрацияВНалоговомОргане.КПП,"""") КАК КПП,
	|   Организации.ОГРН КАК ОГРН,
	//|	СведенияОбОтветственныхЛицахСрезПоследних.Руководитель.Ссылка КАК Руководитель,
	//|	СведенияОбОтветственныхЛицахСрезПоследних.УдалитьДолжностьРуководителя.Ссылка КАК ДолжностьРуководителя,
	|	ЕСТЬNULL(ДопСведВерсияДанных.Значение, """") КАК ВерсияДанныхОрганизаций
	|ИЗ 
	|	Справочник.Организации КАК Организации
	|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДопСведВерсияДанных
	|	ПО (ДопСведВерсияДанных.Свойство = &СвойствоХэш)
	|		И (ДопСведВерсияДанных.Объект = Организации.Ссылка) 

	мЗапрос = Новый Запрос;
			
	мЗапрос.Текст = 
	"ВЫБРАТЬ
	|	ОснованияУвольнения.Ссылка КАК Ссылка,
	|	ОснованияУвольнения.Статья КАК Статья,
	|	ОснованияУвольнения.Часть КАК Часть,
	|	ОснованияУвольнения.Пункт КАК Пункт,

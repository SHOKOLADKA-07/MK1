&НаСервере      
Функция ВыгрузкаСведСотр(мПараметры)   Экспорт    
	мМаксКС = Константы.МК_МаксКолвоСотрВВыгрузке.Получить();;    // Максимальное кол-во сотрудников, отправляемых за один раз  
	Если мМаксКС = 0 Тогда                                        // Если 0, то значение по умолчанию - 1000
		мМаксКС = 1000;
	КонецЕсли;	                                                                                                            
	
	ИнтерактивныйРежим = Ложь;      // Нужно знать, как вызвана функция - интерактивно или регламентом в фоне
	мСпособВыгрузки = 1;            // 1 - выгружаем в МояКоменда, 2 - на диск.     
	мВозврат = Новый Массив;     
	мВозврат.Добавить(0);       // 0 Успешность процесса
	мВозврат.Добавить(Ложь);    // 1 Есть ли протокол невыгруженных сотров
	мВозврат.Добавить(0);       // 2 Массив невыгруженных сотров
	мВозврат.Добавить(0);       // 3 Кол-во выгруженных.

	Если мПараметры.Свойство("ИдентификаторФормы") Тогда   // Это значит, что вызов интерактивный, хоть и в фоне
		мДир = мПараметры.мДир;
		мСпособВыгрузки = мПараметры.мСпособВыгрузки;    // 1 - выгружаем в МояКоменда, 2 - на диск. 
		ИнтерактивныйРежим = Истина;    
		мАдресРез1 = мПараметры.мАдрес1;
		мАдресРез2 = мПараметры.мАдрес2;
		мАдресРез3 = мПараметры.мАдрес3;
	КонецЕсли;	 
	мТолькоИзменения = мПараметры.ТолькоИзменения;
	мMODE = "full";
	Если мТолькоИзменения Тогда
		мMODE = "partly";
	КонецЕсли;	

	Если ИнтерактивныйРежим Тогда
		ДлительныеОперации.СообщитьПрогресс("","Выполняется заполнение справочников");
	КонецЕсли;                   
	
	
	Если мСпособВыгрузки = 2 Тогда
		// Надо получить имя временного каталога, в который будем складывать json файлы порций сотрудников перед архивированием.
		// Создадим свой временный каталог в нем. Может не пригодиться.
		мВДир = ПолучитьИмяВременногоФайла();
		мДирВрем = мВДир + "\mVrem\";   // Пишут, что вот так правильно формировать временный каталог
		СоздатьКаталог(мДирВрем);
    КонецЕсли;
	
	ОО = Обработки.МК_НастройкаВыгрузки.Создать();             // Получили доступ к обработке, в которой находятся служебные функции
	// Первым делом получим нужные организации
	СписокОрганизаций = ОО.ПолучитьСписокОрганизаций();  
	// Тут же получим данные по другим фильтрам выгрузки
	ФильтрСотрудники = ОО.ПолучитьФильтрСотрудники();   // Возвращается массив: {ВидДействия,СписокСотрудников} Вид действия: "0" - не учитывать, "1" - выгружать, "2" - не выгружать.
	ФильтрДолжности = ОО.ПолучитьФильтрДолжности(); 
	ФильтрВидыЗанятости = ОО.ПолучитьФильтрВидыЗанятости(); 
	// Для ГПХ введена еще одна константа - выше уровнем. Редактируется в "секретных настройках".
	мВыгружатьГПХ = Константы.МК_ВыгружатьГПХ.Получить();   
	мКастомныеПоля = Константы.МК_ПрименятьПользовательскиеПоля.Получить();  
	мВыгрузкаПланНач = Константы.МК_ВыгружатьПлановыеНачисления.Получить();
	Если НЕ мВыгружатьГПХ Тогда
		ФильтрВидыЗанятости[2] = "2";
	КонецЕсли;	
		
	// Настройки выгружаемой информации (теперь можно выгружать не все реквизиты).	
	мНВИ = ОО.ПолучитьНастройкиВыгружаемойИнформации();     // Тут массив с элементами "1" или "0".  
	мНВИ[14]="1";  // 16.04.2025. Вид занятости теперь выгружаем обязательно. До этого было не так. 
	
    // Эти переменные нужны для отключения выгрузки справочников, если не выгружаются 
	мВыгружатьДолжности = (мНВИ[4] = "1");         // соответствующие реквизиты.
	мВыгружатьОрганизации = (мНВИ[2] = "1");     
	мВыгружатьГрафики = (мНВИ[20] = "1");    
	// Надо получить константу про выгрузку структуры предприятия
	мСтруктура = Константы.МК_ВыгружатьОргСтруктуру.Получить();
	мВыгружатьСтруктуру = Ложь;
	мВыгружатьПодразделения = Ложь;
	Если мСтруктура Тогда 
		мВыгружатьСтруктуру = (мНВИ[22] = "1");   		
	Иначе	
		мВыгружатьПодразделения = (мНВИ[3] = "1");           
	КонецЕсли;	                                    
	ФильтрСтруктуры = ОО.ПолучитьФильтрСтруктуры();
	ФильтрПодразделения = ОО.ПолучитьФильтрПодразделения();  
	
    мРезультат = Ложь;       
	мКолво = 0;
	// Сведения надо отправлять отдельно: 
	// properties - на адрес /api/1cexchange/users-properties - справочники
	// users - на адрес /api/1cexchange/users-list            - сотрудники
	// departmens - на адрес /api/1cexchange/departments-list - подразделения
	ДатаУвольненияДо = ДобавитьМесяц(НачалоДня(ТекущаяДата()), -1);   // Вообще-то с датами увольнения все сделано в запросе. Но пока оствлю как есть
	
	мНПР = ОО.ПолучитьПереопределяемыеРеквизиты();  // Тут массив значений, которые изменяют переопределяемые реквизиты (пока только ФИО, руководитель отдела и должность)   
	
	// Сначала справочники 
	Выгрузка = Новый Структура;  
	Выгрузка.Вставить("mode",мMODE);	
	Выгрузка.Вставить("Properties",МассивСвойств(СписокОрганизаций,мТолькоИзменения,мВыгружатьОрганизации,мВыгружатьДолжности,мВыгружатьГрафики,мНПР));    // Получили справочники для списка организаций
    ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
		
	мПрот = Новый Массив;
	Если мСпособВыгрузки = 1 Тогда
		мСеанс = ОО.СоздатьСеансСвязи(ИнтерактивныйРежим);
    	Если мСеанс = Неопределено Тогда
 			// Ошибка авторизации. Ничего не отправляем.
		Иначе         
			Попытка
				ЗаписатьJSON(ЗаписьJSON, Выгрузка);	
				ТекстJSON = ЗаписьJSON.Закрыть();
			Исключение
				Сообщить(ЗначениеВСтрокуВнутр(Выгрузка));
				ВызватьИсключение(ОписаниеОшибки());
			КонецПопытки; 

			мРезультат = Истина;    // Пока эта истина говорит о том, что сеанс создан (получен токен).
			hЗапрос = ОО.СоздатьHTTPЗапрос("/api/1c-exchange/user-properties", мСеанс);     
			hЗапрос.УстановитьТелоИзСтроки(ТекстJSON);  
			hЗапрос.Заголовки.Вставить("Source","1C Enterprise MK");
			hОтвет = мСеанс.Соединение.ВызватьHTTPМетод("POST", hЗапрос); 
			мОтвет = ОО.ПроверитьОтвет(hОтвет,"Справочники",ИнтерактивныйРежим);   // Пока этот мОтвет не анализируется.
		КонецЕсли;	
	Иначе   // Выгружаем на диск.  
		ЗаписатьJSON(ЗаписьJSON, Выгрузка);	
		ТекстJSON = ЗаписьJSON.Закрыть();
        мАдрес1 = ПоместитьВоВременноеХранилище(ТекстJSON,мАдресРез1);
	    мВозврат.Добавить(мАдрес1);
		мВозврат.Добавить(ОО.ПолучитьИмяФайла("Справочники",мДир));
    КонецЕсли;  
	
	
	Если мВыгружатьПодразделения Или мВыгружатьСтруктуру Тогда   
		Выгрузка = Новый Структура;     
		Выгрузка.Вставить("mode",мMODE);                   
		Выгрузка.Вставить("Departments", Новый Массив);
		Если мВыгружатьПодразделения И (мСпособВыгрузки = 2 ИЛИ мСеанс <> Неопределено) Тогда   
			// Теперь отправим подразделения     
		
			СвойствоХэшПодр = ОО.НайтиДопРеквХэшДанных("ПодразделенияОрганизаций");
		
			// Получим подразделения по нужным организациям
			СписокПодразделений = ПолучитьСписокПодразделений(СписокОрганизаций,ФильтрПодразделения, СвойствоХэшПодр, мНПР[3]); // мНПР[3] - способ хранения руководителей подразделений     
			
			// Добавим подразделения в выгрузку.		
			Для Каждого мПодр Из СписокПодразделений Цикл    
				РодительИД = Неопределено;
	
				Если НЕ мПодр.Родитель = Справочники.ПодразделенияОрганизаций.ПустаяСсылка() Тогда
					РодительИД = СокрЛП(мПодр.Родитель.УникальныйИдентификатор());
				КонецЕсли;
		
				Подразделение = Новый Структура;
				Подразделение.Вставить("id", СокрЛП(мПодр.Ссылка.УникальныйИдентификатор()));
				//Подразделение.Вставить("org_num", СокрЛП(ВыборкаПоПодразделениям.Код));
				Подразделение.Вставить("company",СокрЛП(мПодр.Организация.УникальныйИдентификатор()));
				Подразделение.Вставить("parent", РодительИД);
				Подразделение.Вставить("name", СокрЛП(мПодр.Наименование));
				Подразделение.Вставить("is_removed", мПодр.ПометкаУдаления);
				// Попробуем найти руководителя.
				мНач = "";     
				мНачФЛ="";
				Если ЗначениеЗаполнено(мНПР[3]) Тогда      
					мМодуль = Метаданные.ОбщиеМодули.Найти("РуководителиПодразделений");  
					Если НЕ (мМодуль = Неопределено) Тогда    
						мСсылкаНаМодуль = ОбщегоНазначения.ОбщийМодуль("РуководителиПодразделений");
					Иначе	                                                                        
						мСсылкаНаМодуль = ОбщегоНазначения.ОбщийМодуль("РуководителиПодразделенийОрганизаций");
					КонецЕсли;	
					Если мНПР[3] = Перечисления.МК_СтандартныйРуководительПодразделения.СтРеквФЛ И НЕ (мМодуль = Неопределено) Тогда   // Подключена работа с руководителями подразделений в виде ФизЛица //кабинет сотрудника или "Персонал"
						// Смотрим реквизит "РуководительПодразделения" из выборки. Он - физическое лицо.   
						Если ЗначениеЗаполнено(мПодр.РуководительПодразделения) Тогда
							мНачФЛ = СокрЛП(мПодр.РуководительПодразделения.УникальныйИдентификатор());
							мСписСотр = ОО.СписокСотрудниковПоФизлицу(мПодр.Организация,мПодр.РуководительПодразделения);  // В этой функции подбираются только основные сотрудники или внешние
							Если мСписСотр.Следующий() Тогда                                                               // совместители. Если все хорошо, вернется одна запись. Если больше - нас не волнует,
								мНач = СокрЛП(мСписСотр.СотрудникСсылка.УникальныйИдентификатор());                        // возьмем первого.
							КонецЕсли;	
						КонецЕсли;	
					ИначеЕсли мНПР[3] = Перечисления.МК_СтандартныйРуководительПодразделения.СтРеквПозШР Тогда   // Подключена работа с руководителями подразделений в виде позиции ШР (кабинет сотрудника или "Персонал")						 					                                                  
							
						мПозСтр = мПодр.СтруктураСсылка;
						Если ЗначениеЗаполнено(мПозСтр) Тогда
							//мПозШР = РуководителиПодразделений.ПозицияРуководителя(мПозСтр);       // Тут под подразделением понимается позиция в структуре предприятия.      
							мПозШР = мСсылкаНаМодуль.ПозицияРуководителя(мПозСтр);    
							Если НЕ (мПозШР = Неопределено) Тогда
								мРук = мСсылкаНаМодуль.СотрудникНаПозицииРуководителя(мПозШР);    // Возвращается ссылка на Сотрудника
								Если НЕ (мРук = Неопределено) Тогда                                          
									мНач = СокрЛП(мРук.УникальныйИдентификатор());
									мНачФЛ = СокрЛП(мРук.ФизическоеЛицо.УникальныйИдентификатор());
								КонецЕсли;	
							КонецЕсли;	
						КонецЕсли;	
				 	Иначе	
						мДопСвед = мПодр.ДополнительныеРеквизиты;				
						Для Каждого мСвед Из мДопСвед Цикл   
							Если мСвед.Свойство = мНПР[3] Тогда
								Попытка      
									// Руководитель должен иметь тип ссылки на справочник "Сотрудники".
									мНач = СокрЛП(мСвед.Значение.УникальныйИдентификатор());
									мНачФЛ = СокрЛП(мСвед.Значение.ФизическоеЛицо.УникальныйИдентификатор());
								Исключение
								КонецПопытки;	
							КонецЕсли;
						КонецЦикла;
					КонецЕсли;		
				КонецЕсли;			                                               
				Подразделение.Вставить("head", СокрЛП(мНач));
				Подразделение.Вставить("head_individual", СокрЛП(мНачФЛ));
			
			
				// Проверим необходимость выгрузки, если только изменения.
				ЗаписьJSON = Новый ЗаписьJSON;
				ЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ЗаписьJSON, Подразделение);	
				ПодразделениеJSON = ЗаписьJSON.Закрыть();
			
				ПодразделениеХеш = СокрЛП(ОО.ПолучитьХешСтроки(ПодразделениеJSON));
			
				Изменилось = Ложь;
				Если СокрЛП(мПодр.ВерсияДанныхПодразделений) <> ПодразделениеХеш Тогда
					ДопСвед = РегистрыСведений.ДополнительныеСведения.СоздатьМенеджерЗаписи();
					ДопСвед.Объект = мПодр.Ссылка;
					ДопСвед.Свойство = СвойствоХэшПодр;
					ДопСвед.Значение = ПодразделениеХеш;
					ДопСвед.Записать();
					Изменилось = Истина;
				КонецЕсли; 
				Если (мТолькоИзменения И Изменилось) ИЛИ НЕ мТолькоИзменения Тогда                                                 
					Выгрузка.Departments.Добавить(Подразделение);			
				КонецЕсли;
			КонецЦикла;   
		ИначеЕсли мВыгружатьСтруктуру Тогда     // Тут выгрузка структуры
			СвойствоХэшПодр = ОО.НайтиДопРеквХэшДанных("СтруктураПредприятия");
		
			// Получим подразделения по нужным организациям
			СписокПодразделений = ПолучитьСтруктуру(ФильтрСтруктуры, СвойствоХэшПодр, мНПР[3]); // мНПР[3] - способ хранения руководителей подразделений     
			
			// Добавим подразделения в выгрузку.		
			Для Каждого мПодр Из СписокПодразделений Цикл    
				РодительИД = Неопределено;
	
				Если НЕ мПодр.Родитель = Справочники.СтруктураПредприятия.ПустаяСсылка() Тогда
					РодительИД = СокрЛП(мПодр.Родитель.УникальныйИдентификатор());
				КонецЕсли;
		
				Подразделение = Новый Структура;
				Подразделение.Вставить("id", СокрЛП(мПодр.Ссылка.УникальныйИдентификатор()));
				//Подразделение.Вставить("org_num", СокрЛП(ВыборкаПоПодразделениям.Код));
				Подразделение.Вставить("company",Неопределено);
				Подразделение.Вставить("parent", РодительИД);
				Подразделение.Вставить("name", СокрЛП(мПодр.Наименование));
				Подразделение.Вставить("is_removed", мПодр.ПометкаУдаления);
				// Попробуем найти руководителя.
				мНач = "";     
				мНачФЛ="";
				Если ЗначениеЗаполнено(мНПР[3]) Тогда      
					мМодуль = Метаданные.ОбщиеМодули.Найти("РуководителиПодразделений");  
					Если НЕ (мМодуль = Неопределено) Тогда    
						мСсылкаНаМодуль = ОбщегоНазначения.ОбщийМодуль("РуководителиПодразделений");
					Иначе	                                                                        
						мСсылкаНаМодуль = ОбщегоНазначения.ОбщийМодуль("РуководителиПодразделенийОрганизаций");
					КонецЕсли;	
											
					Если мНПР[3] = Перечисления.МК_СтандартныйРуководительПодразделения.СтРеквПозШР Тогда   // Подключена работа с руководителями подразделений в виде позиции ШР (кабинет сотрудника или "Персонал"
						мПозШР = мСсылкаНаМодуль.ПозицияРуководителя(мПодр.Ссылка);    
						Если НЕ (мПозШР = Неопределено) Тогда
							мРук = мСсылкаНаМодуль.СотрудникНаПозицииРуководителя(мПозШР);    // Возвращается ссылка на Сотрудника
							Если НЕ (мРук = Неопределено) Тогда                                          
								мНач = СокрЛП(мРук.УникальныйИдентификатор());
								мНачФЛ = СокрЛП(мРук.ФизическоеЛицо.УникальныйИдентификатор());
							КонецЕсли;	
						КонецЕсли;					
				 	Иначе	
						мДопСвед = мПодр.ДополнительныеРеквизиты;				
						Для Каждого мСвед Из мДопСвед Цикл   
							Если мСвед.Свойство = мНПР[3] Тогда
								Попытка      
									// Руководитель должен иметь тип ссылки на справочник "Сотрудники".
									мНач = СокрЛП(мСвед.Значение.УникальныйИдентификатор());
									мНачФЛ = СокрЛП(мСвед.Значение.ФизическоеЛицо.УникальныйИдентификатор());
								Исключение
								КонецПопытки;	
							КонецЕсли;
						КонецЦикла;
					КонецЕсли;	
				КонецЕсли;	
				Подразделение.Вставить("head", СокрЛП(мНач));
				Подразделение.Вставить("head_individual", СокрЛП(мНачФЛ));
				
				// Проверим необходимость выгрузки, если только изменения.
				ЗаписьJSON = Новый ЗаписьJSON;
				ЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ЗаписьJSON, Подразделение);	
				ПодразделениеJSON = ЗаписьJSON.Закрыть();
			
				ПодразделениеХеш = СокрЛП(ОО.ПолучитьХешСтроки(ПодразделениеJSON));
			

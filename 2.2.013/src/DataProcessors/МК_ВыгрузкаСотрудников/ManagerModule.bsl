Функция ТекущиеПоказателиСотрудников(Сотрудники, ДатаСведений) Экспорт 
	
	СотрудникиДаты = Новый ТаблицаЗначений;    
 
    СотрудникиДаты.Колонки.Добавить("Сотрудник", Новый ОписаниеТипов("СправочникСсылка.Сотрудники")); 	
    СотрудникиДаты.Колонки.Добавить("Период", Новый ОписаниеТипов("Дата"));   
	Для Каждого Сотрудник Из Сотрудники Цикл  
		мСтр = СотрудникиДаты.Добавить();
		мСтр.Сотрудник = Сотрудник;
		мСтр.Период = ДатаСведений;
	КонецЦикла;	

	
	Запрос = Новый Запрос;
	
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	ПараметрыПостроения = ЗарплатаКадрыОбщиеНаборыДанных.ПараметрыПостроенияДляСоздатьВТИмяРегистраСрез();
	ПараметрыПостроения.ФормироватьСПериодичностьДень = Истина;  // была Ложь
	
	ЗарплатаКадрыОбщиеНаборыДанных.СоздатьВТИмяРегистраСрезПоследних(
		"ЗначенияПериодическихПоказателейРасчетаЗарплатыСотрудников",
		Запрос.МенеджерВременныхТаблиц,
		Истина,
		ЗарплатаКадрыОбщиеНаборыДанных.ОписаниеФильтраДляСоздатьВТИмяРегистра(СотрудникиДаты),
		ПараметрыПостроения);
		
		
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗначенияПериодическихПоказателей.Сотрудник КАК Сотрудник,
	|	ЗначенияПериодическихПоказателей.Показатель КАК Показатель,
	|	ЗначенияПериодическихПоказателей.Период КАК Период,
	|	ЗначенияПериодическихПоказателей.ПериодЗаписи КАК ПериодЗаписи, 
	|	ЗначенияПериодическихПоказателей.ДатаНачала КАК ДатаНачала, 
	|	ЗначенияПериодическихПоказателей.ДатаОкончания КАК ДатаОкончания, 
	//|	ЗначенияПериодическихПоказателей.ЭтоВозвратноеСобытие КАК ВозвратноеСобытие, 
	|	ЗначенияПериодическихПоказателей.Значение КАК Значение
	|ИЗ
	|	ВТЗначенияПериодическихПоказателейРасчетаЗарплатыСотрудниковСрезПоследних КАК ЗначенияПериодическихПоказателей";	
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();             
	мВыборка = РезультатЗапроса[0].Выгрузить();		
	Возврат мВыборка;
КонецФункции 


Функция ПоискВМассивеСоответствий(мМассив,мКлюч,мЗначение,мТип)
	мРезультат = Неопределено;
	Для Каждого мСтрока Из мМассив Цикл
		//Для Каждого мЭлСтр Из мСтрока Цикл
		//	Если мЭлСтр.Ключ = мКлюч И мЭлСтр.Значение = мЗначение Тогда
		//		мРезультат = Мстрока;
		//		Прервать;
		//	КонецЕсли;
		//КонецЦикла;	
		// Теперь надо проверять не только совпадение вида оплаты, но и тип.
		мНужноеНачисление = Ложь;
		мНужныйТип = Ложь;
		Для Каждого мЭлСтр Из мСтрока Цикл
			Если мЭлСтр.Ключ = мКлюч И мЭлСтр.Значение = мЗначение Тогда
				мНужноеНачисление = Истина;
			ИначеЕсли мЭлСтр.Ключ = "Тип" И мЭлСтр.Значение = мТип Тогда
				мНужныйТип = Истина;
			КонецЕсли;
		КонецЦикла;	                
		Если мНужноеНачисление и мНужныйТип Тогда
			мРезультат = Мстрока;
			Прервать;
		КонецЕсли;	
	КонецЦикла;	
	Возврат мРезультат;
КонецФункции	        

Функция ПоискВМассивеСтруктур(мМассив,мКлюч,мЗначение)
	мРезультат = Неопределено;
	Для Каждого мСтрока Из мМассив Цикл
		Для Каждого мЭлСтр Из мСтрока Цикл
			Если мЭлСтр.Ключ = мКлюч И мЭлСтр.Значение = мЗначение Тогда
				мРезультат = Мстрока;				
			КонецЕсли;
		КонецЦикла;	                 
		Если Не (мРезультат = Неопределено) Тогда
			Прервать;
		КонецЕсли;	
	КонецЦикла;		
	Возврат мРезультат;
КонецФункции	
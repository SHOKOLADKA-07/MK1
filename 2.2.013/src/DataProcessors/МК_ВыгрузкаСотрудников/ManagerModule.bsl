							// мТабПоказ: ВидНачисления, РеквизитМК, ЧтоВыгружать, Показатель
							мСтрокаНач = ПоискВМассивеСоответствий(мСписНач,"ВидНачисления",мНач.Начисление,0);
							Если Не (мСтрокаНач = Неопределено) Тогда  // Есть такое начисление в списке.
								мРеквМК = мСтрокаНач.РеквизитМК;
								Если мСтрокаНач.ЧтоВыгружать = Перечисления.МК_ВидыВыгрузки.Размер Тогда							
									мСумма = мПланНач.Получить(мРеквМК)+ мНач.Размер;
									мПланНач.Вставить(мРеквМК,мСумма);							
								Иначе    // Значит нужен не размер, а ПоказательРасчетаЗарплаты. Его надо найти в таблице значений мТабПоказ по виду показателя (отбор по сотруднику уже сделан)																
									мСтрокаПоказ = мТабПоказ.Найти(мСтрокаНач.Показатель);
									Если Не мСтрокаПоказ = Неопределено Тогда        
										мСумма = мПланНач.Получить(мРеквМК)+ мСтрокаПоказ.Значение;									
										мПланНач.Вставить(мРеквМК,мСумма);							
									КонецЕсли;
								КонецЕсли;	
							КонецЕсли	
						КонецЦикла;					
						// Собрали начисления к отправке.           
						Для Каждого мНач Из мПланНач Цикл 
							мЭлемКастом = Новый Структура;
							мЭлемКастом.Вставить("name",мНач.Ключ);
							мЭлемКастом.Вставить("value",мНач.Значение);
							мСписКастом.Добавить(мЭлемКастом);
						КонецЦикла;	
					КонецЕсли;						
				КонецЕсли;	                                              
				Сотрудник.Вставить("custom_fields",мСписКастом);      
			КонецЕсли;		
			
			Если мНужен и мВыгрузкаПланНач Тогда
				Если мПланНачСтандарт.Количество()>0 Тогда                 // Стандартные поля в МК     
					мСписСтандарт = Новый Массив;
					// Надо предварительно обнулить суммы
					Для Каждого мНач Из мПланНачСтандарт Цикл    // В мНач (соответствие) ключ - РеквизитМК, значение - сумма к отправке, накапливаемая
						//мПланНачСтандарт.Вставить(мНач.Ключ,0);
						мНач.Сумма = 0;
						мНач.Дата = Неопределено;
					КонецЦикла;	                 
					// Теперь нужно перебрать начисления сотрудника    
					Отбор = Новый Структура;
					Отбор.Вставить("Сотрудник", мСотр.Ссылка);
					мТабНач = мПлановыеНачисления.НайтиСтроки(Отбор);  
					мТабПоказ = мПоказателиРасчетаЗарплаты.Скопировать(Отбор);  
					мДата = Дата(1, 1, 1); 
					мДатаОкончания = Дата(1, 1, 1); 
					Для Каждого мНач из мТабНач Цикл  										 
						// мТабПоказ: ВидНачисления, РеквизитМК, ЧтоВыгружать, Показатель  
						// мТабПоказ:
						// 29.10.25 Оказывается, что при изменении показателей (например "Оклад"), в регистре плановых навислений
						// дата не изменяется. А меняется она в регистре показателей сотрудников. Поэтому будем для даты начала начислений
						// брать бОльшую дату - из основного показателя или из начисления. Причем самая поздняя дата изменений по сотруднику будет
						// подставляться во все начисления, так как показатель может не измениться, а размер - да. Например при изменении оклада
						// размер РК меняется, а показатель (15%) - нет.
						мСтрокаНач = ПоискВМассивеСоответствий(мСписНач,"ВидНачисления",мНач.Начисление,1);
						Если Не (мСтрокаНач = Неопределено) Тогда  // Есть такое начисление в списке.
							мРеквМК = мСтрокаНач.РеквизитМК;
							мСтрока =  ПоискВМассивеСтруктур(мПланНачСтандарт,"ВидНачисления",мРеквМК); 
							Если Не мСтрока = Неопределено Тогда  
								Если мНач.ПериодЗаписи > мДата Тогда
									//мСтрока.Дата = мНач.ПериодЗаписи;
									мДата = мНач.ПериодЗаписи;
								КонецЕсли;									
								Если мСтрокаНач.ЧтоВыгружать = Перечисления.МК_ВидыВыгрузки.Размер Тогда	
									мСтрока.Сумма = мСтрока.Сумма + мНач.Размер;       											
								Иначе    // Значит нужен не размер, а ПоказательРасчетаЗарплаты. Его надо найти в таблице значений мТабПоказ по виду показателя (отбор по сотруднику уже сделан)																
									мСтрокаПоказ = мТабПоказ.Найти(мСтрокаНач.Показатель);
									Если Не мСтрокаПоказ = Неопределено Тогда        
										мСтрока.Сумма = мСтрока.Сумма + мСтрокаПоказ.Значение;																	
									КонецЕсли;
								КонецЕсли;	
								// Проверяем дату основного показателя
								мСтрокаПоказ = мТабПоказ.Найти(мНач.ОсновнойПоказатель);
								Если (Не мСтрокаПоказ = Неопределено) Тогда
									Если мСтрокаПоказ.ПериодЗаписи > мДата  Тогда        
										мДата = мСтрокаПоказ.ПериодЗаписи;																	
									КонецЕсли;                           
									Если Не (мСтрокаПоказ.ДатаОкончания = Дата("31.12.3999 23:59:59")) И мСтрокаПоказ.ДатаОкончания > мДатаОкончания Тогда  // Дата окончания есть
										мДатаОкончания = мСтрокаПоказ.ДатаОкончания;
									КонецЕсли;	
								КонецЕсли;	

							КонецЕсли;	
						КонецЕсли	
					КонецЦикла;					
					// Собрали начисления к отправке.  
					Если мДата = Дата(1, 1, 1) Тогда
						мДата = Неопределено;
					КонецЕсли;	
					Если мДатаОкончания = Дата(1, 1, 1) Тогда
						мДатаОкончания = Неопределено;
					КонецЕсли;	
					Для Каждого мНач Из мПланНачСтандарт Цикл 
						мЭлемСтандарт = Новый Структура;
						мЭлемСтандарт.Вставить("name",мНач.ВидНачисления);
						мЭлемСтандарт.Вставить("value",мНач.Сумма);						
						мЭлемСтандарт.Вставить("date",мДата);
						мЭлемСтандарт.Вставить("date_end",мДатаОкончания);
						мСписСтандарт.Добавить(мЭлемСтандарт);
					КонецЦикла;					
					Сотрудник.Вставить("planned_salary",мСписСтандарт);      
				КонецЕсли;	   			
			КонецЕсли;	   			
			
			Если мНужен Тогда		
				// Сравнение с предыдущими выгруженными данными
				ЗаписьJSON = Новый ЗаписьJSON;
				ЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ЗаписьJSON, Сотрудник);	
				СотрудникJSON = ЗаписьJSON.Закрыть();
			
				СотрудникХеш = СокрЛП(ОО.ПолучитьХешСтроки(СотрудникJSON));
			
				Изменилось = Ложь;
				Если СокрЛП(мСотр.ВерсияДанныхСотрудника) <> СотрудникХеш Тогда
					ДопСвед = РегистрыСведений.ДополнительныеСведения.СоздатьМенеджерЗаписи();
					ДопСвед.Объект = мСотр.Ссылка;
					ДопСвед.Свойство = СвойствоХэшСотр;
					ДопСвед.Значение = СотрудникХеш;
					ДопСвед.Записать();
					Изменилось = Истина;
				КонецЕсли; 
                Если (мТолькоИзменения И Изменилось) ИЛИ НЕ мТолькоИзменения Тогда 
					Выгрузка.Users.Добавить(Сотрудник);
					мКолвоПорции = мКолвоПорции + 1;
					Если мКолвоПорции = мМаксКС Тогда     
						мНомерПорции = мНомерПорции + 1;
						Если мСпособВыгрузки = 1 Тогда        // На сайт
							мРезультат = ОтправитьСотрудников(Выгрузка,мСеанс,ОО,ИнтерактивныйРежим);   // Отправляем порцию сотрудников           														
						Иначе	                             // В файл
							мРезультат = СохранитьПорциюНаДиск(Выгрузка,мНомерПорции,мДирВрем);
						КонецЕсли;
						мОКолво = мОКолво + мКолвоПорции;
						мКолвоПорции = 0;
						Выгрузка.Users.Очистить();
					КонецЕсли;	
				КонецЕсли;
			КонецЕсли;
			ПроцВып = Окр(мнСотр/ВсегоСотр*100,0);
		
			// Cообщаем "процент" и "текст сообщения"
			Если ИнтерактивныйРежим Тогда
				ДлительныеОперации.СообщитьПрогресс(ПроцВып,"Выполняется обработка списка сотрудников");
            КонецЕсли;
		КонецЦикла;  
		// Сведения по сотрудникам подобраны. Пока все.
		// Надо отправить.   
		мКолво = Выгрузка.Users.Количество();
		Если мКолво > 0 Тогда              
			мОКолво = мОКолво + мКолво;
			Если мСпособВыгрузки = 1 Тогда               				
				мРезультат = ОтправитьСотрудников(Выгрузка,мСеанс,ОО,ИнтерактивныйРежим);
			Иначе    // Выгрузка в файл.                                                     
				ДлительныеОперации.СообщитьПрогресс("","Файл копируется в указанный каталог");   
				Если мНомерПорции = 0 Тогда          // Если ни одной порции еще не было сохранено, то отправляем JSON файл.                             
					ЗаписьJSON = Новый ЗаписьJSON;     				
					ЗаписьJSON.УстановитьСтроку();
        			ЗаписатьJSON(ЗаписьJSON, Выгрузка);	
					ТекстJSON = ЗаписьJSON.Закрыть();
					мАдрес3 = ПоместитьВоВременноеХранилище(ТекстJSON,мАдресРез3);
			    	мВозврат.Добавить(мАдрес3);
					мВозврат.Добавить(ОО.ПолучитьИмяФайла("Сотрудники",мДир));					                         
				Иначе	
					мНомерПорции = мНомерПорции + 1;
					мРезультат = СохранитьПорциюНаДиск(Выгрузка,мНомерПорции,мДирВрем);				
				КонецЕсли;	         				
			КонецЕсли;	
		КонецЕсли;
		// Может получиться, что в последней порции ничего нет. Поэтому формирование архива с файлами-порциями по сотрудникам
		// надо выполнить сейчас
		Если мСпособВыгрузки = 2 И мНомерПорции <> 0 Тогда  
			ИмяАрхива = мДирВрем + "\Сотрудники"+"_"+ОО.ДатаВСтроку(ТекущаяДата())+".zip";
			мАрхив = Новый ЗаписьZipФайла(ИмяАрхива,"", "Выгрузка сотрудников",МетодСжатияZIP.Сжатие, УровеньСжатияZIP.Оптимальный, МетодШифрованияZIP.Zip20);
			мАрхив.Добавить(мДирВрем+"*.json");
			мАрхив.Записать();
			
			мФайлАрхив = Сред(ИмяАрхива, СтрНайти(ИмяАрхива, "\", НаправлениеПоиска.СКонца) + 1);     // Выделяем только имя файла
			Попытка          	    	 
				Двоичное=Новый ДвоичныеДанные(ИмяАрхива);
				мАдрес3 = ПоместитьВоВременноеХранилище(Двоичное,мАдресРез3);     
				мВозврат.Добавить(мАдрес3);      // Адрес zip-архива.
				мВозврат.Добавить(мФайлАрхив);   // Имя файла уже вычислено. Передаем.
			Исключение    
				мРезультат = Ложь;
				мВозврат.Добавить(Неопределено);
				мВозврат.Добавить(Неопределено);
			КонецПопытки;	
         КонецЕсли;	
	КонецЕсли;                               
		                     
	
	// Возвращать будем массив. 
	// первый элемент - успешность процесса
	// второй - список сотрудников без емэйл не пустой.
	// третий - кол-во выгруженных сотрудников.
	Если мСпособВыгрузки =1 Тогда
		Если мРезультат Тогда
			мРез = 1;        
		Иначе
			мРез = 0;
		КонецЕсли;	
	Иначе 
		мРез = 2;        
	КонецЕсли;	
	мВозврат[0] = мРез;
	лПрот = Ложь;
	Если мПрот.Количество() > 0 Тогда
		лПрот = Истина;
	КонецЕсли;	       
	мВозврат[1] = лПрот;   
	Если лПрот Тогда
		мВозврат[2] = мПрот;
	КонецЕсли;	
	мВозврат[3] = мОКолво;   
	Если лПрот Тогда
		мВозврат.Добавить(мПрот);
	КонецЕсли;	
	// Еще 6 элементов добавляются выше - имена и адреса созданных файлов для выгрузки на диск.
	Возврат мВозврат;
КонецФункции        

Функция ОтправитьСотрудников(Выгрузка,мСеанс,ОО,ИнтерактивныйРежим)     // В связи с отправкой сотрудников порциями, процесс отправки вынесен в отдельную функцию.
	Если ИнтерактивныйРежим Тогда
		ДлительныеОперации.СообщитьПрогресс("","Сведения отправляются на сайт МояКоманда");
	КонецЕсли;	
	Попытка  
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
        ЗаписатьJSON(ЗаписьJSON, Выгрузка);	
		ТекстJSON = ЗаписьJSON.Закрыть();
		//ТекстJSON = ЗаписатьЗначениеJSON(Выгрузка);
	Исключение                                                          
		Сообщить(ЗначениеВСтрокуВнутр(Выгрузка));
		ВызватьИсключение(ОписаниеОшибки());
	КонецПопытки;

	hЗапрос = ОО.СоздатьHTTPЗапрос("/api/1c-exchange/user-list", мСеанс);  
	hЗапрос.Заголовки.Вставить("Source","1C Enterprise MK");
	hЗапрос.УстановитьТелоИзСтроки(ТекстJSON);   
	// Изменение в логике создания запросов. Бывают ситуации, когда запрос не успевает обработаться и обрывается по тайм-ауту. Поэтому 
	// переходим на серию запросов, которые надо запускать через некоторую паузу, до получения окончательного результата.				
	мРезультат = ОО.ВызватьhМетод("POST", мСеанс, hЗапрос,"/api/1c-exchange/user-list", "Сотрудники", ИнтерактивныйРежим);
	Возврат мРезультат;
КонецФункции

Функция СохранитьПорциюНаДиск(Выгрузка,мНомерПорции,мДир);
	ИмяФайла = мДир+"Сотрудники"+мНомерПорции+".json";
	ЗаписьJSON = Новый ЗаписьJSON;  
	ЗаписьJSON.ОткрытьФайл(ИмяФайла);
	ЗаписатьJSON(ЗаписьJSON,Выгрузка); 
	ЗаписьJSON.Закрыть();
КонецФункции

Функция МассивСвойств(СписокОрганизаций,мТолькоИзменения,мВыгружатьОрганизации,мВыгружатьДолжности,мВыгружатьГрафики, мНПР);
	// Тут заполним небольшие справочники и перечисления, передаваемые в МоюКоманду
	// По просьбе клиента массив убираем. Свойства сразу добавляются в структуру.
	// Первый элемент - виды занятости.
	Элемент = Новый Структура;
	ВидыЗанятости = Новый Соответствие;
	ВидыЗанятости.Вставить("1","Основное");
	ВидыЗанятости.Вставить("2","Внешнее совместительство");   
	ВидыЗанятости.Вставить("3","Внутреннее совместительство");
	ВидыЗанятости.Вставить("4","ГПХ");
	ВидыЗанятости.Вставить("5","Не определено");
	Элемент.Вставить("type_of_employment",ВидыЗанятости);
	
	ОО = Обработки.МК_НастройкаВыгрузки.Создать();             // Получили доступ к обработке, в которой находятся служебные функции
	СвойствоХэшДолжн = ОО.НайтиДопРеквХэшДанных("Должности");  
	
	Если мВыгружатьОрганизации Тогда
		// Теперь - краткий справочник организаций. Пока поживет.
		Организации = Новый Соответствие;   
		Для Каждого Организация Из СписокОрганизаций Цикл     
			Организации.Вставить(СокрЛП(Организация.Значение.УникальныйИдентификатор()),Организация.Значение.Наименование);
		КонецЦикла;    
		Элемент.Вставить("company",Организации);
	
		// Теперь - полный справочник организаций.
		СвойствоХэшОрг = ОО.НайтиДопРеквХэшДанных("Организации");  
		Организации = Новый Массив();                              
	
		мСписОрг = СписокОрганизацийПолный(СписокОрганизаций, СвойствоХэшОрг); 
		// Добавим организации в выгрузку.
		Пока мСписОрг.Следующий() Цикл
			мОрг = Новый Структура;
			мОрг.Вставить("id", СокрЛП(мСписОрг.Ссылка.УникальныйИдентификатор()));
			мОрг.Вставить("pname",СокрЛП(мСписОрг.НаименованиеПолное));
			мОрг.Вставить("sname",СокрЛП(мСписОрг.НаименованиеСокращенное));
			мОрг.Вставить("inn",мСписОрг.ИНН);
			мОрг.Вставить("kpp",мСписОрг.КПП);
			мОрг.Вставить("ogrn",мСписОрг.ОГРН);
			// Руководителя запросом не выходит получать, так как к комплексной автоматизации нет регистра ответственных лиц.  
			Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.СведенияОбОтветственныхЛицах") Тогда
				// Это запрос сведений о руководителе в ЗУП
				мДРук = ЗарплатаКадры.ОтветственныеЛицаОрганизации(мСписОрг.Ссылка, "Руководитель,ДолжностьРуководителя", ТекущаяДатаСеанса());
			Иначе 
				// А тут - для комплексной.  
				мДРук = ПолучитьДанныеРуководителя(мСписОрг.Ссылка, ТекущаяДатаСеанса());
			КонецЕсли;	
			// Из запроса приходит ссылка на физическое лицо. По ней нам надо найти сотрудника, так как МояКоманда ничего о физлицах не знает. 
			мСотрРук = Неопределено;
			мДолжнРук = Неопределено;
			Если ЗначениеЗаполнено(мДРук.Руководитель) Тогда;    
				мОрг.Вставить("head_individual",СокрЛП(мДРук.Руководитель.УникальныйИдентификатор()));   // Теперь и ID физлица тоже передается.
			 	мСписСотр = ОО.СписокСотрудниковПоФизлицу(мСписОрг.Ссылка,мДРук.Руководитель);  // В этой функции подбираются только основные сотрудники или внешние
				Если мСписСотр.Следующий() Тогда                                                // совместители. Если все хорошо, вернется одна запись. Если больше - нас не волнует,
					мСотрРук = мСписСотр.СотрудникСсылка;                                       // возьмем первого.
			 		мДолжнРук = мСписСотр.ДолжностьСсылка;
			 		мВидЗан = мСписСотр.ВидЗанятости;
			 	КонецЕсли;	
			 	Если ЗначениеЗаполнено(мСотрРук) Тогда
			 		мОрг.Вставить("head",СокрЛП(мСотрРук.УникальныйИдентификатор()));
			 	КонецЕсли;	
			 КонецЕсли;	
			 // Должность руководителя может быть не указана в регистре ответственных лиц. В этом случае ее видимо надо извлечь из сотрудника.
        	 Если ЗначениеЗаполнено(мДРук.ДолжностьРуководителя) Тогда
			 	мОрг.Вставить("head_position",СокрЛП(мДРук.ДолжностьРуководителя.УникальныйИдентификатор())); 
			 ИначеЕсли ЗначениеЗаполнено(мДолжнРук) Тогда
			 	мОрг.Вставить("head_position",СокрЛП(мДолжнРук.УникальныйИдентификатор())); 
			 КонецЕсли;
		
			// Проверим необходимость выгрузки, если только изменения.
			ЗаписьJSON = Новый ЗаписьJSON;
			ЗаписьJSON.УстановитьСтроку();
			ЗаписатьJSON(ЗаписьJSON, мОрг);	
			ОрганизацияJSON = ЗаписьJSON.Закрыть();
				
			ОрганизацияХеш = СокрЛП(ОО.ПолучитьХешСтроки(ОрганизацияJSON));
			
			Изменилось = Ложь;
			Если СокрЛП(мСписОрг.ВерсияДанныхОрганизаций) <> ОрганизацияХеш Тогда
				ДопСвед = РегистрыСведений.ДополнительныеСведения.СоздатьМенеджерЗаписи();
				ДопСвед.Объект = мСписОрг.Ссылка;
				ДопСвед.Свойство = СвойствоХэшОрг;
				ДопСвед.Значение = ОрганизацияХеш;
				ДопСвед.Записать();
				Изменилось = Истина;
			КонецЕсли; 
			Если (мТолькоИзменения И Изменилось) ИЛИ НЕ мТолькоИзменения Тогда                                                 
				Организации.Добавить(мОрг);			
			КонецЕсли;
		КонецЦикла;   
		Элемент.Вставить("company_full",Организации);	
	КонецЕсли;
	
	Если мВыгружатьДолжности Тогда
		ФильтрДолжности = ОО.ПолучитьФильтрДолжности(); 
		// Теперь список должностей
		СписокДолжностей = ПолучитьСписокДолжностей(ФильтрДолжности, СвойствоХэшДолжн);
		Должности = Новый Соответствие;   
		Пока СписокДолжностей.Следующий() Цикл     
			// Тут надо проверить - нужно отправлять или нет, если только изменения.
			// Сравнение с предыдущими выгруженными данными   
			мСтрока = Новый Структура;
			мСтрока.Вставить("id",СокрЛП(СписокДолжностей.Ссылка.УникальныйИдентификатор()));
			мСтрока.Вставить("name",СписокДолжностей.Ссылка.Наименование);
			ЗаписьJSON = Новый ЗаписьJSON;
			ЗаписьJSON.УстановитьСтроку();
			ЗаписатьJSON(ЗаписьJSON, мСтрока);	
			ДолжностьJSON = ЗаписьJSON.Закрыть();
			
			ДолжностьХеш = СокрЛП(ОО.ПолучитьХешСтроки(ДолжностьJSON));
			
			Изменилось = Ложь;
			Если СокрЛП(СписокДолжностей.ВерсияДанныхДолжности) <> ДолжностьХеш Тогда
				ДопСвед = РегистрыСведений.ДополнительныеСведения.СоздатьМенеджерЗаписи();
				ДопСвед.Объект = СписокДолжностей.Ссылка;
				ДопСвед.Свойство = СвойствоХэшДолжн;
				ДопСвед.Значение = ДолжностьХеш;
				ДопСвед.Записать();
				Изменилось = Истина;
			КонецЕсли; 
			Если (мТолькоИзменения И Изменилось) ИЛИ НЕ мТолькоИзменения Тогда                                                 
				Должности.Вставить(СокрЛП(СписокДолжностей.Ссылка.УникальныйИдентификатор()),СписокДолжностей.Ссылка.Наименование);			
			КонецЕсли;
		КонецЦикла;    		
		// Могут быть еще "кастомные" должности в виде дополнительных реквизитов к справочникам сотрудников или физлиц.
		// Они хранятся в справочнике "ЗначенияСвойствОбъектов".
		Если ЗначениеЗаполнено(мНПР[4]) Тогда
			СписокДолжностей = ПолучитьКастомныеДолжности(мНПР[4]); 
			Пока СписокДолжностей.Следующий() Цикл   
				Должности.Вставить(СокрЛП(СписокДолжностей.Ссылка.УникальныйИдентификатор()),СписокДолжностей.Ссылка.Наименование);			
			КонецЦикла;	                           			
		КонецЕсли;                                 
		Элемент.Вставить("positions",Должности);   
	КонецЕсли;
	
	ТипыДок = Новый Соответствие;
	ТипыДок.Вставить("03","Свидетельство о рождении");
	ТипыДок.Вставить("07","Военный билет");
	ТипыДок.Вставить("08","Временное удостоверение, выданное взамен военного билета");
	ТипыДок.Вставить("10","Паспорт иностранного гражданина");
	ТипыДок.Вставить("11","Свидетельство о рассмотрении ходатайства о признании лица беженцем на территории РФ по существу");
	ТипыДок.Вставить("12","Вид на жительство в РФ");
	ТипыДок.Вставить("13","Удостоверение беженца");
	ТипыДок.Вставить("14","Временное удостоверение личности гражданина РФ");
	ТипыДок.Вставить("15","Разрешение на временное проживание в РФ");
	ТипыДок.Вставить("19","Свидетельство о предоставлении временного убежища на территории РФ");
	ТипыДок.Вставить("21","Паспорт гражданина РФ");
	ТипыДок.Вставить("22","Загранпаспорт гражданина РФ");
	ТипыДок.Вставить("23","Свидетельство о рождении, выданное уполномоченным органом иностранного государства");
	ТипыДок.Вставить("24","Удостоверение личности военнослужащего РФ");
	ТипыДок.Вставить("27","Военный билет офицера запаса");
	ТипыДок.Вставить("91","Иные документы");
	
	Элемент.Вставить("types_of_doc",ТипыДок);

	// Теперь основания увольнения
	СписокОснУвол = ПолучитьОснованияУвольнения();
	ОснУвол = Новый Соответствие;   
	Пока СписокОснУвол.Следующий() Цикл     
		ОснУвол.Вставить(СокрЛП(СписокОснУвол.Ссылка.УникальныйИдентификатор()),СписокОснУвол.Ссылка.Наименование); //,СписокОснУвол.Статья);
	КонецЦикла;    
	Элемент.Вставить("GroundDismiss",ОснУвол);       
	
	// Теперь графики работы     
	Если мВыгружатьГрафики Тогда
		СвойствоХэшГраф = ОО.НайтиДопРеквХэшДанных("ГрафикиРаботыСотрудников");    
		мГрафики = Новый Массив();
		мСписГраф = ПолучитьГрафики(СвойствоХэшГраф);                                 
		Пока мСписГраф.Следующий() Цикл
			мГраф = Новый Структура;
			мГраф.Вставить("id", СокрЛП(мСписГраф.Ссылка.УникальныйИдентификатор()));
			мГраф.Вставить("name",СокрЛП(мСписГраф.Ссылка.Наименование));
			// Неполное рабочее время
			Если мСписГраф.НРВ Тогда
				мНРВ = 1;
			Иначе     
				мНРВ = 0;
			КонецЕсли;	
			мГраф.Вставить("nrab_vrem",мНРВ);
			// Неполная рабочая неделя 
			Если мСписГраф.НРН Тогда
				мНРН = 1;
			Иначе     
				мНРН = 0;
			КонецЕсли;	
    	    мГраф.Вставить("nrab_ned",мНРН);
			// Неполный рабочий день
			Если мСписГраф.НРД Тогда
				мНРД = 1;
			Иначе     
				мНРД = 0;
			КонецЕсли;	
    	    мГраф.Вставить("nrab_den",мНРД);
		
				
			// Проверим необходимость выгрузки, если только изменения.
			ЗаписьJSON = Новый ЗаписьJSON;
			ЗаписьJSON.УстановитьСтроку();
			ЗаписатьJSON(ЗаписьJSON, мГраф);	
			ГрафикJSON = ЗаписьJSON.Закрыть();
				
			ГрафикХеш = СокрЛП(ОО.ПолучитьХешСтроки(ГрафикJSON));
			
			Изменилось = Ложь;
			Если СокрЛП(мСписГраф.ВерсияДанныхГрафиков) <> ГрафикХеш Тогда
				ДопСвед = РегистрыСведений.ДополнительныеСведения.СоздатьМенеджерЗаписи();
				ДопСвед.Объект = мСписГраф.Ссылка;
				ДопСвед.Свойство = СвойствоХэшГраф;
				ДопСвед.Значение = ГрафикХеш;
				ДопСвед.Записать();
				Изменилось = Истина;
			КонецЕсли; 
			Если (мТолькоИзменения И Изменилось) ИЛИ НЕ мТолькоИзменения Тогда                                                 
				мГрафики.Добавить(мГраф);			
			КонецЕсли;
		КонецЦикла;   
		Элемент.Вставить("schedule",мГрафики);	
	КонецЕсли;
	// Готово, все собрали
    Возврат Элемент;
КонецФункции

Функция ПолучитьДанныеРуководителя(Организация, Дата = Неопределено) Экспорт // Это для комплексной автоматизации
	
	ОтветственноеЛицо = Перечисления.ОтветственныеЛицаОрганизаций.Руководитель;
	Модуль = ОбщегоНазначения.ОбщийМодуль("ОтветственныеЛицаСервер");
	
	СтруктураОтветственных = Модуль.ПолучитьОтветственныеЛицаОрганизации(Организация, Дата);
	Результат 			   = Новый Структура();
	
	Для Каждого МетаВидОтветственного Из Метаданные.Перечисления.ОтветственныеЛицаОрганизаций.ЗначенияПеречисления Цикл
		
		Ключ = МетаВидОтветственного.Имя;
		Если ОтветственноеЛицо = Перечисления.ОтветственныеЛицаОрганизаций[Ключ] Тогда
			Результат.Вставить("Руководитель", СтруктураОтветственных[Ключ]);
			Результат.Вставить("ДолжностьРуководителя", СтруктураОтветственных[Ключ + "ДолжностьСсылка"]);
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции


Функция ПолучитьСписокПодразделений(СписокОрганизаций,ФильтрПодразделения, СвойствоХэш, мСпосХрПодр)  
	УстановитьПривилегированныйРежим(Истина);
	
	мЗапрос = Новый Запрос;
	мЗапрос.УстановитьПараметр("Организации", СписокОрганизаций);
	мЗапрос.УстановитьПараметр("ДатаВыборки", ТекущаяДата());
	мЗапрос.УстановитьПараметр("СвойствоХэш", СвойствоХэш);
	
	мЗапрос.Текст = 
		"ВЫБРАТЬ
		|	мРуководители.Подразделение КАК Подразделение,
		|	мРуководители.Руководитель КАК Руководитель  
		|ПОМЕСТИТЬ ВТРуководители
		|ИЗ 
		|	РегистрСведений.ПодразделенияОрганизацииРуководители.СрезПоследних(&ДатаВыборки) КАК мРуководители;	
		|
		|ВЫБРАТЬ
		|   ПодразделенияОрганизаций.Ссылка КАК Ссылка,
		|	ПодразделенияОрганизаций.Владелец КАК Организация,
		|	ПодразделенияОрганизаций.Родитель КАК Родитель,
		|	ПодразделенияОрганизаций.Код КАК Код,
		|	ПодразделенияОрганизаций.Родитель.Код КАК РодительКод,
		|	ПодразделенияОрганизаций.ПометкаУдаления КАК ПометкаУдаления,
		|	ПодразделенияОрганизаций.Наименование КАК Наименование,
		|	ЕСТЬNULL(ДопСведВерсияДанных.Значение, """") КАК ВерсияДанныхПодразделений,	
		|	ЕСТЬNULL(ВТРуководители.Руководитель,"""") КАК РуководительПодразделения,
		|	ЕСТЬNULL(СтруктураПредприятия.Ссылка,"""") КАК СтруктураСсылка,		
		|	ПодразделенияОрганизаций.ДополнительныеРеквизиты.(
		|		Свойство КАК Свойство,
		|		Свойство.Имя КАК Имя,
		|		Значение КАК Значение
		|	) КАК ДополнительныеРеквизиты 
		|ИЗ
		|	Справочник.ПодразделенияОрганизаций КАК ПодразделенияОрганизаций  
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДопСведВерсияДанных
		|	ПО (ДопСведВерсияДанных.Свойство = &СвойствоХэш)
		|		И (ДопСведВерсияДанных.Объект = ПодразделенияОрганизаций.Ссылка) 
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВТРуководители
		|	ПО ВТРуководители.Подразделение = ПодразделенияОрганизаций.Ссылка              
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СтруктураПредприятия КАК СтруктураПредприятия
		|   По СтруктураПредприятия.Источник = ПодразделенияОрганизаций.Ссылка              
		|ГДЕ
		|	ПодразделенияОрганизаций.Владелец В (&Организации)
		|   И ПодразделенияОрганизаций.Расформировано = Ложь 
		|	И (ПодразделенияОрганизаций.ДатаРасформирования = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
    	|	ИЛИ ПодразделенияОрганизаций.ДатаРасформирования > &ДатаВыборки)
		|   И НЕ ПодразделенияОрганизаций.Ссылка.ПометкаУдаления
		|   &УсловияФильтров";                                                  
	
	мТекст = "";
	Если ФильтрПодразделения[0] <> "0" Тогда          
		мЗапрос.УстановитьПараметр("Подразделения",ФильтрПодразделения[1]);	
		Если НЕ ПустаяСтрока(мТекст) Тогда
			мТекст = мТекст + Символы.ПС; 
		КонецЕсли;	 
		Если ФильтрПодразделения[0] = "1" Тогда  // Учитываем, выгружаем.
			мТекст = мТекст + "    И ПодразделенияОрганизаций.Ссылка В (&Подразделения)";
	    Иначе
			мТекст = мТекст + "    И НЕ (ПодразделенияОрганизаций.Ссылка В (&Подразделения))";
		КонецЕсли;			   
	КонецЕсли;       
	мЗапрос.Текст = СтрЗаменить(мЗапрос.Текст, "&УсловияФильтров",мТекст);  
    РезультатЗапроса = мЗапрос.ВыполнитьПакет();
	//Выборка = РезультатЗапроса[1].Выбрать(); 
	Выборка = РезультатЗапроса[1].Выгрузить();

	Возврат Выборка;
		
КонецФункции                         

Функция ПолучитьСтруктуру(ФильтрПодразделения, СвойствоХэш, мСпосХрПодр)  
	УстановитьПривилегированныйРежим(Истина);
	
	мЗапрос = Новый Запрос;
	мЗапрос.УстановитьПараметр("ДатаВыборки", ТекущаяДата());
	мЗапрос.УстановитьПараметр("СвойствоХэш", СвойствоХэш);
	
	мЗапрос.Текст = 
    	"ВЫБРАТЬ
		|   СтруктураПредприятия.Ссылка КАК Ссылка,		
		|	СтруктураПредприятия.Родитель КАК Родитель,
		|	СтруктураПредприятия.Код КАК Код,
		|	СтруктураПредприятия.Родитель.Код КАК РодительКод,
		|	СтруктураПредприятия.ПометкаУдаления КАК ПометкаУдаления,
		|	СтруктураПредприятия.Наименование КАК Наименование,
		|	ЕСТЬNULL(ДопСведВерсияДанных.Значение, """") КАК ВерсияДанныхСтруктуры,					
		|	СтруктураПредприятия.ДополнительныеРеквизиты.(
		|		Свойство КАК Свойство,
		|		Свойство.Имя КАК Имя,
		|		Значение КАК Значение
		|	) КАК ДополнительныеРеквизиты 
		|ИЗ
		|	Справочник.СтруктураПредприятия КАК СтруктураПредприятия  
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДопСведВерсияДанных
		|	ПО (ДопСведВерсияДанных.Свойство = &СвойствоХэш)
		|		И (ДопСведВерсияДанных.Объект = СтруктураПредприятия.Ссылка)
		|   &УсловияФильтров";                                                  
	
	мТекст = "";
	Если ФильтрПодразделения[0] <> "0" Тогда          
		мЗапрос.УстановитьПараметр("Подразделения",ФильтрПодразделения[1]);	
		Если НЕ ПустаяСтрока(мТекст) Тогда
			мТекст = мТекст + Символы.ПС; 
		КонецЕсли;	 
		Если ФильтрПодразделения[0] = "1" Тогда  // Учитываем, выгружаем.
			мТекст = мТекст + "ГДЕ    СтруктураПредприятия.Ссылка В (&Подразделения)";
	    Иначе
			мТекст = мТекст + "ГДЕ    НЕ (СтруктураПредприятия.Ссылка В (&Подразделения))";
		КонецЕсли;			   
	КонецЕсли;       
	мЗапрос.Текст = СтрЗаменить(мЗапрос.Текст, "&УсловияФильтров",мТекст);  
    РезультатЗапроса = мЗапрос.ВыполнитьПакет();	
	Выборка = РезультатЗапроса[0].Выгрузить();

	Возврат Выборка;
		
КонецФункции


Функция ПолучитьСписокДолжностей(ФильтрДолжности, СвойствоХэш)  
	// Новая вводная: если должность исключена из списка выгружаемых, то в справочник ее тоже выгружать не надо.
	
	мЗапрос = Новый Запрос;                                
	мЗапрос.УстановитьПараметр("СвойствоХэш", СвойствоХэш);
	мЗапрос.Текст =                                        	
	"ВЫБРАТЬ
	|	Должности.Ссылка КАК Ссылка,
	|	ЕСТЬNULL(ДопСведВерсияДанных.Значение, """") КАК ВерсияДанныхДолжности
	|ИЗ
	|	Справочник.Должности КАК Должности
	|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДопСведВерсияДанных
	|	ПО (ДопСведВерсияДанных.Свойство = &СвойствоХэш)
	|		И (ДопСведВерсияДанных.Объект = Должности.Ссылка) 
	|ГДЕ
	|	НЕ Должности.ПометкаУдаления
	|	И НЕ Должности.ИсключенаИзШтатногоРасписания
	|   &УсловияФильтров";  
	мТекст = "";
	Если ФильтрДолжности[0] <> "0" Тогда          
		мЗапрос.УстановитьПараметр("Должности",ФильтрДолжности[1]);	
		Если НЕ ПустаяСтрока(мТекст) Тогда
			мТекст = мТекст + Символы.ПС; 
		КонецЕсли;	 
		Если ФильтрДолжности[0] = "1" Тогда  // Учитываем, выгружаем.
			мТекст = мТекст + "    И Должности.Ссылка В (&Должности)";
	    Иначе
			мТекст = мТекст + "    И НЕ (Должности.Ссылка В (&Должности))";
		КонецЕсли;			   
	КонецЕсли;       
	мЗапрос.Текст = СтрЗаменить(мЗапрос.Текст, "&УсловияФильтров",мТекст);  
	РезультатЗапроса = мЗапрос.ВыполнитьПакет();
	Выборка = РезультатЗапроса[0].Выбрать();
	Возврат Выборка;
КонецФункции


Функция ПолучитьСписокПланНач()
	мЗапрос = Новый Запрос;
	
	мЗапрос.Текст = 
	"ВЫБРАТЬ
	|	МК_НВПН.ВидНачисления1С КАК ВидНачисления ,
	|   МК_НВПН.РеквизитМК КАК РеквизитМК,	
	|   МК_НВПН.ЧтоВыгружать КАК ЧтоВыгружать,	
	|   МК_НВПН.Показатель КАК Показатель,
	|   МК_НВПН.Стандарт КАК Тип
	|ИЗ 
	|	Справочник.МК_НастройкаВыгрузкиПлановыхНачислений КАК МК_НВПН
	|ГДЕ
	|	НЕ МК_НВПН.ПометкаУдаления 
	|   И МК_НВПН.Выгружать = Истина" ;
	
		
	РезультатЗапроса = мЗапрос.ВыполнитьПакет();
	Выборка = РезультатЗапроса[0].Выбрать();
	мСписНач = Новый Массив;
	Пока Выборка.Следующий() Цикл	
		Если ЗначениеЗаполнено(Выборка.РеквизитМК) И ЗначениеЗаполнено(Выборка.ВидНачисления) Тогда
			мНач = Новый Структура("ВидНачисления, РеквизитМК, ЧтоВыгружать, Показатель, Тип",Выборка.ВидНачисления,Выборка.РеквизитМК,Выборка.ЧтоВыгружать,Выборка.Показатель,Выборка.Тип);
			мСписНач.Добавить(мНач); 
		КонецЕсли;	
	КонецЦикла;	
			
	Возврат мСписНач; 
КонецФункции	
                                               

Функция СписокСотрудников(мПарам)
	
	// Проблема с договорами ГПХ, назначенными действующим сотрудникам. Такие договоры часто создают запись
	// в регистре "ДанныеДляПодбораСотрудников" с бОльшей датой начала, чем действующая запись для основного
	// рабочего места, что приводит к выборке именно сведений по ГПХ в результат запроса. Надо это исключить
	// мПарам: СписокОрганизаций,ФильтрВидыЗанятости,ФильтрПодразделения,ФильтрДолжности,ФильтрСотрудники,ФильтрСтруктуры,СвойствоХэш,мНВИ,мВыгружатьПодразделения,мВыгружатьСтруктуру. 
	УстановитьПривилегированныйРежим(Истина);
	
	мЗапрос = Новый Запрос;
	мЗапрос.УстановитьПараметр("Организации", мПарам.СписокОрганизаций);
	мЗапрос.УстановитьПараметр("СвойствоХэш", мПарам.СвойствоХэшСотр);
	мЗапрос.УстановитьПараметр("ДатаНачала", ДобавитьМесяц(НачалоДня(ТекущаяДата()), 1));         // Для поступления нужна текущая дата плюс месяц
	мЗапрос.УстановитьПараметр("ДатаОкончания",  ДобавитьМесяц(НачалоДня(ТекущаяДата()), -1)); 	  // А для увольнения - месяцем раньше. То есть если сотрудник уволен, он будет попадать
																								  // в выборку целый месяц.                                                             
	мЗапрос.Текст =   
	"ВЫБРАТЬ    
		// Опять новая вводная - хотят, чтобы запись по ГПХ для работающих сотрудников выгружалась   
		// Закомментирован вариант, исключающий попадание строки по ГПХ по работающему сотруднику в выгрузку
		// 08.08.2025 Снова возвращаемся к варианту без выгрузки ГПХ 
		|	ДанныеДляПодбора.Сотрудник КАК Сотрудник, 
		|   МИНИМУМ(ДанныеДляПодбора.ПоДоговоруГПХ)	КАК ПоДоговоруГПХ		
		|ПОМЕСТИТЬ СрезДанных1
		|ИЗ
		|	РегистрСведений.ДанныеДляПодбораСотрудников КАК ДанныеДляПодбора
		|ГДЕ
		|	ДанныеДляПодбора.Организация В(&Организации)
		|	И ДанныеДляПодбора.ВидСобытия <> ЗНАЧЕНИЕ(Перечисление.ВидыКадровыхСобытий.Увольнение)
		|	И ДанныеДляПодбора.Начало <> ДАТАВРЕМЯ(1, 1, 1)
		|	И ДанныеДляПодбора.Начало <= КОНЕЦПЕРИОДА(&ДатаНачала, ДЕНЬ)
		|	И (ДанныеДляПодбора.Окончание = ДАТАВРЕМЯ(1, 1, 1)
		|			ИЛИ ДанныеДляПодбора.Окончание >= НАЧАЛОПЕРИОДА(&ДатаОкончания, ДЕНЬ))
		|   &УсловияФильтров            		
		|
		|СГРУППИРОВАТЬ ПО
		|	ДанныеДляПодбора.Сотрудник  
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ДанныеДляПодбора.Сотрудник 
		|;
		|
		|ВЫБРАТЬ 
		|	СрезДанных1.Сотрудник КАК Сотрудник, 		
		|	МАКСИМУМ(ДанныеДляПодбора.Начало) КАК Начало
		|ПОМЕСТИТЬ СрезДанных
		|ИЗ СрезДанных1 Как СрезДанных1      
		|   	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеДляПодбораСотрудников КАК ДанныеДляПодбора		
		|       ПО СрезДанных1.ПоДоговоруГПХ = ДанныеДляПодбора.ПоДоговоруГПХ 
		|           И СрезДанных1.Сотрудник = ДанныеДляПодбора.Сотрудник     
		|
		|СГРУППИРОВАТЬ ПО
		|	СрезДанных1.Сотрудник  
        |
		|ИНДЕКСИРОВАТЬ ПО
		|	СрезДанных1.Сотрудник 
		|;      		
		//|	ДанныеДляПодбора.Сотрудник КАК Сотрудник, 		
		//|   ДанныеДляПодбора.ПоДоговоруГПХ КАК ПоДоговоруГПХ,   
		//|	МАКСИМУМ(ДанныеДляПодбора.Начало) КАК Начало
		//|ПОМЕСТИТЬ СрезДанных
		//|ИЗ
		//|	РегистрСведений.ДанныеДляПодбораСотрудников КАК ДанныеДляПодбора
		//|ГДЕ
		//|	ДанныеДляПодбора.Организация В(&Организации)
		//|	И ДанныеДляПодбора.ВидСобытия <> ЗНАЧЕНИЕ(Перечисление.ВидыКадровыхСобытий.Увольнение)
		//|	И ДанныеДляПодбора.Начало <> ДАТАВРЕМЯ(1, 1, 1)
		//|	И ДанныеДляПодбора.Начало <= КОНЕЦПЕРИОДА(&ДатаНачала, ДЕНЬ)
		//|	И (ДанныеДляПодбора.Окончание = ДАТАВРЕМЯ(1, 1, 1)
		//|			ИЛИ ДанныеДляПодбора.Окончание >= НАЧАЛОПЕРИОДА(&ДатаОкончания, ДЕНЬ))
		//|   &УсловияФильтров            		
		//|
		//|СГРУППИРОВАТЬ ПО
		//|	ДанныеДляПодбора.Сотрудник,  
		//|	ДанныеДляПодбора.ПоДоговоруГПХ  
		//|
		//|ИНДЕКСИРОВАТЬ ПО
		//|	ДанныеДляПодбора.Сотрудник 
		//|;
		|
		|////////////////////////////////////////////////////////////////////////////////     
		|// Группа подзапросов для определения даты последнего кадрового события, изменяющего должность или подразделение
		|// Сначала делаем выборку текущих значение должностей/подразделений
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ     
		|	ДанныеДляПодбора.Сотрудник КАК Сотрудник,
		|	ДанныеДляПодбора.Подразделение КАК Подразделение,
		|	ДанныеДляПодбора.Должность КАК Должность 
		|ПОМЕСТИТЬ ВТДанныеПоСотрудникам
		|ИЗ
		|	СрезДанных КАК СрезДанных
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеДляПодбораСотрудников КАК ДанныеДляПодбора
		|		ПО СрезДанных.Сотрудник = ДанныеДляПодбора.Сотрудник
		|			И СрезДанных.Начало = ДанныеДляПодбора.Начало
		|;
		|////////////////////////////////////////////////////////////////////////////////
		|// Находим первое с конца кадровое событие, отличающееся от текущего состояния по должности или подразделению
		|ВЫБРАТЬ 
		|	ДанныеПоСотрудникам.Сотрудник КАК Сотрудник, 
		|	МАКСИМУМ(КадроваяИсторияСотрудников.Период) КАК Период
		|ПОМЕСТИТЬ ВТПредыдущиеДолжности 
		|ИЗ
		|	ВТДанныеПоСотрудникам КАК ДанныеПоСотрудникам	
    	|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КадроваяИсторияСотрудников КАК КадроваяИсторияСотрудников 
    	|	ПО КадроваяИсторияСотрудников.Сотрудник = ДанныеПоСотрудникам.Сотрудник  
    	//|	И (КадроваяИсторияСотрудников.Должность <> ДанныеПоСотрудникам.Должность 
    	//|	ИЛИ КадроваяИсторияСотрудников.Подразделение <> ДанныеПоСотрудникам.Подразделение)
		|   &УсловиеОпределенияДатыПоследнегоНазначения
		|ГДЕ
		|	КадроваяИсторияСотрудников.ДействуетДо = ДАТАВРЕМЯ(1, 1, 1)	     // Временные назначения игнорируем
		|СГРУППИРОВАТЬ ПО
		|	ДанныеПоСотрудникам.Сотрудник
		|;
		|////////////////////////////////////////////////////////////////////////////////
		|// Вот теперь получается временная таблица с нужными датами.
		|ВЫБРАТЬ 
		|	ПредыдущиеДолжности.Сотрудник КАК Сотрудник,
		|	МИНИМУМ(КадроваяИсторияСотрудников.Период) КАК Период
		|ПОМЕСТИТЬ ВТДатыИзменения
		|ИЗ 
		|	ВТПредыдущиеДолжности КАК ПредыдущиеДолжности 
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КадроваяИсторияСотрудников КАК КадроваяИсторияСотрудников 
    	|	ПО КадроваяИсторияСотрудников.Сотрудник = ПредыдущиеДолжности.Сотрудник      	
    	|	И КадроваяИсторияСотрудников.Период > ПредыдущиеДолжности.Период
		|СГРУППИРОВАТЬ ПО 
		|	ПредыдущиеДолжности.Сотрудник
		|;
		|////////////////////////////////////////////////////////////////////////////////
		|// Получаем период последнего документа, удостоверяющий личность.
		|ВЫБРАТЬ  
		|   ДанныеДляПодбора.Сотрудник КАК Сотрудник,
		|   МАКСИМУМ(Документы.Период) КАК Период
		|ПОМЕСТИТЬ ВТДокументыУЛ
		|ИЗ
		|   СрезДанных КАК СрезДанных   
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеДляПодбораСотрудников КАК ДанныеДляПодбора
		|		ПО СрезДанных.Сотрудник = ДанныеДляПодбора.Сотрудник
		|			И СрезДанных.Начало = ДанныеДляПодбора.Начало
		|       ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДокументыФизическихЛиц.СрезПоследних Как Документы
		|       ПО (Документы.Физлицо = ДанныеДляПодбора.ФизическоеЛицо И Документы.ЯвляетсяДокументомУдостоверяющимЛичность)
        |СГРУППИРОВАТЬ ПО
		|	ДанныеДляПодбора.Сотрудник
		|;                  
		|////////////////////////////////////////////////////////////////////////////////
		|// Определяем текущий вид занятости: 1С не меняет этот реквизит в 'ДанныеДляПодбора', если в кадровом документе только такое изменение.
		|ВЫБРАТЬ  
		|   ДанныеДляПодбора.Сотрудник КАК Сотрудник,
		|   МАКСИМУМ(ВидыЗанятости.Период) КАК Период
		|ПОМЕСТИТЬ ВТВидыЗанятости
		|ИЗ
		|   СрезДанных КАК СрезДанных   
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеДляПодбораСотрудников КАК ДанныеДляПодбора
		|		ПО СрезДанных.Сотрудник = ДанныеДляПодбора.Сотрудник
		|			И СрезДанных.Начало = ДанныеДляПодбора.Начало
		|       ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ВидыЗанятостиСотрудников.СрезПоследних Как ВидыЗанятости
		|       ПО (ВидыЗанятости.Сотрудник = ДанныеДляПодбора.Сотрудник)
        |СГРУППИРОВАТЬ ПО
		|	ДанныеДляПодбора.Сотрудник
		|;
		|////////////////////////////////////////////////////////////////////////////////   
		|// Формирование окончательного результата
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СправочникСотрудники.Ссылка КАК Ссылка,
		|	СправочникСотрудники.Код КАК Код,
		|	ДанныеДляПодбора.Наименование КАК НаименованиеСотрудника,  
		|   ДанныеДляПодбора.ФизическоеЛицо.Ссылка КАК ФизЛицоСсылка,
		|	СправочникСотрудники.ВАрхиве КАК ВАрхиве,
		|	ЕСТЬNULL(ТекущиеКадровыеДанныеСотрудников.ДатаПриема, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаПриема,
		|	ЕСТЬNULL(ТекущиеКадровыеДанныеСотрудников.ДатаУвольнения, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаУвольнения,
		|	ДанныеДляПодбора.Подразделение КАК Подразделение,  
		|	ДанныеДляПодбора.МестоВСтруктуреПредприятия КАК МестоВСтруктуре,
		|	ДанныеДляПодбора.Должность КАК Должность,
		|	ДанныеДляПодбора.Должность.Ссылка КАК ДолжностьКод,
		|	ВЫБОР
		|		КОГДА ДанныеДляПодбора.Филиал = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)
		|			ТОГДА ДанныеДляПодбора.Филиал
		|		ИНАЧЕ ДанныеДляПодбора.Организация
		|	КОНЕЦ КАК ОрганизацияСотрудника,
		|	СправочникСотрудники.ПометкаУдаления КАК ПометкаУдаления,
		|	ФИОФизическихЛицСрезПоследних.Фамилия КАК Фамилия,
		|	ФИОФизическихЛицСрезПоследних.Имя КАК Имя,
		|	ФИОФизическихЛицСрезПоследних.Отчество КАК Отчество,
		|	СправочникСотрудники.ФизическоеЛицо.ДатаРождения КАК ДатаРождения,
		|	ДанныеДляПодбора.ФизическоеЛицо.Пол КАК Пол,
		|	ДанныеДляПодбора.ФизическоеЛицо.СтраховойНомерПФР КАК СНИЛС,
		|	ДанныеДляПодбора.Начало КАК Начало,
		|	ДанныеДляПодбора.Окончание КАК Окончание,
		|	ВидыЗанятости.ВидЗанятости КАК ВидЗанятости,
		|	ДанныеДляПодбора.ПоДоговоруГПХ КАК ПоДоговоруГПХ,   
		|   Документы.ВидДокумента КАК ВидДокумента,
		|   Документы.Серия КАК Серия,
		|   Документы.Номер КАК Номер,
		|   Документы.ДатаВыдачи КАК ДатаВыдачи,
		|   Документы.КемВыдан КАК КемВыдан,
		|   Документы.КодПодразделения КАК КодПодразделения,
		|   Графики.ГрафикРаботы КАК ГрафикРаботы,  
		|   ЕСТЬNULL(ДистанционнаяРабота.РаботаетДистанционно, ЛОЖЬ) КАК РаботаетДистанционно,
		|	ФизическиеЛица.КонтактнаяИнформация.(
		|		Тип КАК Тип,
		|		Вид КАК Вид,
		|		Представление КАК Представление,
		|		ЗначенияПолей КАК ЗначенияПолей
		|	) КАК КонтактнаяИнформация,
		|	СправочникСотрудники.ДополнительныеРеквизиты.(
		|		Свойство КАК Свойство,
		|		Свойство.Имя КАК Имя,
		|		Значение КАК Значение
		|	) КАК ДополнительныеРеквизиты,    
		//|СклоненияПредставленийОбъектов.ХешПредставления КАК Хеш,
		//|	СклоненияПредставленийОбъектов.ИменительныйПадеж КАК Именительный,
		//|	СклоненияПредставленийОбъектов.РодительныйПадеж КАК Родительный,
		//|	СклоненияПредставленийОбъектов.ДательныйПадеж КАК Дательный,
		//|	СклоненияПредставленийОбъектов.ВинительныйПадеж КАК Винительный,
		//|	СклоненияПредставленийОбъектов.ТворительныйПадеж КАК Творительный,
		//|	СклоненияПредставленийОбъектов.ПредложныйПадеж КАК Предложный,
		|	ЕСТЬNULL(ДопСведВерсияДанных.Значение, """") КАК ВерсияДанныхСотрудника,
		|   ДатыИзменения.Период КАК ДатаИзмененияДП
		|ИЗ
		|	СрезДанных КАК СрезДанных
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеДляПодбораСотрудников КАК ДанныеДляПодбора
		|		ПО СрезДанных.Сотрудник = ДанныеДляПодбора.Сотрудник
		|			И СрезДанных.Начало = ДанныеДляПодбора.Начало
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК СправочникСотрудники
		|		ПО (ДанныеДляПодбора.Сотрудник = СправочникСотрудники.Ссылка)
		|			И (ДанныеДляПодбора.Наименование = СправочникСотрудники.Наименование)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ТекущиеКадровыеДанныеСотрудников КАК ТекущиеКадровыеДанныеСотрудников
		|		ПО (ДанныеДляПодбора.Сотрудник = ТекущиеКадровыеДанныеСотрудников.Сотрудник)
		|			И (ДанныеДляПодбора.ФизическоеЛицо = ТекущиеКадровыеДанныеСотрудников.ФизическоеЛицо)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФИОФизическихЛиц.СрезПоследних КАК ФИОФизическихЛицСрезПоследних
		|		ПО (ДанныеДляПодбора.ФизическоеЛицо = ФИОФизическихЛицСрезПоследних.ФизическоеЛицо)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизическиеЛица
		|		ПО (ДанныеДляПодбора.ФизическоеЛицо = ФизическиеЛица.Ссылка)		
		|       ЛЕВОЕ СОЕДИНЕНИЕ ВТДокументыУЛ КАК ВТДокументыУЛ
		|       ПО СрезДанных.Сотрудник = ВТДокументыУЛ.Сотрудник 
		|       ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДокументыФизическихЛиц.СрезПоследних Как Документы
		|       ПО (Документы.Физлицо = ДанныеДляПодбора.ФизическоеЛицо И Документы.ЯвляетсяДокументомУдостоверяющимЛичность 
		|		И Документы.Период = ВТДокументыУЛ.Период)		
		|       ЛЕВОЕ СОЕДИНЕНИЕ ВТВидыЗанятости КАК ВТВидыЗанятости
		|       ПО СрезДанных.Сотрудник = ВТВидыЗанятости.Сотрудник 
		|       ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ВидыЗанятостиСотрудников.СрезПоследних Как ВидыЗанятости
		|       ПО (ВидыЗанятости.Сотрудник = ДанныеДляПодбора.Сотрудник 
		|		И ВидыЗанятости.Период = ВТВидыЗанятости.Период)		
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДопСведВерсияДанных
		|		ПО (ДопСведВерсияДанных.Свойство = &СвойствоХэш)
		|			И (ДопСведВерсияДанных.Объект = ДанныеДляПодбора.Сотрудник)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДатыИзменения КАК ДатыИзменения
		|		ПО СрезДанных.Сотрудник = ДатыИзменения.Сотрудник
		|       ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГрафикРаботыСотрудников.СрезПоследних Как Графики
		|       ПО (СрезДанных.Сотрудник = Графики.Сотрудник)   
		|       ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДистанционнаяРаботаСотрудников.СрезПоследних Как ДистанционнаяРабота
		|       ПО (СрезДанных.Сотрудник = ДистанционнаяРабота.Сотрудник)";

     // Тут надо добавить условия по сотрудникам, видам занятости, подразделениям и должностям, если они есть.   
	 мТекст = "";
	 Если мПарам.ФильтрСотрудники[0] <> "0" Тогда          
		 мЗапрос.УстановитьПараметр("Сотрудники",мПарам.ФильтрСотрудники[1]);	
		 Если мПарам.ФильтрСотрудники[0] = "1" Тогда  // Учитываем, выгружаем.
			 мТекст = "   И ДанныеДляПодбора.Сотрудник В (&Сотрудники)";
	     Иначе
		     мТекст = "   И НЕ (ДанныеДляПодбора.Сотрудник В (&Сотрудники))";
		 КонецЕсли;	                                                       		   
	 КонецЕсли;	       
	 Если мПарам.ФильтрДолжности[0] <> "0" Тогда          
		 мЗапрос.УстановитьПараметр("Должности",мПарам.ФильтрДолжности[1]);	
		 Если НЕ ПустаяСтрока(мТекст) Тогда
			 мТекст = мТекст + Символы.ПС; 
		 КонецЕсли;	 
		 Если мПарам.ФильтрДолжности[0] = "1" Тогда  // Учитываем, выгружаем.
			 мТекст = мТекст + "    И ДанныеДляПодбора.Должность В (&Должности)";
	     Иначе
		     мТекст = мТекст + "    И НЕ (ДанныеДляПодбора.Должность В (&Должности))";
		 КонецЕсли;			   
	 КонецЕсли;                                         
	 Если мПарам.ФильтрВидыЗанятости[2] = "2" Тогда   // Это про ГПХ. Тут "выгружать ГПХ" не означает, что всех остальных выгружать не надо
		 Если НЕ ПустаяСтрока(мТекст) Тогда    // Поэтому интересует только факт невыгрузки 
			 мТекст = мТекст + Символы.ПС; 
		 КонецЕсли;	 
		 мТекст = мТекст + "    И НЕ ДанныеДляПодбора.ПоДоговоруГПХ"
	 КонецЕсли;	 
	 Если мПарам.ФильтрВидыЗанятости[0] <> "0" Тогда          
		 мЗапрос.УстановитьПараметр("ВидыЗанятости",мПарам.ФильтрВидыЗанятости[1]);	
		 Если НЕ ПустаяСтрока(мТекст) Тогда
			 мТекст = мТекст + Символы.ПС; 
		 КонецЕсли;	 
		 Если мПарам.ФильтрВидыЗанятости[0] = "1" Тогда  // Учитываем, выгружаем.
			Если мПарам.ФильтрВидыЗанятости[2] <> "2" Тогда
			 	мТекст = мТекст + "    И (ДанныеДляПодбора.ВидЗанятости В (&ВидыЗанятости) ИЛИ ДанныеДляПодбора.ПоДоговоруГПХ)";
			Иначе	
				мТекст = мТекст + "    И ДанныеДляПодбора.ВидЗанятости В (&ВидыЗанятости)";
			КонецЕсли;	
	     Иначе
		     мТекст = мТекст + "    И НЕ (ДанныеДляПодбора.ВидЗанятости В (&ВидыЗанятости))";
		 КонецЕсли;			   
	 КонецЕсли;   
	 Если мПарам.ФильтрПодразделения[0] <> "0" Тогда          
		 мЗапрос.УстановитьПараметр("Подразделения",мПарам.ФильтрПодразделения[1]);	
		 Если НЕ ПустаяСтрока(мТекст) Тогда
			 мТекст = мТекст + Символы.ПС; 
		 КонецЕсли;	 
		 Если мПарам.ФильтрПодразделения[0] = "1" Тогда  // Учитываем, выгружаем.
			 мТекст = мТекст + "    И ДанныеДляПодбора.Подразделение В Иерархии(&Подразделения)";
	     Иначе
		     мТекст = мТекст + "    И НЕ (ДанныеДляПодбора.Подразделение В Иерархии(&Подразделения))";
		 КонецЕсли;			   
	 КонецЕсли;     
	 Если мПарам.ФильтрСтруктуры[0] <> "0" Тогда          
		 мЗапрос.УстановитьПараметр("МестаВСтруктуре",мПарам.ФильтрСтруктуры[1]);	
		 Если НЕ ПустаяСтрока(мТекст) Тогда
			 мТекст = мТекст + Символы.ПС; 
		 КонецЕсли;	 
		 Если мПарам.ФильтрСтруктуры[0] = "1" Тогда  // Учитываем, выгружаем.
			 мТекст = мТекст + "    И ДанныеДляПодбора.МестоВСтруктуреПредприятия В Иерархии(&МестаВСтруктуре)";
	     Иначе
		     мТекст = мТекст + "    И НЕ (ДанныеДляПодбора.МестоВСтруктуреПредприятия В Иерархии(&МестаВСтруктуре))";
		 КонецЕсли;			   
	 КонецЕсли;

	мЗапрос.Текст = СтрЗаменить(мЗапрос.Текст, "&УсловияФильтров",мТекст);   
	
	// Изменение в определении даты последнего назначения (изменения должности или подразделения): теперь нужно смотреть настройку
	// выгрузки должности и подразделения: если выгружаются оба реквизита, то оба и проверяем. Иначе - только тот, что выгружается.
	// Подразделение - мНВИ[3], Должность - мНВИ[4]
	мТекст = "И (КадроваяИсторияСотрудников.Должность <> ДанныеПоСотрудникам.Должность ИЛИ КадроваяИсторияСотрудников.Подразделение <> ДанныеПоСотрудникам.Подразделение)";   	
	Если мПарам.мВыгружатьПодразделения И мПарам.мНВИ[4] = "0" Тогда		
		мТекст = "И КадроваяИсторияСотрудников.Подразделение <> ДанныеПоСотрудникам.Подразделение";
	ИначеЕсли (Не мПарам.ВыгружатьПодразделения) И мПарам.мНВИ[4] = "1" Тогда			
		мТекст = "И КадроваяИсторияСотрудников.Должность <> ДанныеПоСотрудникам.Должность";
	КонецЕсли;	
	мЗапрос.Текст = СтрЗаменить(мЗапрос.Текст, "&УсловиеОпределенияДатыПоследнегоНазначения",мТекст);
	 	
	РезультатЗапроса = мЗапрос.ВыполнитьПакет();
	Выборка = РезультатЗапроса[7].Выгрузить();
	Возврат Выборка;
КонецФункции

                     
Функция ПолучитьГрафики(СвойствоХэшГраф) Экспорт    
	мДатаСреза = ТекущаяДата();
	мЗапрос = Новый Запрос;
	мЗапрос.УстановитьПараметр("ДатаСреза",мДатаСреза);
	мЗапрос.УстановитьПараметр("СвойствоХэш",СвойствоХэшГраф);
	мЗапрос.Текст = 
	"ВЫБРАТЬ
	|	Графики.Ссылка КАК Ссылка,
	|   ЕСТЬNULL(Графики.НеполноеРабочееВремя, ЛОЖЬ) КАК НРВ,
	|   ЕСТЬNULL(Графики.СокращеннаяРабочаяНеделя, ЛОЖЬ) КАК НРН,
	|   ЕСТЬNULL(Графики.НеполныйРабочийДень, ЛОЖЬ) КАК НРД,	
	|	ЕСТЬNULL(ДопСведВерсияДанных.Значение, """") КАК ВерсияДанныхГрафиков
	|ИЗ 
	|	Справочник.ГрафикиРаботыСотрудников КАК Графики
	|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДопСведВерсияДанных
	|	ПО (ДопСведВерсияДанных.Свойство = &СвойствоХэш)
	|		И (ДопСведВерсияДанных.Объект = Графики.Ссылка) 
	|ГДЕ
	|	НЕ Графики.ПометкаУдаления";
	
		
	РезультатЗапроса = мЗапрос.ВыполнитьПакет();
	Выборка = РезультатЗапроса[0].Выбрать();
			
	Возврат Выборка;
КонецФункции   

Функция СписокСотрудниковКП(мПарам)         
	// мПарам: СписокОрганизаций,ФильтрВидыЗанятости,ФильтрПодразделения,ФильтрДолжности,ФильтрСотрудники,ФильтрСтруктуры,СвойствоХэш,мНВИ,мВыгружатьПодразделения,мВыгружатьСтруктуру. 
	// Запрос с кастомными полями.
	// Тут нужно еще выбирать плановые начисления
	УстановитьПривилегированныйРежим(Истина);    
	мДокумент1 = Константы.МК_ДокументФЛ1.Получить();
	мДокумент2 = Константы.МК_ДокументФЛ2.Получить();
	мДокумент3 = Константы.МК_ДокументФЛ3.Получить();
	
	мЗапрос = Новый Запрос;
	мЗапрос.УстановитьПараметр("Организации", мПарам.СписокОрганизаций);
	мЗапрос.УстановитьПараметр("Документ1", мДокумент1);
	мЗапрос.УстановитьПараметр("Документ2", мДокумент2);
	мЗапрос.УстановитьПараметр("Документ3", мДокумент3);
	мЗапрос.УстановитьПараметр("СвойствоХэш", мПарам.СвойствоХэшСотр);    
	мЗапрос.УстановитьПараметр("ДатаНачала", ДобавитьМесяц(НачалоДня(ТекущаяДата()), 1));         // Для поступления нужна текущая дата плюс месяц	
	мЗапрос.УстановитьПараметр("ДатаОкончания",  ДобавитьМесяц(НачалоДня(ТекущаяДата()), -1)); 	  // А для увольнения - месяцем раньше. То есть если сотрудник уволен, он будет попадать
	              	                                                                              // в выборку целый месяц.                                                             
	мЗапрос.Текст =   
	"ВЫБРАТЬ     
	    |	ДанныеДляПодбора.Сотрудник КАК Сотрудник, 
		|   МИНИМУМ(ДанныеДляПодбора.ПоДоговоруГПХ)	КАК ПоДоговоруГПХ		
		|ПОМЕСТИТЬ СрезДанных1
		|ИЗ
		|	РегистрСведений.ДанныеДляПодбораСотрудников КАК ДанныеДляПодбора
		|ГДЕ
		|	ДанныеДляПодбора.Организация В(&Организации)

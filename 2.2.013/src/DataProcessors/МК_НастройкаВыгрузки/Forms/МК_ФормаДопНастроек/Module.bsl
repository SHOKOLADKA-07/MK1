

&НаСервере
Процедура ОКНаСервере(мПарам)
	Константы.МК_МаксКолвоСотрВВыгрузке.Установить(ЭтаФорма.МаксКолвоСотр);   
	//Если ЭтаФорма.НеРаботаемСКЭДО Тогда    	
	//	Константы.МК_РаботаемСКЭДО.Установить(Ложь);	
	//	Константы.МК_НеРаботаемСКЭДО.Установить(Истина);
	//Иначе                                               
	//	Константы.МК_РаботаемСКЭДО.Установить(ЭтаФорма.РаботаемСКЭДО);	
	//	Константы.МК_НеРаботаемСКЭДО.Установить(Ложь);		
	//КонецЕсли;	                                        
	Константы.МК_РаботаемСКЭДО.Установить(ЭтаФорма.РаботаемСКЭДО);
	Константы.МК_НеРаботаемСКЭДО.Установить(ЭтаФорма.НеРаботаемСКЭДО);
	Константы.МК_ОтключитьКЭДО.Установить(ЭтаФорма.ОтключитьКЭДО);
	Константы.МК_ВыгружатьГПХ.Установить(ЭтаФорма.ВыгружатьГПХ);
	Константы.МК_ПрименятьПользовательскиеПоля.Установить(ЭтаФорма.ПрименятьПользовательскиеПоля);
	Константы.МК_ВыгружатьПлановыеНачисления.Установить(ЭтаФорма.ВыгружатьПлановыеНачисления); 
	Константы.МК_ИспользоватьРуководителейПодразделений.Установить(ЭтаФорма.ИспользуютсяРуководителиПодразделений);   
	Константы.МК_ВыгружатьОргСтруктуру.Установить(мПарам.ВыгружатьОргСтруктуру);
КонецПроцедуры

&НаКлиенте
Процедура ОК(Команда)
	мПарам = Новый Структура("ВыгружатьОргСтруктуру");
	Если ЭтаФорма.ВыгрузкаПодразделений = 0 Тогда
		мОргСтр = Ложь;
	Иначе	           
		мОргСтр = Истина;
	КонецЕсли;
	мПарам.ВыгружатьОргСтруктуру = мОргСтр;
	ОКНаСервере(мПарам);  
	ЭтаФорма.Закрыть(мПарам);
	ОбновитьИнтерфейс();
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ЭтаФорма.МаксКолвоСотр = Константы.МК_МаксКолвоСотрВВыгрузке.Получить(); 
	Если ЭтаФорма.МаксКолвоСотр = 0 Тогда
		ЭтаФорма.МаксКолвоСотр = 1000;
	КонецЕсли;	
	ЭтаФорма.РаботаемСКЭДО = Константы.МК_РаботаемСКЭДО.Получить();
	ЭтаФорма.НеРаботаемСКЭДО = Константы.МК_НеРаботаемСКЭДО.Получить();
	ЭтаФорма.ОтключитьКЭДО = Константы.МК_ОтключитьКЭДО.Получить();
	ЭтаФорма.ВыгружатьГПХ = Константы.МК_ВыгружатьГПХ.Получить();   
	ЭтаФорма.ПрименятьПользовательскиеПоля = Константы.МК_ПрименятьПользовательскиеПоля.Получить();
	ЭтаФорма.ВыгружатьПлановыеНачисления = Константы.МК_ВыгружатьПлановыеНачисления.Получить();
	ЭтаФорма.ИспользуютсяРуководителиПодразделений = Константы.МК_ИспользоватьРуководителейПодразделений.Получить();   
	мОргСтр = Константы.МК_ВыгружатьОргСтруктуру.Получить();
	Если мОргСтр Тогда
		ЭтаФорма.ВыгрузкаПодразделений = 1;
	Иначе	                               
		ЭтаФорма.ВыгрузкаПодразделений = 0;
	КонецЕсли;		
КонецПроцедуры   


	


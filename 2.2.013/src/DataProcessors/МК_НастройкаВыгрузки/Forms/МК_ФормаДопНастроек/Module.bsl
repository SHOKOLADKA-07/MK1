&НаСервере
Процедура ПодготовкаКУдалениюРасширенияНаСервере()    
	
	НабЗап = РегистрыСведений.ФайлыВРабочемКаталоге.СоздатьНаборЗаписей(); 	
	НабЗап.Записать();

	мВыборка = Справочники.МК_ДокументыКЭДОПрисоединенныеФайлы.Выбрать();        
    Пока мВыборка.Следующий() Цикл
        мОбъект = мВыборка.ПолучитьОбъект();     
		мОбъект.УстановитьПометкуУдаления(Истина, Истина);
        //мОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);        
    КонецЦикла; 	
КонецПроцедуры


&НаКлиенте
Процедура ПодготовкаКУдалениюРасширения(Команда)
	 Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса",
      ЭтотОбъект);	
 
    ПоказатьВопрос(Оповещение,
        "После выполнения этого действия данные восстановить не удастся. Вы действительно хотите выполнить подготовку к удалению расширения?",
        РежимДиалогаВопрос.ДаНетОтмена,
        0, // таймаут в секундах
        КодВозвратаДиалога.Нет,"Подготовка к удалению расширения"); 
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияВопроса(Результат, Параметры) Экспорт
 
    Если Результат = КодВозвратаДиалога.Да Тогда
        ПодготовкаКУдалениюРасширенияНаСервере();  
		ПоказатьПредупреждение(, "Помечены на удаление присоединенные файлы КЭДО МояКоманда. Теперь нужно выполнить удаление помеченных объектов и отключить расширение, перезапустить программу и затем удалить расширение.");   
    КонецЕсли;	
 
КонецПроцедуры

&НаКлиенте
Процедура ОтключитьКЭДОПриИзменении(Элемент)
	Если ЭтаФорма.ОтключитьКЭДО Тогда 
		ЭтаФорма.РаботаемСКЭДО = Ложь;
		ЭтаФорма.НеРаботаемСКЭДО = Ложь;
	Иначе
		ЭтаФорма.НеРаботаемСКЭДО = Истина;
		ЭтаФорма.РаботаемСКЭДО = Ложь;
	КонецЕсли;		
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьРегистрДокументыКЭДО(Команда)
	ЗаполнитьРегистрДокументыКЭДОНаСервере();
КонецПроцедуры


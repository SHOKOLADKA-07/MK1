&НаКлиенте
Процедура НастройкаВыгружаемойИнформацииПередНачаломИзменения(Элемент, Отказ)  
	Отказ = Истина;
	Если Элемент.ТекущиеДанные.ОбязательноВыгружать Тогда
		Элемент.ТекущиеДанные.Выгружать = Истина;   
		Сообщить("Этот реквизит выгружается обязательно");
	Иначе	
		Если Элемент.ТекущиеДанные.Выгружать = Истина Тогда
			Элемент.ТекущиеДанные.Выгружать = Ложь;
			мЭл = "0";
		Иначе
			Элемент.ТекущиеДанные.Выгружать = Истина;
			мЭл = "1";
		КонецЕсли;	   
		//СохранитьНВИ2();			
	КонецЕсли;
КонецПроцедуры


&НаКлиенте
Процедура ФильтрыВыгрузкиСотрудниковЗначенияНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)  
	СтандартнаяОбработка = Ложь;  
	ВыбраннаяСтрока = Элемент.Родитель.ТекущаяСтрока; 
	Если ВыбраннаяСтрока = 0 Тогда 		 
		СписокОрганизацийОткрытие(Элемент, СтандартнаяОбработка);
	ИначеЕсли ВыбраннаяСтрока = 1 Тогда	                         
		СписокВидовЗанятостиОткрытие(Элемент, СтандартнаяОбработка);
	ИначеЕсли ВыбраннаяСтрока = 2 Тогда
		//СтандартнаяОбработка = Ложь; 
		мСписВыб = ЭтаФорма.СписокПодразделений;     
		Если мСписВыб.Количество() = 0 Тогда     // Если еще ничего не выбрано, сразу открываем полный справочник.
			СписокПодразделенийОткрытие(Элемент, СтандартнаяОбработка);   
		Иначе	                                 // Если уже что-то есть, открываем краткую форму выбора. Только в ней можно отменить выбор.
			СписокПодразделенийКраткийОткрытие(Элемент, СтандартнаяОбработка);			
		КонецЕсли;	  
	ИначеЕсли ВыбраннаяСтрока = 3 Тогда
		//СтандартнаяОбработка = Ложь; 
		мСписВыб = ЭтаФорма.СписокПодразделенийСтруктура;     
		Если мСписВыб.Количество() = 0 Тогда     // Если еще ничего не выбрано, сразу открываем полный справочник.
			СписокПодразделенийСтруктураОткрытие(Элемент, СтандартнаяОбработка);   
		Иначе	                                 // Если уже что-то есть, открываем краткую форму выбора. Только в ней можно отменить выбор.
			СписокПодразделенийСтруктураКраткийОткрытие(Элемент, СтандартнаяОбработка);			
		КонецЕсли;		
	ИначеЕсли ВыбраннаяСтрока = 4 Тогда                          
		СписокДолжностейОткрытие(Элемент, СтандартнаяОбработка);		
	ИначеЕсли ВыбраннаяСтрока = 5 Тогда
		СписокСотрудниковОткрытие(Элемент, СтандартнаяОбработка);
	КонецЕсли;	
КонецПроцедуры



	мСписВыб = ЭтаФорма.СписокПодразделений;
	мПараметры = Новый Структура("МножественныйВыбор", Истина);     
	мПараметры.Вставить("ЗакрыватьПослеВыбора", Ложь);  
	мПараметры.Вставить("СписокВыбранных",мСписВыб);     	    
	ДопПараметры = Неопределено;
	Оповещение = Новый ОписаниеОповещения("ВыполнитьПослеОкончания4", ЭтотОбъект,ДопПараметры);   	
	ОткрытьФорму("Обработка.МК_НастройкаВыгрузки.Форма.МК_ФормаВыбораПодразделений",мПараметры,ЭтаФорма,,,,Оповещение,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьПослеОкончания4(Результат, ДопПараметры) Экспорт     
	// Результат - это параметр, передаваемый в команде Закрыть при закрытии формы, вызванной в верхней процедуре.
	Если Результат <> Неопределено Тогда  
		// Тут результат - это массив, где первый элемент - список выбранных значений, а второй:
		// 1 - была нажата кнопка ОК, 2 - Показать все
		ЭтаФорма.СписокПодразделений = Результат[0];          
		ЭтаФорма.ТекущийЭлемент.ТекущиеДанные.Значения = Результат[0];    
		Если Результат[1] = 2 Тогда    
			Элемент = Неопределено;
			СтандартнаяОбработка = Истина;
			СписокПодразделенийОткрытие(Элемент, СтандартнаяОбработка);
		КонецЕсли;	
  	КонецЕсли; 
КонецПроцедуры     


&НаКлиенте
Процедура СписокПодразделенийСтруктураОткрытие(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;   
	мСписВыб = ЭтаФорма.СписокПодразделенийСтруктура.ВыгрузитьЗначения();  
	// В форму выбора подразделений список выбранных значений передается через временное хранилище.
	// То есть надо сохранить массив во временное хранилище, а в форму передать адрес.
	АдресВХранилище = ПоместитьВоВременноеХранилище(мСписВыб);
	мПараметры = Новый Структура("МножественныйВыбор", Истина);  
	мПараметры.Вставить("РежимВыбора", Истина);
	мПараметры.Вставить("ЗакрыватьПослеВыбора", Ложь);  
	мПараметры.Вставить("АдресСпискаПодобранных",АдресВХранилище); 
	мПараметры.Вставить("ВыборГруппИЭлементов", ИспользованиеГруппИЭлементов.ГруппыИЭлементы);   

	ДопПараметры = Неопределено;
	Оповещение = Новый ОписаниеОповещения("ВыполнитьПослеОкончания6", ЭтотОбъект,ДопПараметры);  	
	ОткрытьФорму("Справочник.СтруктураПредприятия.ФормаВыбора", мПараметры,ЭтаФорма,,,,Оповещение,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца );
КонецПроцедуры


&НаКлиенте
Процедура ВыполнитьПослеОкончания6(Результат, ДопПараметры) Экспорт     
	// Результат - это параметр, передаваемый в команде Закрыть при закрытии формы, вызванной в верхней процедуре.
	Если Результат <> Неопределено Тогда  
		мСписокЗначений = Новый СписокЗначений;
		мСписокЗначений.ЗагрузитьЗначения(Результат); 
		// Из стандартной формы выбора возвращаются только значения, выбранные в текущем сеансе.
		// Их надо объединить с теми, что были выбраны ранее.
		Для Каждого Элемент Из мСписокЗначений Цикл
			Если ЭтаФорма.СписокПодразделенийСтруктура.НайтиПоЗначению(Элемент) = Неопределено Тогда
				ЭтаФорма.СписокПодразделенийСтруктура.Добавить(Элемент.Значение, Элемент.Представление);
			КонецЕсли;	
		КонецЦикла;	     	         
		ЭтаФорма.ТекущийЭлемент.ТекущиеДанные.Значения = ЭтаФорма.СписокПодразделенийСтруктура;
  	КонецЕсли; 
КонецПроцедуры     

&НаКлиенте
Процедура СписокПодразделенийСтруктураКраткийОткрытие(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;   
	мСписВыб = ЭтаФорма.СписокПодразделенийСтруктура;
	мПараметры = Новый Структура("МножественныйВыбор", Истина);     
	мПараметры.Вставить("ЗакрыватьПослеВыбора", Ложь);  
	мПараметры.Вставить("СписокВыбранных",мСписВыб);     	    
	ДопПараметры = Неопределено;
	Оповещение = Новый ОписаниеОповещения("ВыполнитьПослеОкончания7", ЭтотОбъект,ДопПараметры);   	
	ОткрытьФорму("Обработка.МК_НастройкаВыгрузки.Форма.МК_ФормаВыбораСтруктуры",мПараметры,ЭтаФорма,,,,Оповещение,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьПослеОкончания7(Результат, ДопПараметры) Экспорт     
	// Результат - это параметр, передаваемый в команде Закрыть при закрытии формы, вызванной в верхней процедуре.
	Если Результат <> Неопределено Тогда  
		// Тут результат - это массив, где первый элемент - список выбранных значений, а второй:
		// 1 - была нажата кнопка ОК, 2 - Показать все
		ЭтаФорма.СписокПодразделенийСтруктура = Результат[0];          
		ЭтаФорма.ТекущийЭлемент.ТекущиеДанные.Значения = Результат[0];    
		Если Результат[1] = 2 Тогда    
			Элемент = Неопределено;
			СтандартнаяОбработка = Истина;
			СписокПодразделенийСтруктураОткрытие(Элемент, СтандартнаяОбработка);
		КонецЕсли;	
  	КонецЕсли; 
КонецПроцедуры     

&НаКлиенте
Процедура СписокВидовЗанятостиОткрытие(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;   
	мСписВыб = ЭтаФорма.СписокВидовЗанятости;
	мПараметры = Новый Структура("МножественныйВыбор", Истина);     
	мПараметры.Вставить("ЗакрыватьПослеВыбора", Ложь);  
	мПараметры.Вставить("СписокВыбранных",мСписВыб);     
	ДопПараметры = Неопределено;
	Оповещение = Новый ОписаниеОповещения("ВыполнитьПослеОкончания5", ЭтотОбъект,ДопПараметры);   	
	ОткрытьФорму("Обработка.МК_НастройкаВыгрузки.Форма.МК_ФормаВыбораВидовЗанятости",мПараметры,ЭтаФорма,,,,Оповещение,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьПослеОкончания5(Результат, ДопПараметры) Экспорт     
	// Результат - это параметр, передаваемый в команде Закрыть при закрытии формы, вызванной в верхней процедуре.
	Если Результат <> Неопределено Тогда 
		ЭтаФорма.СписокВидовЗанятости = Результат;
		ЭтаФорма.ТекущийЭлемент.ТекущиеДанные.Значения = Результат;
  	КонецЕсли; 
КонецПроцедуры 


&НаКлиенте
Процедура ОК(Команда)    // Сохранение всех настроек в константы.   
	// Наверное тут надо выполнить проверку заполненности выгружаемых реквизитом, если есть галочка "Применять"
	мРез = ПроверкаФильтровВыгрузкиСотрудников();
	Если мРез Тогда
		СохранитьКонстанты();
		ЭтаФорма.Закрыть();
	Иначе
		ПоказатьПредупреждение(,"Нельзя оставлять пустой список объектов в фильтре списка выгрузки сотрудников при включенной галочке ""Применять"" ");
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Функция ПроверкаФильтровВыгрузкиСотрудников()  
	мРез = Истина;
	мТаб = ЭтаФорма.ФильтрыВыгрузкиСотрудников;
	Для Каждого мСтр Из мТаб Цикл
		Если мСтр.Применять Тогда 		 
			Если мСтр.Значения.Количество() = 0 Тогда
				мРез = Ложь;
				Прервать;
			КонецЕсли;	
		КонецЕсли;	
	КонецЦикла;	
	Возврат мРез;
КонецФункции



&НаКлиенте
Процедура Отмена(Команда)  // Ничего не сохраняем.   
	ЭтаФорма.Закрыть();
КонецПроцедуры


&НаКлиенте
Процедура Допнастройки(Команда)                                     
	ДопПараметры = Неопределено;
	Оповещение = Новый ОписаниеОповещения("ВыполнитьПослеОкончанияДН", ЭтотОбъект,ДопПараметры);
	ОткрытьФорму("Обработка.МК_НастройкаВыгрузки.Форма.МК_ФормаДопНастроек",,ЭтаФорма,,,,Оповещение,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);  	
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьПослеОкончанияДН(мРез, ДопПараметры) Экспорт     
	// Тут надо проверить значение константы МК_ВыгружатьОргСтруктуру и возможно перерисовать некоторые строки в таблицах.  
	Если Не мРез = Неопределено Тогда
		Если Не (мРез.ВыгружатьОргСтруктуру = ЭтаФорма.ВыгружатьОргСтруктуру) Тогда    			
			ЭтаФорма.ВыгружатьОргСтруктуру = мРез.ВыгружатьОргСтруктуру;    
			
			// 1 - Выгружаемая информация
			// Искать нужные строки будем перебором
			мТаб = ЭтаФорма.НастройкаВыгружаемойИнформации;	
			Для Каждого мСтр Из мТаб Цикл
				Если мСтр.Реквизит = "Подразделение" Тогда
					Если мРез.ВыгружатьОргСтруктуру Тогда				
						мСтр.НеПоказывать = Истина;
					Иначе	                       
						мСтр.НеПоказывать = Ложь;
					КонецЕсли;	
				КонецЕсли;	
			
				Если мСтр.Реквизит = "Подразделение (структура предприятия)" Тогда
					Если мРез.ВыгружатьОргСтруктуру Тогда				
						мСтр.НеПоказывать = Ложь;
					Иначе	    	                   
						мСтр.НеПоказывать = Истина;
					КонецЕсли;	                						
					Прервать;
				КонецЕсли;	
			КонецЦикла;   
			
			// 2 - Фильтры списка выгрузки
			мТаб = ЭтаФорма.ФильтрыВыгрузкиСотрудников;   
			Для Каждого мСтр Из мТаб Цикл
				Если мСтр.ОбъектФильтра = "Подразделения" Тогда
					Если мРез.ВыгружатьОргСтруктуру Тогда				
						мСтр.НеПоказывать = Истина;
					Иначе	                       
						мСтр.НеПоказывать = Ложь;
					КонецЕсли;	
				КонецЕсли;	
			
				Если мСтр.ОбъектФильтра = "Подразделения (структура предприятия)" Тогда
					Если мРез.ВыгружатьОргСтруктуру Тогда				
						мСтр.НеПоказывать = Ложь;
					Иначе	    	                   
						мСтр.НеПоказывать = Истина;
					КонецЕсли;	                						
					Прервать;
				КонецЕсли;	
			КонецЦикла;   
	
			// 3 - переопределяемые реквизиты
			мТаб = ЭтаФорма.ПереопределяемыеРеквизиты;
			мСтр = мТаб.Получить(3);  
			Если мРез.ВыгружатьОргСтруктуру Тогда
				мСтр.ВидМояКоманда = "Руководитель подразделения (структура предприятия)";
			Иначе	
				мСтр.ВидМояКоманда = "Руководитель подразделения";
			КонецЕсли;			
			
			Элементы.НастройкаВыгружаемойИнформации.Обновить();
			Элементы.ФильтрыВыгрузкиСотрудников.Обновить();
			Элементы.ПереопределяемыеРеквизиты.Обновить();
		КонецЕсли;	
	КонецЕсли;	
КонецПроцедуры    


&НаКлиенте
Процедура ФильтрыВыгрузкиСотрудниковЗначенияОткрытиеМножественногоЗначения(Элемент, Идентификатор, СтандартнаяОбработка)  
	СтандартнаяОбработка = Ложь;
КонецПроцедуры          

&НаКлиенте
Процедура ФильтрыВыгрузкиСотрудниковЗначенияПриИзменении(Элемент)    
	мСтрока = Элемент.Родитель.ТекущаяСтрока;
	мСпис = Элемент.Родитель.ТекущиеДанные.Значения;  
	Если мСтрока = 0 Тогда 		 
		ЭтаФорма.СписокОрганизаций = мСпис;				
	ИначеЕсли мСтрока = 1 Тогда	                         
		ЭтаФорма.СписокВидовЗанятости = мСпис;		
	ИначеЕсли мСтрока = 2 Тогда		
		ЭтаФорма.СписокПодразделений = мСпис;     
	ИначеЕсли мСтрока = 3 Тогда          
		ЭтаФорма.СписокДолжностей = мСпис;		
	ИначеЕсли мСтрока = 4 Тогда
		ЭтаФорма.СписокСотрудников = мСпис;
	КонецЕсли;                                
КонецПроцедуры


&НаКлиенте
Процедура ПереопределяемыеРеквизитыВид1СОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, СтандартнаяОбработка)
	Если ВыбранноеЗначение = ПредопределенноеЗначение("Перечисление.МК_СтандартныйРуководительПодразделения.СтРеквФЛ") Тогда 
		 Если Не ПроверкаСтандартногоРуководителя(1) Тогда
			Сообщить("Стандартный реквизит физическое лицо не поддерживается в текущей конфигурации.");
		КонецЕсли;                                        
	ИначеЕсли ВыбранноеЗначение = ПредопределенноеЗначение("Перечисление.МК_СтандартныйРуководительПодразделения.СтРеквПозШР") Тогда
		Если Не ПроверкаСтандартногоРуководителя(2) Тогда
			Сообщить("Стандартный реквизит позиция ШР не поддерживается в текущей конфигурации.");
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры        

&НаСервереБезКонтекста
Функция ПроверкаСтандартногоРуководителя(мРежим) 
	// В КА и ERP нет общего модуля РуководителиПодразделений
	мМодуль = Метаданные.ОбщиеМодули.Найти("РуководителиПодразделений"); 	
	мВозврат = Истина;                        
	Если мМодуль= Неопределено Тогда
		Если мРежим = 2 И (НЕ РуководителиПодразделенийОрганизации.РуководителиПодразделенийИспользуются()) Тогда
			мВозврат = Ложь;			                                                                         
		ИначеЕсли мРежим = 1 Тогда	         
			мВозврат = Ложь;			                                                                         	
		КонецЕсли;          
	Иначе	                                                             
		мСсылкаНаМодуль = ОбщегоНазначения.ОбщийМодуль("РуководителиПодразделений"); 
		Если мРежим = 1 И (НЕ РуководителиПодразделенийОрганизации.РуководителиПодразделенийИспользуются()) Тогда
			мВозврат = Ложь;			                                                                         
		ИначеЕсли мРежим = 2 И  (НЕ мСсылкаНаМодуль.РуководителиПодразделенийИспользуются()) Тогда	         
			мВозврат = Ложь;			                                                                         	
		КонецЕсли;          
	КонецЕсли;	
	Возврат мВозврат;              
КонецФункции


&НаСервере
Процедура СохранитьКонстанты()
	Константы.МК_Сервер.Установить(ЭтаФорма.СерверМояКоманда);
	Константы.МК_Логин.Установить(ЭтаФорма.Логин);
	Константы.МК_Пароль.Установить(ЭтаФорма.Пароль);   
	Константы.МК_СписокОрганизаций.Установить(Новый ХранилищеЗначения(ЭтаФорма.СписокОрганизаций)); 
	Константы.МК_СписокДолжностей.Установить(Новый ХранилищеЗначения(ЭтаФорма.СписокДолжностей));
	Константы.МК_СписокПодразделений.Установить(Новый ХранилищеЗначения(ЭтаФорма.СписокПодразделений));
	Константы.МК_СписокПодразделенийСтруктура.Установить(Новый ХранилищеЗначения(ЭтаФорма.СписокПодразделенийСтруктура));
	Константы.МК_СписокСотрудников.Установить(Новый ХранилищеЗначения(ЭтаФорма.СписокСотрудников)); 
	Константы.МК_СписокВидовЗанятости.Установить(Новый ХранилищеЗначения(ЭтаФорма.СписокВидовЗанятости));  
	// Контактная информация 
	мКЗКИ = ЭтаФорма.КонтактнаяИнформация;        // Тут получаем коллекцию значений
	мТабКИ = мКЗКИ.Выгрузить(,"Вид1С");           // Тут - таблицу значений
	мКонтИнф = мТабКИ.ВыгрузитьКолонку("Вид1С");  // И тут - нужный массив	
	Константы.МК_КонтактнаяИнформация.Установить(Новый ХранилищеЗначения(мКонтИнф)); 
	СохранитьНВИ2();  // Настройки выгружаемой информации    
	СохранитьПереопределяемыеРеквизиты();     
	СохранитьФильтрыВыгрузкиСотрудниковПрименение();  
	СохранитьФильтрыВыгрузкиСотрудниковСпособ();
КонецПроцедуры               

&НаСервере
Процедура СохранитьНВИ2()  // Сюда ничего не передаем, так как измененные настройки считываются из текущей таблицы значений. 
	мсНВИ = "";     
	мКЗ = ЭтаФорма.НастройкаВыгружаемойИнформации;     // Тут получаем коллекцию значений. В связи с тем, что порядок строк в таблице заказчик позже поменял, 
	мКЗ.Сортировать("НомерРеквизита");                 // нужно отсортировать коллекцию по колонке "НомерРеквизита".
	мТаб = мКЗ.Выгрузить(,"Выгружать");                // Тут - таблицу значений
	мНВИ = мТаб.ВыгрузитьКолонку("Выгружать");         // Это - массив. 
	мКолвоНВИ = мНВИ.Количество();
	Для мИндекс = 0 По мКолвоНВИ - 1 Цикл
		Если мНВИ[мИндекс] Тогда
			мЭлемент = "1";
		Иначе	         
			мЭлемент = "0";
		КонецЕсли;	
		мсНВИ = мсНВИ + мЭлемент;		
		Если мИндекс <> мКолвоНВИ - 1 Тогда
			мсНВИ = мсНВИ + ",";
		КонецЕсли;	
	КонецЦикла;
	Константы.МК_НастройкиВыгрузкиИнформации.Установить(мсНВИ);	
КонецПроцедуры	


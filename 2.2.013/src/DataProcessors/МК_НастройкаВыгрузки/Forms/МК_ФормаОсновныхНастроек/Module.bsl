&НаСервере
Функция ПроверкаСвязиНаСервере()
	// Проверка на безопасный режим должна работать только для "земли". Во Фреше - не нужна, там всегда безопасный.
	мРезультат = 2;
	мНеФреш = Константы.МК_НеФреш.Получить();
	Если мНеФреш Тогда;
		Если БезопасныйРежим() <> Ложь Тогда
        	мРезультат = 3;
		КонецЕсли;
	КонецЕсли;
	Если мРезультат = 2 Тогда	     
		// Проверять теперь велят не сохраненные в константах значения, а введенные в настоящий момент в форме  
		мПараметры = Новый Структура;
		мПараметры.Вставить("Сервер",ЭтаФорма.СерверМояКоманда);
		мПараметры.Вставить("Логин",ЭтаФорма.Логин);
		мПараметры.Вставить("Пароль",ЭтаФорма.Пароль);
		мРезультат = РеквизитФормыВЗначение("Объект").ПроверкаСвязиМК(мПараметры);
	КонецЕсли;
	Возврат мРезультат;
КонецФункции

&НаКлиенте
Процедура ПроверкаСвязи(Команда)     
	Результат = ПроверкаСвязиНаСервере();  		
	Если Результат = 2 Тогда
		ПоказатьПредупреждение(,"Есть контакт!");
	ИначеЕсли Результат = 0 Тогда     
		ПоказатьПредупреждение(,"Не получилось. Видимо указано неверное имя сервера.");
	ИначеЕсли Результат = 3 Тогда
		ПоказатьПредупреждение(,"В безопасном режиме расширение работать не будет. Нужно отключить его");
	Иначе	
		ПоказатьПредупреждение(,"Не получилось. Ошибка авторизации.");
	КонецЕсли;	
	
КонецПроцедуры   


&НаСервереБезКонтекста
Функция ПолучитьИС()
	МК_Сервер = Константы.МК_Сервер.Получить();
	ОО = Обработки.МК_НастройкаВыгрузки.Создать();             // Получили доступ к обработке, в которой находятся служебные функции  
	ИмяСервера = ОО.ПолучитьИмяСервера(МК_Сервер);            
КонецФункции	

&НаКлиенте
Процедура КаталогДляВыгрузкиФайловНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	Режим = РежимДиалогаВыбораФайла.ВыборКаталога; 
	ДиалогОткрытия = Новый ДиалогВыбораФайла(Режим); 
	ДиалогОткрытия.Каталог = ЭтаФорма.КаталогДляВыгрузкиФайлов; 
	ДиалогОткрытия.МножественныйВыбор = Ложь; 
	ДиалогОткрытия.Заголовок = "Выберите каталог"; 

	Если ДиалогОткрытия.Выбрать() Тогда   
		Если Элемент.Имя = "КаталогДляВыгрузкиФайлов" Тогда
			ЭтаФорма.КаталогДляВыгрузкиФайлов = ДиалогОткрытия.Каталог; 
		Иначе
			ЭтаФорма.КаталогДляЛогов = ДиалогОткрытия.Каталог; 
		КонецЕсли;	
	КонецЕсли;  		
КонецПроцедуры


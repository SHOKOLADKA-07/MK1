Функция ПроверкаСвязиМК(мПараметры) Экспорт      
	// Тут - два этапа проверки. Первый - просто постучаться на сервер. Это для проверки правильного ввода
	// имени ресурса.
	Результат = 0; // 0 - это не достучались до сервера, 1 - с сервером получилось, но авторизация не прошла, 2 - все хорошо.   
	мРеквС = Неопределено;	
	МК_Сервер = мПараметры.Сервер;
	ИмяСервера = ПолучитьИмяСервера(МК_Сервер);
		
	ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL(, Новый СертификатыУдостоверяющихЦентровОС);
	hСоединение = Новый HTTPСоединение(ИмяСервера,,,,,,ЗащищенноеСоединение);
	Попытка
		hЗапрос = Новый HTTPЗапрос("/api/healthz/");  // Тут простой запрос. Постучался - ответили "ok", значит сервер правильный    
		hОтвет = hСоединение.ВызватьHTTPМетод("GET", hЗапрос);
		мОтвет = hОтвет.ПолучитьТелоКакСтроку();    
		Если НРег(мОтвет) = "ok" Тогда         
			Результат = 1;
			// Теперь есть смысл проверить логин и пароль.
			мРеквС = СоздатьСеансСвязи(Истина,мПараметры);	
			Если НЕ (мРеквС = Неопределено) Тогда
				Результат = 2;
			КонецЕсли;	
		КонецЕсли;	
	Исключение  
		Результат = 0;
	КонецПопытки;	
	Возврат Результат;	
КонецФункции	


Функция СоздатьСеансСвязи(ИнтерактивныйРежим,мПараметры = Неопределено) Экспорт      
	// Тут создается HTTP соединение и выполняется авторизация.    
	Результат = Истина;
	РеквизитыСеанса = Новый Структура;                          
	// К реквизитам сеанса относятся
	// Сервер - Имя Сервера;
	// hСоединение - HTTP соединение;
	// Токен - мТокен, полученный от сервера  
	Если мПараметры = Неопределено Тогда
		МК_Сервер = Константы.МК_Сервер.Получить();
	Иначе     
		МК_Сервер = мПараметры.Сервер;        // Это - для проверки связи
	КонецЕсли;	
	ИмяСервера = ПолучитьИмяСервера(МК_Сервер); 
	РеквизитыСеанса.Вставить("Сервер",ИмяСервера);  
	hСоединение = СоздатьHTTPСоединение(РеквизитыСеанса);
	РеквизитыСеанса.Вставить("Соединение", hСоединение);
	РеквизитыСеанса.Вставить("ИнтерактивныйРежим",ИнтерактивныйРежим);
	мТокен = ПолучитьТокен(РеквизитыСеанса,мПараметры);
	Если мТокен = Неопределено Тогда      
		// Связь установить не удалось
		РеквизитыСеанса = Неопределено;   
	Иначе	
		РеквизитыСеанса.Вставить("Токен",мТокен);
	КонецЕсли;	
	// Добавил новый end-point GET /api/1c-exchange/check, который проверяет включен ли обмен с 1С и возвращает соответствующий ответ. Залил на dev. Доступен с авторизацией.
	// Теперь после получения токена надо проверить: включен ли обмен с 1С.
	Если НЕ РеквизитыСеанса = Неопределено Тогда	
		//hЗапрос = Новый HTTPЗапрос("/api/1c-exchange/check"); 		
		hЗапрос = СоздатьHTTPЗапрос("/api/1c-exchange/check", РеквизитыСеанса);   
		hЗапрос.Заголовки.Вставить("Source","1C Enterprise MK");
		hОтвет = hСоединение.ВызватьHTTPМетод("GET", hЗапрос); 
    	Результат = ПроверитьОтвет(hОтвет,"Проверка связи", ИнтерактивныйРежим);
	КонецЕсли;	
	Если Не Результат Тогда
		РеквизитыСеанса = Неопределено;
	КонецЕсли;	
	Возврат РеквизитыСеанса;
КонецФункции


Функция ПолучитьТокен(РеквизитыСеанса, мПараметры = Неопределено)   Экспорт
	Если мПараметры = Неопределено Тогда
		мЛогин = Константы.МК_Логин.Получить();
		мПароль = Константы.МК_Пароль.Получить();  
	Иначе                                        
		мЛогин = мПараметры.Логин;
		мПароль = мПараметры.Пароль;
	КонецЕсли;	
	мТокен = Неопределено;

	мЗапрос = Новый Структура;  
	мЗапрос.Вставить("email",мЛогин);
    мЗапрос.Вставить("password", мПароль);
     
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	
	Попытка
		ЗаписатьJSON(ЗаписьJSON, мЗапрос);	
		ТекстJSON = ЗаписьJSON.Закрыть();
	Исключение
		Сообщить(ЗначениеВСтрокуВнутр(мЗапрос));
		ВызватьИсключение(ОписаниеОшибки());
	КонецПопытки;
	
	hЗапрос = Новый HTTPЗапрос("/api/login-1c");   
	hЗапрос.Заголовки.Вставить("Source","1C Enterprise MK");
	hЗапрос.Заголовки.Вставить("Content-Type", "application/json");
	hЗапрос.УстановитьТелоИзСтроки(ТекстJSON);
	hОтвет = РеквизитыСеанса.Соединение.ВызватьHTTPМетод("POST", hЗапрос); 
	мОтвет = hОтвет.ПолучитьТелоКакСтроку();    
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(мОтвет);
		СтруктураОтвет = ПрочитатьJSON(ЧтениеJSON);
		Если СтруктураОтвет.data.Свойство("token") Тогда
		    мТокен = СтруктураОтвет.data.token;    
		Иначе
			ПроверитьОтвет(hОтвет, "Авторизация.",РеквизитыСеанса.ИнтерактивныйРежим);
		КонецЕсли;	
	Исключение
		ПроверитьОтвет(hОтвет, "Авторизация.",РеквизитыСеанса.ИнтерактивныйРежим);
	КонецПопытки;	
	Возврат мТокен;	  
КонецФункции

//  Это – краткий список организаций для разных нужд.
Функция ПолучитьСписокОрганизаций() Экспорт    
	// (26.06.24) Теперь список нужных организаций обрабатывается сложней:
	// 1. Может отсутствовать галочка "учитывать организации". Тогда учитываем все.
	// 2. Если учитываем, то надо смотреть на то, как:
	// 2.1 Если "выгружать", то список в константе - это то,что надо
	// 2.2 Если "не выгружать", то нужно взять полный список организаций и убрать из него те, что в константе.
	Попытка
		СписокОрганизаций = Константы.МК_СписокОрганизаций.Получить().Получить();     	
		Если СписокОрганизаций = Неопределено Тогда
			СписокОрганизаций = Новый СписокЗначений;	
			Константы.МК_СписокОрганизаций.Установить(Новый ХранилищеЗначения(СписокОрганизаций));
		КонецЕсли;	
	Исключение    
		СписокОрганизаций = Новый СписокЗначений;		
		Константы.МК_СписокОрганизаций.Установить(Новый ХранилищеЗначения(СписокОрганизаций));
	КонецПопытки;	
	// Получим полный список
	мЗапрос = Новый Запрос;
	мЗапрос.Текст = 
	"ВЫБРАТЬ
	|	Организации.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	НЕ Организации.ПометкаУдаления";
	
	мСписОргПолный = Новый СписокЗначений; 
	РезультатЗапроса = мЗапрос.ВыполнитьПакет();
	Выборка = РезультатЗапроса[0].Выбрать();
		
	Пока Выборка.Следующий() Цикл
		мСписОргПолный.Добавить(Выборка.Ссылка);
	КонецЦикла; 	
	  
    // Надо прочитать две константы: МК_УчитываемыеФильтры и МК_ВидыДействий.
	мУО = ПолучитьУчитываемыеФильтры()[0]; // Это массив. Первый (нулевой) элемент отвечает за организации    
	мВД = ПолучитьВидыДействия()[0];       // То же самое
	Если мУО = "0" Тогда   // Значит фильтр по организациям не активирован. Возвращаем полный список
		мВозврат = мСписОргПолный;
	Иначе                         
		Если мВД = "1" Тогда  // Значит выбрано "выгружать". Возвращаем сохраненный список  
			мВозврат = СписокОрганизаций;
		Иначе                 // Выбрано "не выгружать". Значит надо вернуть список кроме выбранных.
			мВозврат = Новый СписокЗначений;
			Для Каждого мОрг Из мСписОргПолный Цикл
				Если СписокОрганизаций.НайтиПоЗначению(мОрг.Значение) = Неопределено Тогда
					мВозврат.Добавить(мОрг.Значение);
				КонецЕсли;	
			КонецЦикла; 	
		КонецЕсли;	
	КонецЕсли;	
    Возврат мВозврат;
КонецФункции


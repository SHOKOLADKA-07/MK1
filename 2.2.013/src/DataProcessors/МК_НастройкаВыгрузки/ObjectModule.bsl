Функция ПолучитьФильтрВидыЗанятости() Экспорт   
	мСписВЗ = Новый СписокЗначений;
	// Надо прочитать две константы: МК_УчитываемыеФильтры и МК_ВидыДействий.
	мУО = ПолучитьУчитываемыеФильтры()[1]; // Это массив. Первый элемент отвечает за виды занятости
	мВД = "0";                         
	мГПХ = "0";  // Не учитывать фильтр по ГПХ
	Если мУО = "1" Тогда    // Учитывается
		мВД = ПолучитьВидыДействия()[1];       // То же самое
        мСписок = ПолучитьВидыЗанятости(); 
		// С видами занятости не так просто, как с остальными фильтрами. Во первых мы в список видов добавили "ГПХ". А он на самом деле -
		// отдельный реквизит. Во вторых собственно виды занятости - это перечисление. А сохраняем строку.
		// Поэтому массив будет сложнее. Первый элемент будет определять - что делать с ГПХ   
		Для Каждого мВЗ ИЗ мСписок Цикл
			Если мВЗ.Значение = "ГПХ" Тогда  // ГПХ в списке есть  
				мГПХ = мВД
			ИначеЕсли мВЗ.Значение = "Основное место работы" Тогда  
				мСписВЗ.Добавить(Перечисления.ВидыЗанятости.ОсновноеМестоРаботы);             
			ИначеЕсли мВЗ.Значение = "ВнешнееСовместительство" Тогда  
				мСписВЗ.Добавить(Перечисления.ВидыЗанятости.Совместительство);
	        ИначеЕсли мВЗ.Значение = "ВнутреннееСовместительство" Тогда  
				мСписВЗ.Добавить(Перечисления.ВидыЗанятости.ВнутреннееСовместительство); 
			Иначе
			    мСписВЗ.Добавить(Неопределено);
			КонецЕсли;	
		КонецЦикла;	 
		Если мГПХ = "0" И мВД = "1" Тогда   // Если ГПХ в списке нет, но сказано "выгружать", значит надо указать, что ГПХ не выгружать 
			мГПХ = "2";
		КонецЕсли;			
	КонецЕсли;
	мВозврат = Новый Массив;
	// Поэтому массив будет сложнее. Первые два элемента отвечают за виды занятости, а третий элемент будет определять - что делать с ГПХ   
	мВозврат.Добавить(мВД);
	мВозврат.Добавить(мСписВЗ);
	мВозврат.Добавить(мГПХ);
	Возврат мВозврат;
КонецФункции

Функция ВыгрузитьФайлНаСайт(мФайл, РеквизитыСеанса,мТипФайла,ИнтерактивныйРежим, мАдрес,мРежим)  Экспорт   
	// Эта функция в связи с КЭДО будет отправлять различные файлы. Увеличиваем кол-во параметров.
	// мАдрес: пример для расчетных листков - "/api/1c-exchange/pay-list/upload"
	// мРежим: пример для расчетных листков - "Расчетные листки"
	Результат = Ложь;  // Надо вернуть ответ - получилось отправить или нет   
	
	// Если вызов функции происходит из процедуры создания файлов, то сюда прилетает мФайл - строка - полное имя файла.
	// Если же это повторная отправка сохраненного файла, то прилетает ссылка на сохраненный файл.  
	ДвоичныеДанные = Неопределено;
	Если ТипЗНЧ(мФайл) = Тип("Строка") Тогда
		// Надо получить чистое имя файла, без пути    
		мФайл1 =  Сред(мФайл, СтрНайти(мФайл, "\", НаправлениеПоиска.СКонца) + 1); 
		ДвоичныеДанные = Новый ДвоичныеДанные(мФайл);
	Иначе 
		Попытка
			ДвоичныеДанные = РаботаСФайлами.ДвоичныеДанныеФайла(мФайл); 
			мФайл1 = мФайл.Наименование+".zip";
		Исключение
		КонецПопытки;	
	конецЕсли;	                  
	Если НЕ (ДвоичныеДанные = Неопределено) Тогда
		// Пойдем по сложному пути
		Разделитель = СтрЗаменить(Новый УникальныйИдентификатор(), "-", "");  
	
		Тело = Новый ПотокВПамяти();
		ЗаписьДанных = Новый ЗаписьДанных(Тело, , , Символы.ВК + Символы.ПС, ""); // переопределение разделителей               
		ЗаписьДанных.ЗаписатьСтроку("--" + Разделитель);
		ЗаписьДанных.ЗаписатьСтроку("Content-Disposition: form-data; name=file; filename=" + мФайл1);
		ЗаписьДанных.ЗаписатьСтроку("Content-Type: "+мТипФайла);
		ЗаписьДанных.ЗаписатьСтроку(""); // пустая строка для доп переноса и воспроизведения структуры тела
		ЗаписьДанных.Записать(ДвоичныеДанные); // добавляет данные но каретка остается после данных
		ЗаписьДанных.ЗаписатьСтроку(""); // записать не добавляет переносов, добавляем их пустой строкой
		ЗаписьДанных.ЗаписатьСтроку("--" + Разделитель + "--"); // добавляются еще доп переносы, но они уже не на что не влияют, так же после разделителя добавляем "--", должно обозначать конец тела
		ЗаписьДанных.Закрыть();
	
		ДанныеТела = Тело.ЗакрытьИПолучитьДвоичныеДанные(); // получаем тело в дд

	
    	Попытка
			
			hЗапрос = СоздатьHTTPЗапрос(мАдрес, РеквизитыСеанса); 		
			hЗапрос.УстановитьТелоИзДвоичныхДанных(ДанныеТела); // установили тело  
			hЗапрос.Заголовки.Вставить("Source","1C Enterprise MK");
			hЗапрос.Заголовки.Вставить("Content-Length", XMLСтрока(ДанныеТела.Размер()));
			hЗапрос.Заголовки.Вставить("Content-Type", "multipart/form-data; boundary=" + Разделитель);
			hОтвет = РеквизитыСеанса.Соединение.ОтправитьДляОбработки(hЗапрос); // финал
       		Результат = ПроверитьОтвет(hОтвет,мРежим, ИнтерактивныйРежим);   			
		Исключение
			//ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
			//ДобавитьОписаниеОшибки(ОписаниеОшибки, ОписаниеОшибки());		
		КонецПопытки;	
	КонецЕсли;	
	Возврат Результат;
КонецФункции    


// Служебные функции.

Функция ПолучитьИмяСервера(ИмяСервера)  Экспорт
	
	ИмяСервера = НРег(СокрЛП(ИмяСервера));
	ИмяСервера = СтрЗаменить(ИмяСервера, "http://", "");
	ИмяСервера = СтрЗаменить(ИмяСервера, "https://", "");
	ИмяСервера = СтрЗаменить(ИмяСервера, "/", "");
	
	Возврат ИмяСервера;                                                                         
	
КонецФункции

Функция СоздатьHTTPСоединение(РеквизитыСеанса) Экспорт
	
	
	ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL(, Новый СертификатыУдостоверяющихЦентровОС);
	hСоединение = Новый HTTPСоединение(РеквизитыСеанса.Сервер,,,,,,ЗащищенноеСоединение);	
	Возврат hСоединение; 
	
КонецФункции	

Функция СоздатьHTTPЗапрос(АдресРесурса, РеквизитыСеанса) Экспорт
	
	hЗапрос = Новый HTTPЗапрос(АдресРесурса);   
	мТокен = РеквизитыСеанса.Токен;
	hЗапрос.Заголовки.Вставить("authorization", "Bearer "+мТокен);
		
	Возврат hЗапрос;
	
КонецФункции

Функция ПолучитьВидыКонтИнф() Экспорт // Эта функция не только тут нужна
	мКонтИнф = Константы.МК_КонтактнаяИнформация.Получить().Получить();
	// Этот массив сейчас должен состоять из трех элементов:
	// 0 - ссылка на основной email для "МояКоманда";
	// 1 - ссылка на дополнительный email;
	// 2 - ссылка на телефон    
	// 3 - ссылка на адрес (добавлена 06.05.2024).
	Если мКонтИнф = Неопределено Тогда // Этот вариант может случиться только один раз.
		мКонтИнф = Новый Массив(4);
		мКонтИнф[0] = Справочники.ВидыКонтактнойИнформации.НайтиПоРеквизиту("ИмяПредопределенногоВида","EmailФизическиеЛица");
		мКонтИнф[1] = Неопределено;  // ПустаяСсылка();  //ПолучитьПустоеЗначение("СправочникКонтактнойИнформации"); 
		// Дополнительного мэйла может не быть, поэтому второй элемент по умолчанию не заполнен
		мКонтИнф[2] = Справочники.ВидыКонтактнойИнформации.НайтиПоНаименованию("Мобильный телефон");
		// Дополнительного мэйла может не быть, поэтому второй элемент по умолчанию не заполнен
		// Сразу сохраним массив.
		Константы.МК_КонтактнаяИнформация.Установить(Новый ХранилищеЗначения(мКонтИнф));
	КонецЕсли;  	
	Если мКонтИнф.Количество() = 3 Тогда       // Из-за добавленного адреса.
		мКонтИнф.Добавить(Справочники.ВидыКонтактнойИнформации.НайтиПоРеквизиту("ИмяПредопределенногоВида","АдресМестаПроживанияФизическиеЛица"));
		Константы.МК_КонтактнаяИнформация.Установить(Новый ХранилищеЗначения(мКонтИнф));
	КонецЕсли;	
	
	Возврат мКонтИнф;
КонецФункции	


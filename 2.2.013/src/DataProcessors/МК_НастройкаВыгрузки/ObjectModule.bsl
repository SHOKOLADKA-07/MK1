Функция ПолучитьНастройкиВыгружаемойИнформации()  Экспорт
	мсНВИ = Константы.МК_НастройкиВыгрузкиИнформации.Получить();   // Ожидается строка типа "1,1,1, ..0."     
	мКолвоНВИ = 23;
	// 20.03.2026 добавлен реквизит с номером 22 - Выгружать структуру предприятия.
	Если ПустаяСтрока(мсНВИ) Тогда
		мНВИ = Новый Массив(мКолвоНВИ);
		Для мИндекс = 0 По мКолвоНВИ-1 Цикл  
			Если мИндекс = 22 Тогда
				мНВИ[мИндекс] = " ";  // Структура по умолчанию не выгружается.
			Иначе	
				мНВИ[мИндекс] = "1";
			КонецЕсли;	
		КонецЦикла;	
		СохранитьНВИ1(мНВИ);
	Иначе
		мНВИ = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(мсНВИ);
		мКолво = мНВИ.Количество();
		Если мКолво < мКолвоНВИ Тогда
			Для мИндекс = мКолво+1 По мКолвоНВИ Цикл
				Если мИндекс = 23 Тогда
					мНВИ.Добавить(" ");  // Структура по умолчанию не выгружается.
				Иначе	
					мНВИ.Добавить("1");
				КонецЕсли;					
			КонецЦикла;
			СохранитьНВИ1(мНВИ);
		КонецЕсли;	
	КонецЕсли;
    Возврат мНВИ;
КонецФункции     


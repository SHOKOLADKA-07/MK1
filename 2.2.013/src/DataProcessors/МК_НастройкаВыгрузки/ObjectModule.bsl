КонецФункции	

Функция СписокСотрудниковПоФизлицу(мОрганизация,мФизлицо)  Экспорт
	// Подбираем только основных сотрудников или внешних совместителей. 
	// Если все хорошо, должен вернуться один сотрудник.
		
	мЗапрос = Новый Запрос;
	мЗапрос.УстановитьПараметр("Организация", мОрганизация);
	мЗапрос.УстановитьПараметр("Физлицо", мФизлицо);
	мЗапрос.УстановитьПараметр("Дата", ТекущаяДата());        
	
	мЗапрос.Текст =   
	"ВЫБРАТЬ
	|	ДанныеДляПодбора.Должность.Ссылка КАК ДолжностьСсылка,
	|	ДанныеДляПодбора.Сотрудник.Ссылка КАК СотрудникСсылка,    
	|	ДанныеДляПодбора.ВидЗанятости КАК ВидЗанятости
	|ИЗ
	|	РегистрСведений.ДанныеДляПодбораСотрудников КАК ДанныеДляПодбора
	|ГДЕ
	|	ДанныеДляПодбора.ФизическоеЛицо.Ссылка = &Физлицо
	|	И ДанныеДляПодбора.Организация.Ссылка = &Организация
	|	И ДанныеДляПодбора.ВидСобытия <> ЗНАЧЕНИЕ(Перечисление.ВидыКадровыхСобытий.Увольнение)
	|	И НЕ ДанныеДляПодбора.ПоДоговоруГПХ 
	|   И (ДанныеДляПодбора.ВидЗанятости = Значение(Перечисление.ВидыЗанятости.ОсновноеМестоРаботы) 
	|		ИЛИ ДанныеДляПодбора.ВидЗанятости = Значение(Перечисление.ВидыЗанятости.Совместительство))
	|	И ДанныеДляПодбора.Начало <> ДАТАВРЕМЯ(1, 1, 1)
	|	И ДанныеДляПодбора.Начало <= КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
	|	И (ДанныеДляПодбора.Окончание = ДАТАВРЕМЯ(1, 1, 1)
	|			ИЛИ ДанныеДляПодбора.Окончание >= НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ))";

    РезультатЗапроса = мЗапрос.ВыполнитьПакет();
	Выборка = РезультатЗапроса[0].Выбрать();
			
	Возврат Выборка;

КонецФункции

Функция ДатаИзСтроки(Стр)
	
	Рез = Неопределено;
	Попытка
		Рез = Дата(Стр);
	Исключение
	КонецПопытки;
	Если ТипЗнч(Рез) = Тип("Дата") Тогда
		Возврат Рез;	
	КонецЕсли;
	МассивДата = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Стр, "-");
	Если МассивДата.Количество() = 3 Тогда
		Попытка
			Рез = Дата(Число(МассивДата[0]), Число(МассивДата[1]), Число(МассивДата[2]));	
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Возврат Рез;
	
КонецФункции

Функция ВызватьhМетод(мМетод, мСеанс, hЗапрос, АдресРесурса, ТипВыгрузки, ИнтерактивныйРежим) Экспорт
	мКолво = 120;
	hОтвет = мСеанс.Соединение.ВызватьHTTPМетод(мМетод, hЗапрос);   
	мРезультат = ПроверитьОтвет1(hОтвет,ТипВыгрузки,Истина, ИнтерактивныйРежим);
	мВозврат = Истина;
	Если мРезультат[0] = 1 Тогда   // Это значит, что получен положительный ответ на получение запроса, но обработка еще не завершена.
		// К первичному адресу надо добавить слово /result/ и номер процесса, который есть в ответе на POST запрос
		мАдресРесурса = АдресРесурса + "/result/" + Формат(мРезультат[1],"ЧГ=0");
		Для Счетчик = 1 По мКолво Цикл  
			// У вторичного запроса тела нет.   
			hЗапрос = СоздатьHTTPЗапрос(мАдресРесурса, мСеанс); 
			hЗапрос.Заголовки.Вставить("Source","1C Enterprise MK");
			hОтвет = мСеанс.Соединение.ВызватьHTTPМетод("GET", hЗапрос);  
			мРезультат = ПроверитьОтвет1(hОтвет,ТипВыгрузки,Ложь, ИнтерактивныйРежим);   // Ложь говорит о том, что это ответ на вторичный запрос
			Если мРезультат[0] = 2 Тогда    // Это значит, что завершение процесса случилось.
				Прервать;	
			ИначеЕсли мРезультат[0] = 0 Тогда	    // Произошла ошибка. Дальше стучаться нет смысла.  
				мВозврат = Ложь;
				Прервать;	
			КонецЕсли;	
		КонецЦикла;	
	КонецЕсли;
	Если Счетчик = мКолво Тогда
		// Завершение случилось по превышению разрешенных циклов. Надо сообщить об ошибке.
		мОшибка = "Ошибка выгрузки. " + ТипВыгрузки + ". Ответ от сервера не получен за отведенное время.";  
		ИмяСобытия = "МояКоманда. Выгрузка сотрудников";
		Если ИнтерактивныйРежим Тогда
			Сообщить(мОшибка);   
		Иначе
			ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,,, мОшибка);     
		КонецЕсли;	
		мВозврат = Ложь;
	КонецЕсли;
	Возврат мВозврат;
КонецФункции	

Функция ПроверитьОтвет1(hОтвет, ТипВыгрузки, Первичный, ИнтерактивныйРежим)    // Тут проверка специфических ответов - на запросы при выгрузке списка сотрудников.
	// В ответ на первичный запрос получаем ответ типа:
	// {"data":{
	// 	"status": "success",
	// 	"error": [],
	// 	"result": 141}}
	// Ответ на вторичный запрос, если обработка еще не завершена:
	// {"data": {
	//  "status": "pending",
	//  "percent": 10,
	//  "error": [] }}
	// Или такой, если завершилась:               
	// {"data": {
	//  "status": "success",
	//  "percent": 100,
	//  "error": [] }}
    мВозврат = Новый Массив(2);  // Первый элемент: 1 - получен положительный ответ на первичный (или на вторичный) запрос, но ответа еще нет 
	                             //                 2 - получен положительный ответ на вторичный запрос о том, что процесс завершен нормально
								 //                 0 - случилась какая-то ошибка
	                             // Второй элемент  - ID процесса обработки 
	мВозврат[0] = 0;
	мВозврат[1] = 0;
	// Вариантов ответов может быть несколько. В связи с переходом на псевдо-асинхронный режим
	// работы запросов, кроме ошибки или корректного завершения, может быть ответ о том, что
	// обработка запроса на сервере еще не завершена. И стало быть надо послать еще один запрос.
	// Повторные запросы типа GET, они должны передавать серверу некий ID процесса, который возвращается
	// после первичного запроса.
	
	мОшибка = Неопределено;
	ТекстОтвет = hОтвет.ПолучитьТелоКакСтроку();
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТекстОтвет);
		СтрОтвет = ПрочитатьJSON(ЧтениеJSON);
	Исключение   
		мОшибка = "Ошибка выгрузки. "+ТипВыгрузки+". Не удалось преобразовать строку HTTP-ответа в json: "+ТекстОтвет;
	КонецПопытки;                                                                       
	
	Если мОшибка = Неопределено Тогда
		Если ТипЗнч(СтрОтвет) <> Тип("Структура")
			ИЛИ НЕ СтрОтвет.Свойство("data") 
				ИЛИ НЕ СтрОтвет.data.Свойство("status") Тогда
			// Тут какая-то беда. Или структура не получена, или она неправильная  
			мОшибка = "Ошибка выгрузки. "+ТипВыгрузки+". Получен некорректный HTTP ответ: "+ТекстОтвет;
		Иначе
			мСтатус = СтрОтвет.data.status;
			Если мСтатус = "success" Тогда    
				Если Первичный Тогда
					Если СтрОтвет.data.Свойство("result") Тогда
						мВозврат[0] = 1;
						мВозврат[1] = СтрОтвет.data.result;
					Иначе	    // Ошибочная ситуация.
						мОшибка = "Ошибка выгрузки. "+ТипВыгрузки+". В ответе нет свойства 'result'";   // Наверное надо завершать.
					КонецЕсли;
				Иначе	  // Вторичный запрос. Тут успех говорит о том, что процесс завершен.
					мВозврат[0] = 2;         
					мОшибка = "Выгрузка. "+ТипВыгрузки+". Успех";   // Это конечно не ошибка. Но пока пусть будет так.
				КонецЕсли;	
			ИначеЕсли мСтатус = "pending" Тогда  // Такой статус может быть только у ответа на вторичный запрос
				мВозврат[0] = 1;
			ИначеЕсли мСтатус = "failed" Тогда
				// Тут надо разобрать ошибки     
				мОшибка = "Ошибка выгрузки. "+ТипВыгрузки+". " ;  
				Если СтрОтвет.data.Свойство("error") Тогда
					Для Каждого эОшибка Из СтрОтвет.data.error Цикл
						мОшибка = мОшибка + эОшибка + ", ";
					КонецЦикла;	
				Иначе
					мОшибка = мОшибка + "Описание ошибок отсутствует.";
				КонецЕсли;	
			Иначе    
				мОшибка =  "Ошибка выгрузки. "+ТипВыгрузки+". Неизвестный тип статуса ответа: "+мСтатус;
			КонецЕсли;
		КонецЕсли;			
	КонецЕсли;	
	Если НЕ мОшибка = Неопределено Тогда
		Если ИнтерактивныйРежим Тогда
			Сообщить(мОшибка);	
		Иначе                                                   
			ИмяСобытия = "МояКоманда. Выгрузка сотрудников";
			ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,,, мОшибка);     
		КонецЕсли;	
	КонецЕсли;
	Возврат мВозврат;
	
КонецФункции


Функция ПроверитьОтвет(hОтвет, ТипВыгрузки, ИнтерактивныйРежим) Экспорт     
	мРезультат = Ложь;
	мОшибка = Неопределено;
	ТекстОтвет = hОтвет.ПолучитьТелоКакСтроку();
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТекстОтвет);
		СтрОтвет = ПрочитатьJSON(ЧтениеJSON);
	Исключение   
		мОшибка = "Ошибка выгрузки. "+ТипВыгрузки+". Не удалось преобразовать строку HTTP-ответа в json: "+ТекстОтвет;
	КонецПопытки;                                                                       
	
	// Тут будем формировать вменяемые сообщения об успехе или о полученных ошибках.	
	// На код состояния оказывается надеяться нельзя. Если до сервера достучались,
	// значит уже будет 200.
	// Но все-таки коды состояния видимо надо тоже обрабатывать, так как если до сервера не добрались, то
	// корректный ответ будет невозможен.                                                                                М
	
	
	// Надо анализировать СтрОтвет. В нем должен быть раздел data, а дальше - status и error
	// Если status - success, значит все прошло успешно. Если failed, значит надо сформировать
	// сообщение об ошибках. Причем их может быть несколько, так как error - массив.
	
	Если мОшибка = Неопределено Тогда
		Если ТипЗнч(СтрОтвет) <> Тип("Структура")
			ИЛИ НЕ СтрОтвет.Свойство("data") 
				ИЛИ НЕ СтрОтвет.data.Свойство("status") Тогда
			// Тут какая-то беда. Или структура не получена, или она неправильная  
			Если СтрОтвет.Свойство("error") Тогда        // Если ошибка произошла во время авторизации, то ответ имеет другую структуру.
				мОшибка =  "Ошибка соединения. " + СтрОтвет.error.error_msg;
			Иначе	
				мОшибка = "Ошибка выгрузки. "+ТипВыгрузки+". Получен некорректный HTTP ответ: "+ТекстОтвет;  
			КонецЕсли;	
		Иначе
			мСтатус = СтрОтвет.data.status;
			Если мСтатус = "success" Тогда    
				мОшибка = "Выгрузка. "+ТипВыгрузки+". Успех";   // Это конечно не ошибка. Но пока пусть будет так.
				мРезультат = Истина;
				// Тут все хорошо
			ИначеЕсли мСтатус = "failed" Тогда
				// Тут надо разобрать ошибки     
				мОшибка = "Ошибка выгрузки. "+ТипВыгрузки+". " ;  
				Если СтрОтвет.data.Свойство("error") Тогда
					Для Каждого эОшибка Из СтрОтвет.data.error Цикл
						мОшибка = мОшибка + эОшибка + ", ";
					КонецЦикла;	
				Иначе
					мОшибка = мОшибка + "Описание ошибок отсутствует.";
				КонецЕсли;	
			Иначе    
				мОшибка =  "Ошибка выгрузки. "+ТипВыгрузки+". Неизвестный тип статуса ответа: "+мСтатус;
			КонецЕсли;
		КонецЕсли;			
	КонецЕсли;				
	Если ИнтерактивныйРежим Тогда    
		Если НЕ мРезультат Тогда
			Сообщить(мОшибка);	
		КонецЕсли;	
	Иначе                                                   
		ИмяСобытия = "МояКоманда. Выгрузка сотрудников";
		Если НЕ мРезультат Тогда   // Об успехе не будем писать ошибку в журнал.
			ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,,, мОшибка);     
		Иначе
			ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Информация,,, мОшибка);     
		КонецЕсли;	
	КонецЕсли;	
	
	Возврат мРезультат;
	
КонецФункции

Функция ПолучитьХешСтроки(Строка)   Экспорт
	
	ХешированиеДанных  = Новый ХешированиеДанных(ХешФункция.CRC32);
	ХешированиеДанных.Добавить(Строка);
	Возврат ХешированиеДанных.ХешСумма;
	
КонецФункции

Функция НайтиДопРеквХэшДанных(ТипСправочника)    Экспорт
	// Здесь нужно найти существующий тип доп.сведения для переданного справочника.
	// Если найдем, возвращаем его, иначе создаем новый.
	УстановитьПривилегированныйРежим(Истина);
	мВозврат = Неопределено;
	ИмяСв = "МК_ВидСведений_" + ТипСправочника;
	
	мЗапрос = Новый Запрос;
	мЗапрос.УстановитьПараметр("Имя", ИмяСв);
	мЗапрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ДопСв.Ссылка КАК Ссылка
	|ИЗ
	|	ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения КАК ДопСв
	|ГДЕ
	|	ДопСв.Имя = &Имя";
	
	РезультатЗапроса = мЗапрос.ВыполнитьПакет();
	Выборка = РезультатЗапроса[0].Выбрать();
	
	Если Выборка.Следующий() Тогда
		мВозврат = Выборка.Ссылка;
	Иначе   
		// Еще не был создан такой вид.
		ДопСв = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.СоздатьЭлемент();
		ДопСв.ТипЗначения = Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(30));
		ДопСв.Наименование = "МояКоманда вид сведений";	
		ДопСв.Заголовок = ДопСв.Наименование; 
		ДопСв.Имя = ИмяСв;
		ДопСв.НаборСвойств = Справочники.НаборыДополнительныхРеквизитовИСведений.НайтиПоРеквизиту("ИмяПредопределенногоНабора", "Справочник_" + ТипСправочника);
		ДопСв.Доступен = Истина;
		ДопСв.МногострочноеПолеВвода = 0;
		ДопСв.ЭтоДополнительноеСведение = Истина;
		ДопСв.Записать();
	
		НаборСвойствОбъект = ДопСв.НаборСвойств.ПолучитьОбъект();
		НоваяСтрока = НаборСвойствОбъект.ДополнительныеСведения.Добавить();
		НоваяСтрока.Свойство = ДопСв.Ссылка;
		НаборСвойствОбъект.Записать();
		мВозврат =  ДопСв.Ссылка;
	КонецЕсли;	
	Возврат мВозврат;
КонецФункции

Функция МК_ТипМаршрута(мТип,мРежим)   Экспорт           
	мВозврат = Неопределено;      
	Если мРежим = 1 Тогда
		Если мТип = Перечисления.МК_МаршрутыПодписания.М1 Тогда
			мВозврат = 	"director_first";
		ИначеЕсли мТип = Перечисления.МК_МаршрутыПодписания.М2 Тогда
			мВозврат = 	"employee_first";  
		ИначеЕсли мТип = Перечисления.МК_МаршрутыПодписания.М3 Тогда
			мВозврат = 	"director_only";	                  
		ИначеЕсли мТип = Перечисления.МК_МаршрутыПодписания.М4 Тогда
			мВозврат = 	"employee_only";	
		КонецЕсли;
	Иначе                                                      
		Если мТип = "director_first" Тогда
			мВозврат = 	Перечисления.МК_МаршрутыПодписания.М1;
		ИначеЕсли мТип = "employee_first" Тогда
			мВозврат = 	Перечисления.МК_МаршрутыПодписания.М2;  
		ИначеЕсли мТип = "director_only" Тогда
			мВозврат = 	Перечисления.МК_МаршрутыПодписания.М3;	                  
		ИначеЕсли мТип = "employee_only" Тогда
			мВозврат = 	Перечисления.МК_МаршрутыПодписания.М4;	
		КонецЕсли;   
	КонецЕсли;	
	Возврат мВозврат;
КонецФункции	
	

&НаСервереБезКонтекста
Функция НайтиДокКЭДО(мСсылка, МК_Код);	
	мВозврат = Неопределено;
	мЗапрос = Новый Запрос;
	мЗапрос.УстановитьПараметр("мДокОсн",мСсылка);		
	мЗапрос.УстановитьПараметр("мСтатус",Перечисления.МК_СтатусыДокументов.С6);		
	мЗапрос.УстановитьПараметр("мКодДок",МК_Код);		
	мЗапрос.Текст = 
	"ВЫБРАТЬ Первые 1
	|	МК_ДКЭДО.Ссылка КАК Ссылка	
	|ИЗ 
	|	Справочник.МК_ДокументыКЭДО КАК МК_ДКЭДО
	|ГДЕ
	|	НЕ МК_ДКЭДО.ПометкаУдаления 
	|   И НЕ (МК_ДКЭДО.СтатусДокумента = &мСтатус) 
	|   И МК_ДКЭДО.КодТипаДокумента = &мКодДок
	|   И (МК_ДКЭДО.ДокументОснование = &мДокОсн)";
		
	РезультатЗапроса = мЗапрос.ВыполнитьПакет();
	Выборка = РезультатЗапроса[0].Выбрать();
			
	Если Выборка.Следующий() Тогда
		мВозврат = Выборка.Ссылка;
	КонецЕсли;	
    Возврат мВозврат;	
КонецФункции	

&НаСервере
Процедура ОтправитьНаСервере()   // Попытка отправки ранее сохраненного архива.	
	мВозврат = 1;
	мФайлы = Новый Массив;
	РаботаСФайлами.ЗаполнитьПрисоединенныеФайлыКОбъекту(ЭтаФорма.ДокКЭДО, мФайлы);    
	Если мФайлы.Количество()>0 Тогда
		ИмяАрхива = мФайлы[0];
	КонецЕсли;	
	//ДвоичныеДанные = РаботаСФайлами.ДвоичныеДанныеФайла(мФайлы[0]);       
	
	ОО = Обработки.МК_НастройкаВыгрузки.Создать();             // Получили доступ к обработке, в которой находятся служебные функции
	// Тут - отправка. 
	мСеанс = ОО.СоздатьСеансСвязи(Истина);
	Если мСеанс = Неопределено Тогда
		// Ошибка авторизации. Ничего не отправляем. 
		мВозврат = 4;		
	Иначе
		мРезультат = ОО.ВыгрузитьФайлНаСайт(ИмяАрхива,мСеанс,"pdf",Истина,"api/1c-exchange/edms/documents/upload","Документы КЭДО");
		Если НЕ мРезультат Тогда
			мВозврат = 5      // Ошибка отправки файла 
		КонецЕсли;		
    КонецЕсли;	
	Если мВозврат = 1 Тогда   // Все удалось. Нужно отправить json описание файла.
		мДокументы = Новый Массив;
		мДокументы.Добавить(ЭтаФорма.ДокКЭДО);
		мРезультат = Справочники.МК_ДокументыКЭДО.МК_ОтправитьJSON(мДокументы);
		Если НЕ мРезультат Тогда
			мВозврат=7; //  Ошибка отправки описания файла.
		КонецЕсли;	
	КонецЕсли;
	Если мВозврат = 1 Тогда
		Сообщить("Документ отправлен успешно");
	ИначеЕсли мВозврат = 5 Тогда
		Сообщить("Ошибка отправки zip-архива");	
	ИначеЕсли мВозврат = 7 Тогда
		Сообщить("Ошибка отправки описания файла");		
	ИначеЕсли мВозврат = 4 Тогда
		Сообщить("Ошибка авторизации. Ничего не отправлено");		
	КонецЕсли;    
	Если мВозврат =1 ИЛИ мВозврат = 5 ИЛИ мВозврат = 7 Тогда  // 5 или 7 - это все сделано, но не удалось отправить zip-архив или описание.
		ЭтаФорма.Состояние = ПолучитьСостояниеДокумента(ЭтаФорма.ДокКЭДО);
		ЭтаФорма.ТолькоПросмотр = Истина;    
		ЭтаФорма.ЗапретДействий = Истина;
	КонецЕсли;	 
КонецПроцедуры

&НаКлиенте
Процедура Отправить(Команда)
	ОтправитьНаСервере();  
	ЭтаФорма.ОбновитьОтображениеДанных(); 
	//ОбновитьДинамическийСписок();
    ОповеститьОбИзменении(ЭтаФорма.ДокументСсылка);
КонецПроцедуры

&НаСервере
Функция УдалитьНаСервере()
	// Надо поменять статус документа на "Недействителен", пометить документ как неотправленный и
	// попытаться отправить сообщение об изменении на сервер. Если получится, снять пометку "неотправлен".	 	
	мДок = ЭтаФорма.ДокКЭДО.ПолучитьОбъект();
	мДок.СтатусДокумента = Перечисления.МК_СтатусыДокументов.С6;   
	мДок.СтатусЧислом = 8;
	мДок.Отправлен = Ложь;
	мДок.Записать();  
	// Отправка
	мРезультат = Истина;
	ОО = Обработки.МК_НастройкаВыгрузки.Создать();             // Получили доступ к обработке, в которой находятся служебные функции
	мСеанс = ОО.СоздатьСеансСвязи(Истина);
	Если мСеанс = Неопределено Тогда
		// Надо сообщить, что отправка не удалась.  		
	Иначе                         
		мДокс = Новый Массив;
		мДокс.Добавить(СокрЛП(ЭтаФорма.ДокКЭДО.УникальныйИдентификатор())); // Пока один документ отправляем. Хотя можно несколько
		Выгрузка = Новый Структура;
		Выгрузка.Вставить("Documents",мДокс);
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		
		Попытка
			ЗаписатьJSON(ЗаписьJSON, Выгрузка);	
			ТекстJSON = ЗаписьJSON.Закрыть();
		Исключение
			Сообщить(ЗначениеВСтрокуВнутр(Выгрузка));
			ВызватьИсключение(ОписаниеОшибки());
		КонецПопытки;
	КонецЕсли;	
				
	hЗапрос = ОО.СоздатьHTTPЗапрос("api/1c-exchange/edms/delete-documents", мСеанс);
	hЗапрос.УстановитьТелоИзСтроки(ТекстJSON);   
	hЗапрос.Заголовки.Вставить("Source","1C Enterprise MK");
	hОтвет = мСеанс.Соединение.ВызватьHTTPМетод("POST", hЗапрос);
	мОтвет = ОО.ПроверитьОтвет(hОтвет,"ДокументыКЭДО",Истина); 
	Если мОтвет Тогда   // Если отправка случилась успешно, запишем, что документы отправлены.   
		мДок.Отправлен = Истина; 		 
	Иначе
		мДок.Отправлен = Ложь; 
	КонецЕсли;  
	мДок.Записать(); 
	Если мОтвет Тогда
		Сообщить("Состояние документа отправлено успешно");
	КонецЕсли;	
КонецФункции


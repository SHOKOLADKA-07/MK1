Функция ОпределитьРеквизитыВидаДокумента();
	мРез = Ложь;
	МК_Рекв = Справочники.МК_ВидыДокументов.МК_РеквВидаДокумента(ЭтаФорма.Документ,ЭтаФорма.ПечатнаяФорма);	  // Возвращает соответствие МК_Код, МаршрутПодписания, КодМинтруда, 
	Если МК_Рекв <> Неопределено Тогда   
		Попытка
			мДокумент = ЭтаФорма.ДокументСсылка.ПолучитьОбъект();
			ЭтаФорма.МК_Код = МК_Рекв.Получить("МК_Код");
			//ЭтаФорма.МК_Наименование = МК_Рекв.Получить("МК_Ссылка");
			ЭтаФорма.МК_Наименование = Справочники.МК_ВидыДокументовМояКоманда.НайтиПоРеквизиту("ID",ЭтаФорма.МК_Код);
			ЭтаФорма.МаршрутПодписания = МК_Рекв.Получить("Маршрут");
			ЭтаФорма.КодМинтруда = МК_Рекв.Получить("КодМинтруда");    
			ЭтаФорма.МК_Списочный = МК_Рекв.Получить("Списочный");    
		
			Если ЭтаФорма.МК_Код = "195" Тогда       // 195 - код трудового договора
				ЭтаФорма.НомерДокумента = мДокумент.ТрудовойДоговорНомер;
				ЭтаФорма.ДатаДокумента = мДокумент.ТрудовойДоговорДата;
			Иначе     
				Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(мДокумент, "НомерПриказа") Тогда
					ЭтаФорма.НомерДокумента = мДокумент.НомерПриказа;
				Иначе	
					ЭтаФорма.НомерДокумента = мДокумент.Номер;
				КонецЕсли;	
				ЭтаФорма.ДатаДокумента = мДокумент.Дата;
			КонецЕсли;
		Исключение	  // В исключение попадают отчеты типа личной карточки Т-2
			ЭтаФорма.ДатаДокумента = ТекущаяДата();                    
			ЭтаФорма.МК_Код = МК_Рекв.Получить("МК_Код");
			//ЭтаФорма.МК_Наименование = МК_Рекв.Получить("МК_Ссылка");
			ЭтаФорма.МК_Наименование = Справочники.МК_ВидыДокументовМояКоманда.НайтиПоРеквизиту("ID",ЭтаФорма.МК_Код);
			ЭтаФорма.МаршрутПодписания = МК_Рекв.Получить("Маршрут");
			ЭтаФорма.КодМинтруда = МК_Рекв.Получить("КодМинтруда");    
		КонецПопытки;		
		мРез = Истина;
	КонецЕсли;	      
	Возврат мРез;
КонецФункции	


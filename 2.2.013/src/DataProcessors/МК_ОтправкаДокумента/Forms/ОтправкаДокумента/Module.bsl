&НаКлиенте                                            
Процедура ОтправитьФайл(мРежим)  
	Если ЭтаФорма.ЗапретДействий Тогда
		Возврат;    // Пока ничего не делаем, если ЗапретДействий.
	КонецЕсли;	
	мПарамПодписи = Неопределено;   
	//мОрг = Неопределено; 	
	мТабДок = Неопределено;
	мИдент = Неопределено;
	мНовыйУИД = Неопределено;
	Если ЭтаФорма.Сотрудники.Количество() = 1 ИЛИ МК_Списочный Тогда       
		мТабДок = ЭтаФорма.ВладелецФормы.ТекущаяПечатнаяФорма;	
		мНовыйУИД =  Новый УникальныйИдентификатор();
		мИдент = СокрЛП(мНовыйУИД);
	КонецЕсли;	
		
	// Сначала нужно записать новый документ в справочник. При этом сформируется UUID нового документа.
	// Его будем использовать в качестве имени файла. 	
	// мНовыйСсылка = МК_ДобавитьДокументКЭДО(мРежим); 
	// 19.12.24 Изменение поведения. Пока добавлять документ нежелательно, так как он может и не создаться/не подписаться
	// по разным причинам. Поэтому тут нужно застолбить UUID, с которым в случае удачи будет записан документ КЭДО	
	мОрг =ЭтаФорма.Организация;
	//Если мНовыйУИД <> Неопределено Тогда  		
		// Тут, если сказано подписать, надо открыть форму подписания. И дальше работать с выбранным сертификатом и паролем.
		Если мРежим = 3 Тогда			
			мПараметры = Новый Структура("ТабличныйДокумент,IDдокумента,НовыйУИД,ПараметрыПодписи,Организация",
									мТабДок,мИдент,мНовыйУИД,мПарамПодписи,мОрг) ; 				
			Оп = Новый ОписаниеОповещения("МК_ВыполнитьПослеОкончания", ЭтотОбъект); 
			ОткрытьФорму("Обработка.МК_ОтправкаДокумента.Форма.МК_ПодписаниеЭЦП",мПараметры,ЭтаФорма,Истина,,,Оп,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
		Иначе
			Если ЭтаФорма.Сотрудники.Количество() > 1 И (Не МК_Списочный) Тогда       
				мРезультат = СоздатьPDFы(мРежим, мПарамПодписи);
			Иначе	
				мРезультат = СоздатьPDFНаСервере(мТабДок,мИдент,мРежим,мНовыйУИД,мПарамПодписи,Неопределено);	 
			КонецЕсли;	
			Если ЭтаФорма.ЗапретДействий Тогда		  
				Элементы.Группа3.Видимость = Ложь;
				Если ДокументОтправлен(ЭтаФорма.ДокКЭДО) Тогда
					Элементы.Отправить.Видимость = Ложь;
				Иначе	                                
					Элементы.Отправить.Видимость = Истина;
				КонецЕсли;                              
				Элементы.Удалить.Видимость = Истина;		
			Иначе
				Элементы.Удалить.Видимость = Ложь;		
				Элементы.Отправить.Видимость = Ложь;		
			КонецЕсли;
			ЭтаФорма.ОбновитьОтображениеДанных(); 
			//ОбновитьДинамическийСписок();  
			ОповеститьОбИзменении(ЭтаФорма.ДокументСсылка);
		КонецЕсли;	 
	//Иначе
	//	мРезультат = 0;   // Не удалось получить новый ГУИД. Так бывает?
	//КонецЕсли;	 
КонецПроцедуры  

&НаКлиенте                                            
Функция МК_ВыполнитьПослеОкончания(мПарам, мДопПарам) Экспорт	  // Сюда попадаем после получения реквизитов подписи.
	мСерверноеПодпиcание = ЭтаФорма.СоздаватьЭЦПНаСервере;
	Если мПарам = Неопределено Тогда                                                        
		мРезультат = Новый Массив(1); 
		мРезультат[0] = 6;
	Иначе		
		// Тут надо выполнить создание и подписание документа.     
		// Это - серверный способ подписания. Он нормально работает в файловой базе, но в клиент-серверной
		// надо, чтобы криптоменеджер был установлен на сервере. Пока такое не встречалось. Поэтому мСерверноеПодписание
		// буду нормально инициализировать позже.
		мРежим = 3;                                      
		мПарамПодписи = мПарам.ПараметрыПодписи;  
		мТАбДок = мПарам.ТабДок;
		мИдент = мПарам.IDДокумента;								
		мНовыйСсылка = мПарам.СсылкаНаДокумент;        
		мПарамПодписи = мПарам.ПараметрыПодписи;
		Если мСерверноеПодпиcание Тогда                                    
			Если ЭтаФорма.Сотрудники.Количество() > 1 И (Не МК_Списочный) Тогда       
				мРезультат = СоздатьPDFы(мРежим, мПарамПодписи);
			Иначе	                 	
				мНовыйУИД = мПарам.НовыйУИД;    
				мРезультат = СоздатьPDFНаСервере(мТабДок,мИдент,мРежим,мНовыйУИД,мПарамПодписи,Неопределено);	 
			КонецЕсли;				
		Иначе          			
			// Надо создать PDF файл на сервере и передать сюда через временное хранилище.      
			// Здесь для множественных документов нужно организовывать цикл.          
			Если ЭтаФорма.Сотрудники.Количество() > 1 И (Не МК_Списочный) Тогда       
				СоздатьPDFыДляКлиента();    // Все новые данные пишутся в таблицу "ДокументыСотрудников" 
				мРез = ПодписатьДокументыНаКлиенте(мПарамПодписи,мПарам.МенеджерКрипты);   
				
				Если мРез = Ложь Тогда   // Это значит, что подписание обломалось совсем.
				Иначе
					ЗаписатьиОтправитьКомплекты(мПарамПодписи);
				КонецЕсли;	
			Иначе	
				мРез = СоздатьPDFНаСервереДляКлиента(мТабДок,мИдент,Неопределено); 
				Если мРез[0] = 1 Тогда  
					// Теперь надо подписать.
					мРезультат = ПодписатьДокументНаКлиенте(мРез[1],мПарамПодписи,мПарам.МенеджерКрипты);  
					Если мРезультат = Неопределено Тогда  // Это может быть, если МенеджерКриптографии не создался
					ИначеЕсли мРезультат.Успешно Тогда
						// Тут имеем во временном хранилище PDF и в структуре мРезультат - двоичные данные подписи.
						// Надо опять делать серверный вызов, там сохранять документ и подпись в файлы, архивировать и отправлять
						мРезультат = ЗаписатьИОтправитьКомплект(мРез[1],мРезультат.Подпись,мИдент,мПарамПодписи,мРежим,мНовыйСсылка, Неопределено);  
					Иначе  // Подписание обломалось
						Сообщить(мРезультат.ТекстОшибки);
					КонецЕсли;	
				КонецЕсли;		
			КонецЕсли;	
		КонецЕсли;	
	КонецЕсли;	  
	Если ЭтаФорма.ЗапретДействий Тогда		  
		Элементы.Группа3.Видимость = Ложь;
		Если ДокументОтправлен(ЭтаФорма.ДокКЭДО) Тогда
			Элементы.Отправить.Видимость = Ложь;   
		Иначе	                                
			Элементы.Отправить.Видимость = Истина;
		КонецЕсли;                              
		Элементы.Удалить.Видимость = Истина;			
	Иначе
		Элементы.Удалить.Видимость = Ложь;		
		Элементы.Отправить.Видимость = Ложь;		
	КонецЕсли;
	ЭтаФорма.ОбновитьОтображениеДанных(); 
	ОповеститьОбИзменении(ЭтаФорма.ДокументСсылка);
	//ОбновитьДинамическийСписок();
КонецФункции	


&НаСервере
Функция МК_ДобавитьДокументКЭДО(мРежим,мНовыйУИД,мСотрудник)
	мИдент = Неопределено;
	//МК_Код = Справочники.МК_ВидыДокументов.МК_РеквВидаДокумента(ЭтаФорма.Документ,ЭтаФорма.ПечатнаяФорма);
	Если ЗначениеЗаполнено(ЭтаФорма.МК_Код) Тогда                    
		НовыйЭлемент = Справочники.МК_ДокументыКЭДО.СоздатьЭлемент();
		мСсылка = Справочники.МК_ДокументыКЭДО.ПолучитьСсылку(мНовыйУИД);
		НовыйЭлемент.УстановитьСсылкуНового(мСсылка); 	
		НовыйЭлемент.ДокументОснование = ЭтаФорма.ДокументСсылка;
		НовыйЭлемент.Наименование = ЭтаФорма.Документ;
		НовыйЭлемент.КодТипаДокумента = ЭтаФорма.МК_Код;
		НовыйЭлемент.ОрганизацияСсылка = ЭтаФорма.Организация;
		НовыйЭлемент.НомерДокумента = ЭтаФорма.НомерДокумента;
		//НовыйЭлемент.ДатаДокумента = ЭтаФорма.ДатаДокумента;
		НовыйЭлемент.ДатаДокумента = УниверсальноеВремя(ТекущаяДатаСеанса(), ЧасовойПоясСеанса());
		НовыйЭлемент.МаршрутПодписания = ЭтаФорма.МаршрутПодписания;
		НовыйЭлемент.КрайнийСрокПодписания = ЭтаФорма.КрайнийСрокПодписания; 
		НовыйЭлемент.Руководитель = ЭтаФорма.Руководитель;
		НовыйЭлемент.РуководительФЛ = ЭтаФорма.РуководительФЛ;
		НовыйЭлемент.ТипФормы = ЭтаФорма.ПечатнаяФорма;
		Если мРежим = 1 Тогда
			НовыйЭлемент.СтатусДокумента = Перечисления.МК_СтатусыДокументов.С1;  // Черновик 
			НовыйЭлемент.СтатусЧислом = 1;
		Иначе	                                                                             
			НовыйЭлемент.СтатусДокумента = Перечисления.МК_СтатусыДокументов.С2;  // На подписании
			НовыйЭлемент.СтатусЧислом = 1;
		КонецЕсли;
		НовыйЭлемент.Отправлен = Ложь; 					// На момент создания документа, он не отправлен.   
		Если мСотрудник = Неопределено Тогда
			Для Каждого мСтр ИЗ ЭтаФорма.Сотрудники Цикл      // Добавляем сотрудников
				мСтрДок = НовыйЭлемент.СотрудникиДокумента.Добавить();
				мСтрДок.СотрудникСсылка = мСтр.Сотрудник;
			КонецЦикла;	
		Иначе
			мСтрДок = НовыйЭлемент.СотрудникиДокумента.Добавить();
			мСтрДок.СотрудникСсылка = мСотрудник;
		КонецЕсли;	
		НовыйЭлемент.Записать();   
		// Нужно определить статус документа и код статуса - для регистра
		мИдент = НовыйЭлемент.Ссылка;	 		
		ЭтаФорма.ДокКЭДО = мИдент;
	КонецЕсли;	                                                       
	Возврат мИдент;
КонецФункции 

Функция СоздатьPDFы(мРежим,мПарамПодписи)      // Здесь в цикле будут создаваться множественные документы  
	мРезультат = Неопределено;   // Что-то нужно будет вернуть
    Для Каждого мСтрока Из ЭтаФорма.ДокументыСотрудников Цикл
		мНовыйУИД =  Новый УникальныйИдентификатор();  
		мИдент = СокрЛП(мНовыйУИД);
		мАдрес = мСтрока.АдресДокумента;
		мТабДок = ПолучитьИзВременногоХранилища(мАдрес); 
		мСотрудник = мСтрока.Сотрудник;
		мРез = СоздатьPDFНаСервере(мТабДок,мИдент,мРежим,мНовыйУИД,мПарамПодписи,мСотрудник);	 
		// Тут нужно отразить результат по документу в таблице
	КонецЦикла;
	Возврат мРезультат;
КонецФункции	


Функция СоздатьPDFНаСервере(мДокумент,мИдент,мРежим,мНовыйУИД,мПарамПодписи,мСотрудник);  
	ОО = Обработки.МК_НастройкаВыгрузки.Создать();             // Получили доступ к обработке, в которой находятся служебные функции
	мВозврат = Новый Массив;
	мВозврат.Добавить(1);  // Все хорошо   
	Если мСотрудник = Неопределено Тогда
		мСотр = ЭтаФорма.Сотрудники[0].Сотрудник;
	Иначе
		мСотр = мСотрудник;
	КонецЕсли;	
	мДок = ЭтаФорма.Документ;       
	мИмяФайла = мСотр.ФизическоеЛицо.Фамилия + "_" + мСотр.ФизическоеЛицо.Инициалы + "_Документ_№"+ ЭтаФорма.НомерДокумента+"_от_"+Формат(ЭтаФорма.ДатаДокумента, "ДФ=гггг-ММ-дд; ДП=");   
	мИмяФайла = ОбщегоНазначенияКлиентСервер.ЗаменитьНедопустимыеСимволыВИмениФайла(мИмяФайла,"_");
	мИмяФайла = СтрЗаменить(СокрЛП(мИмяФайла),".","");
	// Теперь создаем каталоги правильно.
	мВремДир = ФайловаяСистема.СоздатьВременныйКаталог();  
	мДирДок = мВремДир + мИдент + ПолучитьРазделительПутиСервера();    // Папка для файлов документа. В ней будут: основной PDF-файл, xml-файл описание, потом подписи, МЧД и т.д.
	СоздатьКаталог(мДирДок);   

	ИмяPDF = мДирДок+ мИмяФайла + ".pdf";  	 	
	Попытка                               	   
		мДокумент.Записать(ИмяPDF, ТипФайлаТабличногоДокумента.PDF_A_1);  		
	Исключение   
		мВозврат[0] = 2  // Не удалось создать PDF-файл
	КонецПопытки;	
	
	
	мРез = Истина;                  
	мИмяФайлаПодписи = Неопределено;
	Если мВозврат[0] = 1 И мРежим = 3 Тогда  // Если файл создался и режим с подписью, надо подписать.   
		// Для этого нужно открыть форму подписания.
		мОшибкаПодписи = МК_ПодписатьЭЦП(ИмяPDF,мДирДок,мПарамПодписи);  
		Если мОшибкаПодписи = Неопределено Тогда        
			мИмяФайлаПодписи = ЭтаФорма.ИмяФайлаПодписи;
		Иначе	
			мВозврат[0] = 6;  
			мВозврат.Добавить(мОшибкаПодписи);
			мРез = Ложь;
		КонецЕсли;	
	КонецЕсли;    	
	
    Если мВозврат[0]=1 Тогда    
		// Опять возвращаемся к идее создания zip-архива для каждого документа.
		Попытка
			ИмяАрхива = мВремДир + мИдент + ".zip";
			мАрхив = Новый ЗаписьZipФайла(ИмяАрхива,"", "Документ КЭДО",МетодСжатияZIP.Сжатие, УровеньСжатияZIP.Оптимальный, МетодШифрованияZIP.Zip20);     
			мФайлы = мДирДок + "*.*";                                                                                                           
			мАрхив.Добавить(мФайлы);
			мАрхив.Записать();    
		Исключение                                         
			мВозврат[0] = 3  // Не удалось создать ZIP-файл
		КонецПопытки;	 
	КонецЕсли;                                                      	
	ПродолжитьОтправкуФайла(мВозврат,ИмяАрхива,мРежим,мИмяФайла, мНовыйУИД, мСотрудник);	
	УдалитьФайлы(мВремДир);
КонецФункции	                                                    


Функция ПродолжитьОтправкуФайла(мВозврат,ИмяАрхива,мРежим,мИмяФайла,мНовыйУИД,мСотрудник)
	// Вот тут zip-файл уже создан. Надо создать запись для него в справочнике документов КЭДО.     
	ОО = Обработки.МК_НастройкаВыгрузки.Создать();
	Если мВозврат[0] = 1 Тогда
		мНовыйСсылка = МК_ДобавитьДокументКЭДО(мРежим,мНовыйУИД,мСотрудник); 
		мДокКЭДО = мНовыйСсылка.ПолучитьОбъект();        
		мДокКЭДО.ИмяФайлаДокумента = мИмяФайла+".pdf";      
		мДокКЭДО.ИмяФайлаПодписи = ЭтаФорма.ИмяФайлаПодписи;
		мДокКэдо.ВладелецЭЦП = ЭтаФорма.ВладелецЭЦП; 
		мДокКЭДО.ДатаПодписи = УниверсальноеВремя(ТекущаяДатаСеанса(), ЧасовойПоясСеанса());   
		мДокКЭДО.МЧД = ЭтаФорма.МЧД;
    	мДокКЭДО.Записать();
		
		// Сохраним файл в присоединенных файлах. !!! 18.08.2025 Отключаем работу с присоединенными файлами - Фреш пока ее не поддерживает.
		//Попытка
		//	мФайл = Новый Файл(ИмяАрхива);	
		//	мДвоичДан = Новый ДвоичныеДанные(ИмяАрхива);
		//	мВрХр = ПоместитьВоВременноеХранилище(мДвоичДан);
		//	// Подготоваливаем описание файла заполнив все необходимые параметры
		//	ПараметрыФайла = РаботаСФайлами.ПараметрыДобавленияФайла();
		//	ПараметрыФайла.Автор = Пользователи.ТекущийПользователь();
		//	ПараметрыФайла.ВладелецФайлов = мНовыйСсылка;         
		//	ПараметрыФайла.Вставить("Владелец",мНовыйСсылка);
		//	ПараметрыФайла.ИмяБезРасширения = мФайл.ИмяБезРасширения; //  СтрЗаменить(ИмяАрхива,".zip","");
		//	ПараметрыФайла.РасширениеБезТочки = "zip"; 			
		//	// Используем функцию БСП и добавляем файл к объекту
		//	РаботаСФайлами.ДобавитьФайл(ПараметрыФайла, мВрХр);   		
		//Исключение
		//	мВозврат[0] = 8  // Не удалось записать присоединенный файл
		//КонецПопытки;
	
	
		// Тут - отправка. 
		Если мВозврат[0] = 1 Тогда 
			мСеанс = ОО.СоздатьСеансСвязи(Истина);
			Если мСеанс = Неопределено Тогда
				// Ошибка авторизации. Ничего не отправляем. 
				мВозврат[0] = 4;
				мРезультат = Ложь;
			Иначе
				мРезультат = ОО.ВыгрузитьФайлНаСайт(ИмяАрхива,мСеанс,"pdf",Истина,"api/1c-exchange/edms/documents/upload","Документы КЭДО");
				Если НЕ мРезультат Тогда
					мВозврат[0] = 5      // Ошибка отправки файла 
				КонецЕсли;	
			КонецЕсли;
    	КонецЕсли;
	КонецЕсли;
	Если мВозврат[0] = 1 Тогда   // Все удалось. Нужно отправить json описание файла.
		мДокументы = Новый Массив;
		мДокументы.Добавить(мНовыйСсылка);
		мРезультат = Справочники.МК_ДокументыКЭДО.МК_ОтправитьJSON(мДокументы);
		Если НЕ мРезультат Тогда
			мВозврат[0]=7; //  Ошибка отправки описания файла.
		КонецЕсли;	
	КонецЕсли;
	мСтатус = "";   
	мКодСтатуса = 1;
	Если мВозврат[0] = 1 Тогда
		Сообщить("Документ отправлен успешно");  
		Если мДокКЭДО.СтатусДокумента = Перечисления.МК_СтатусыДокументов.С1 Тогда;  // Черновик			
			мСтатус = "Отправлен как черновик";   
			мКодСтатуса = 3;			
		Иначе
			мСтатус = "На подписании";  
			мКодСтатуса = 4;			
		КонецЕсли;
	ИначеЕсли мВозврат[0] = 5 Тогда
		Сообщить("Ошибка отправки zip-архива");		
		мСтатус = "Не отправлен";  		
	ИначеЕсли мВозврат[0] = 7 Тогда
		Сообщить("Ошибка отправки описания файла");				
	ИначеЕсли мВозврат[0] = 4 Тогда
		Сообщить("Ошибка авторизации. Ничего не отправлено");			
	//ИначеЕсли мВозврат[0] = 8 Тогда
	//	Сообщить("Ошибка. Не удалось записать присоединенный файл");
	ИначеЕсли мВозврат[0] = 3 Тогда
		Сообщить("Ошибка. Не удалось создать zip-архив");			
	ИначеЕсли мВозврат[0] = 6 Тогда
		Сообщить("Ошибка формирования электронной подписи: "+ мВозврат[1]); //мОшибкаПодписи);
	ИначеЕсли мВозврат[0] = 2 Тогда
		Сообщить("Ошибка создания pdf-файла");	
	КонецЕсли;    
	Если мВозврат[0] =1 ИЛИ мВозврат[0] = 4 ИЛИ мВозврат[0] = 5 ИЛИ мВозврат[0] = 7 Тогда  // 5 или 7 - это все сделано, но не удалось отправить zip-архив или описание.
		ЭтаФорма.Состояние = ПолучитьСостояниеДокумента(мНовыйСсылка);
		ЭтаФорма.ТолькоПросмотр = Истина;    
		ЭтаФорма.ЗапретДействий = Истина;
		// При записи нового элемента нужно заполнить для него сведения в регистре сведений "МК_СостояниеДокументовКЭДО"
		Если мКодСтатуса = 1 И ЗначениеЗаполнено(мДокКЭДО.ИмяФайлаПодписи) ТОгда
			мКодСтатуса = 2;
			мСтатус = "Подписан, не отправлен";
		КонецЕсли;	
		Справочники.МК_ДокументыКЭДО.ОтразитьВРегистре(мДокКЭДО.ДокументОснование,мНовыйСсылка,мДокКЭДО.КодТипаДокумента,мСтатус,мКодСтатуса);
	КонецЕсли;	  	
КонецФункции   

Функция МК_ПодписатьЭЦП(ИмяPDF,мДирДок,мПарамПодписи)
	//мРез = Истина;
	мРез = Неопределено;
	Попытка    	
		мДСерт = мПарамПодписи.Сертификат.СертификатЭЦП.ДанныеСертификата.Получить();
		мСертификат = Новый СертификатКриптографии(мДСерт);	
		мПрограмма = мПарамПодписи.Сертификат.СертификатЭЦП.Программа;
		мМК = ПолучитьМенеджерКриптографии("Подписание",мПрограмма);
    	мМК.ПарольДоступаКЗакрытомуКлючу = мПарамПодписи.Пароль; // строка     
		// Тут надо вычислить имя файла-подписи. 1С дублирует его из имени pdf-файла, а МК хочет видеть в имени владельца
		// подписи.                                                         
		мНаимДок = СтрЗаменить(СокрЛП(ЭтаФорма.МК_Наименование), " ","_");	
		// Сначала ФИО владельца ЭЦП.
		мИмяПодписи = СокрЛП(мПарамПодписи.ФизЛицо.Фамилия) + "_"+ 
		                 СокрЛП(мПарамПодписи.ФизЛицо.Имя) + "_"+  
						    СокрЛП(мПарамПодписи.ФизЛицо.Отчество)+"_"+мНаимДок + ".sig"; 			
   		мМК.Подписать(ИмяPDF, мДирДок+мИмяПодписи, мСертификат);  
		ЭтаФорма.ВладелецЭЦП = мПарамПодписи.ФизЛицо; 
		ЭтаФорма.ИмяФайлаПодписи = мИмяПодписи;
	Исключение   	
		мОшибка = ИнформацияОбОшибке();  
		мРез = ПодробноеПредставлениеОшибки(мОшибка);
	КонецПопытки;	
	Возврат мРез;
КонецФункции	           

Функция ПолучитьМенеджерКриптографии(Операция = "", Программа = Неопределено)
		
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.ЭлектроннаяПодпись") Тогда
		МодульЭлектроннаяПодпись = ОбщегоНазначения.ОбщийМодуль("ЭлектроннаяПодпись"); 
		ОписаниеОшибки = "";
		мРез = МодульЭлектроннаяПодпись.МенеджерКриптографии(Операция,,ОписаниеОшибки, Программа);
		Возврат мРез;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции


Функция ПодписатьДокументНаКлиенте(АдресВХ, мПарамПодписи, мМК)  Экспорт		
	мРез = Новый Структура("Успешно,Подпись,ТекстОшибки",Истина);
	
	Если ТипЗнч(мМК) = Тип("Строка") Тогда
		ПоказатьПредупреждение(, мМК);
		Возврат Неопределено;
	КонецЕсли;

	мДанныеДокумента = ПолучитьИзВременногоХранилища(АдресВХ);
		
	Если ЗначениеЗаполнено(мПарамПодписи.Пароль) Тогда                    
		мМК.ПарольДоступаКЗакрытомуКлючу = мПарамПодписи.Пароль; // строка		
	КонецЕсли;
	
	ПотокВПамяти = Новый ПотокВПамяти;     	
	мДСерт = ПолучитьДанныеСертификата(мПарамПодписи.Сертификат);
	мСертификат = Новый СертификатКриптографии(мДСерт);	
	
	Попытка
		мМК.Подписать(мДанныеДокумента,ПотокВПамяти,мСертификат);
		мРез.Подпись = ПотокВПамяти.ЗакрытьИПолучитьДвоичныеДанные(); 		
	Исключение
		мРез.Успешно = Ложь;
		мРез.ТекстОшибки = ОписаниеОшибки();
	КонецПопытки;  
	Возврат мРез;  
КонецФункции    


&НаСервере                                                   
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)   
	ОО = Обработки.МК_НастройкаВыгрузки.Создать();             // Получили доступ к обработке, в которой находятся служебные функции
	мСсылка = Параметры.мДок;                                         
	ЭтаФорма.ДокументСсылка = мСсылка;	 
	ЭтаФорма.МК_МенеджерПечати = Параметры.МК_МенеджерПечати;                            
	мДокумент = мСсылка.ПолучитьОбъект();	
	мТип = ТипЗнч(мСсылка); 
	мЗначение = Новый(мТип);
    ЭтаФорма.Документ = мЗначение.Метаданные().ПолноеИмя();   
	// Надо поискать документ в справочнике МК_ДокументыКЭДО. Возможно он уже создан. 
	// Чтобы искать, надо уже знать код типа документа МК, иначе для приема на работу неясно что искать - приказ или договор.
	мВидФормы = Параметры.ИменаМакетов; 
	мМногоСотрудников = Параметры.МК_МногоСотрудников;
	МК_Рекв = Справочники.МК_ВидыДокументов.МК_РеквВидаДокумента(ЭтаФорма.Документ,мВидФормы);	  // Возвращает соответствие МК_Код, МК_Наименование, МаршрутПодписания, КодМинтруда, Списочная? 
	мДКЭДО = НайтиДокКЭДО(мСсылка, МК_Рекв.Получить("МК_Код"));  
	ЭтаФорма.СоздаватьЭЦПНаСервере = Константы.СоздаватьЭлектронныеПодписиНаСервере.Получить();  
	ЭтаФорма.МК_Области = Параметры.МК_Области;
	
	//ЭтаФорма.ПечатнаяФорма - этот реквизит на сервере недоступен. Определяется при открытии на клиенте
	//ЭтаФорма.НомерДокумента = мДокумент.Номер;  // Номер и дату можно определить при открытии, когда узнаем код документа МК
	//ЭтаФорма.ДатаДокумента = мДокумент.Дата;   
	Если мДКЭДО = Неопределено ИЛИ (НЕ мДКЭДО.Отправлен) Тогда
		// Тут создание нового документа  
		Попытка
			ЭтаФорма.Организация = мДокумент.Организация;
		Исключение	 
			ЭтаФорма.Организация = мДокумент.ГоловнаяОрганизация;
		КонецПопытки;
		// В ЗУП руководитель - физлицо. А у нас - сотрудник.
		Попытка
			ЭтаФорма.РуководительФЛ = мДокумент.Руководитель;
		Исключение   
			Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.СведенияОбОтветственныхЛицах") Тогда
				// Это запрос сведений о руководителе в ЗУП
				ЭтаФорма.РуководительФЛ = ЗарплатаКадры.ОтветственныеЛицаОрганизации(ЭтаФорма.Организация, "Руководитель", ТекущаяДатаСеанса()).Руководитель;
			Иначе 
				// А тут - для комплексной.  
				ЭтаФорма.РуководительФЛ = Обработки.МК_ВыгрузкаСотрудников.ПолучитьДанныеРуководителя(ЭтаФорма.Организация, ТекущаяДатаСеанса()).Руководитель;
			КонецЕсли;
		КонецПопытки;	
		мСписСотр = ОО.СписокСотрудниковПоФизлицу(ЭтаФорма.Организация,ЭтаФорма.РуководительФЛ);  // В этой функции подбираются только основные сотрудники или внешние
		Если мСписСотр.Следующий() Тогда                                                           // совместители. Если все хорошо, вернется одна запись. Если больше - нас не волнует,
			ЭтаФорма.Руководитель = мСписСотр.СотрудникСсылка;                                     // возьмем первого.
		КонецЕсли;			
		//ЭтаФорма.КрайнийСрокПодписания = мДокумент.Дата+(60*60*24*3);  // Три дня
		ЭтаФорма.КрайнийСрокПодписания = ТекущаяДата()+(60*60*24*3);  // Три дня				
		мТЗ = ЭтаФорма.Протокол;  									
		Попытка     // Еще беда - в "отмене совмещения" нет Сотрудника, есть СовмещающийСотрудник  
			мСотрудник = мДокумент.Сотрудник;    
		Исключение	
			Попытка
				мСотрудник = мДокумент.СовмещающийСотрудник; 
			Исключение  
				Попытка 
					мСотрудник = мДокумент.ФизическиеЛица[0].ФизическоеЛицо;     
				Исключение 
					Попытка                                             
						// Тут видимо надо проверять: если документ списочный, то нужно всех сотрудников в этот список
						// записывать. Попутно проверять отношение к КЭДО.
						//                                                   
						Если Не мМногоСотрудников Тогда
							мСотрудник = мДокумент.Сотрудники[0].Сотрудник;  					  
						Иначе	
							Для Каждого мСотр Из мДокумент.Сотрудники Цикл    
								Если Справочники.МК_СотрудникиКЭДО.ПроверитьСогласиеКЭДО(мСотр.Сотрудник) Тогда	 				
						    		мНоваяСтрока = ЭтаФорма.Сотрудники.Добавить();
									мНоваяСтрока.Сотрудник = мСотр.Сотрудник;							
								Иначе									
									мСтр = мТЗ.Добавить();
									мСтр.ТабНом = СокрЛП(мСотр.Сотрудник.Код);
									мСтр.ФИО = мСотр.Сотрудник.Наименование;
									мСтр.Организация = СокрЛП(мСотр.Сотрудник.ГоловнаяОрганизация.Наименование);
								КонецЕсли;	
							КонецЦикла;	
						КонецЕсли;					
					Исключение    
						Попытка
							мСотрудник = мДокумент.Субъект;   // Это - "Согласие на обработку персональных данных"
						Исключение    
							Попытка      
								мСотрудник = мДокумент.Ссылка;   // Это - из справочника сотрудников							
							Исключение
							КонецПопытки;	
						КонецПопытки;	
					КонецПопытки	
				КонецПопытки;					
			КонецПопытки;	
		КонецПопытки;
		// В большинстве документов Сотрудник - это Сотрудник.Ссылка. Но есть и такие (пока обнаружен только приказ на отпуск 
		// по уходу за ребенком), где Сотрудник - ФизическоеЛицо.Ссылка   
		Если ТипЗнч(мСотрудник) = Тип("СправочникСсылка.ФизическиеЛица") Тогда   
			// Нужно найти сотрудника.
			мСписСотр = ОО.СписокСотрудниковПоФизлицу(мДокумент.Организация,мСотрудник);  // В этой функции подбираются только основные сотрудники или внешние
			Если мСписСотр.Следующий() Тогда                                              // совместители. Если все хорошо, вернется одна запись. Если больше - нас не волнует,
				мСотрудник = мСписСотр.СотрудникСсылка;                                   // возьмем первого.
			КонецЕсли;	
		КонецЕсли;      
		Если Не мМногоСотрудников Тогда
			НоваястрокаТЗ = ЭтаФорма.Сотрудники.Добавить();  
			НоваяСтрокаТЗ.Сотрудник = мСотрудник; 			
		КонецЕсли;	
		ЭтаФорма.Состояние = "Документ не создан";     
		ЭтаФорма.ЗапретДействий = Ложь;                            
	Иначе	                                         
		//мДКЭДО = мДКЭДОСсылка.ПолучитьОбъект();
		ЭтаФорма.Организация = мДКЭДО.ОрганизацияСсылка;      
		ЭтаФорма.Руководитель = мДКЭДО.Руководитель;   
		ЭтаФорма.РуководительФЛ = мДКЭДО.РуководительФЛ;   
		ЭтаФорма.КрайнийСрокПодписания =мДКЭДО.КрайнийСрокПодписания;		
		ЭтаФорма.НомерДокумента = мДКЭДО.НомерДокумента;
		ЭтаФорма.ДатаДокумента = мДКЭДО.ДатаДокумента;  
		ЭтаФорма.МК_Код = мДКЭДО.КодТипаДокумента; 
		ЭтаФорма.МаршрутПодписания = мДКЭДО.МаршрутПодписания;  
		ЭтаФорма.МК_Наименование =  Справочники.МК_ВидыДокументовМояКоманда.НайтиПоРеквизиту("ID",ЭтаФорма.МК_Код);
		ЭтаФорма.ТолькоПросмотр = Истина;  
		Для Каждого мСтр ИЗ мДКЭДО.СотрудникиДокумента Цикл      // Добавляем сотрудников
			мНоваяСтрока = ЭтаФорма.Сотрудники.Добавить();
			мНоваяСтрока.Сотрудник = мСтр.СотрудникСсылка;  
		КонецЦикла;		
		ЭтаФорма.ДокКЭДО = мДКЭДО;
		ЭтаФорма.Состояние = ПолучитьСостояниеДокумента(мДКЭДО);
		ЭтаФорма.ЗапретДействий = Истина;
	КонецЕсли; 
	
КонецПроцедуры       

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	// Если протокол "Не КЭДО" не пустой, то не надо открывать форму отправки, а надо показать список
	// сотрудников без КЭДО
	Если ЭтаФорма.Протокол.Количество() > 0 Тогда
		Отказ = Истина;   
		ТабДок = ДанныеТЗвТД();   
		Печать(ТабДок);
	Иначе	
		ЭтаФорма.ПечатнаяФорма = ЭтаФорма.ВладелецФормы.МК_ИмяФормы;
		// Теперь можно (нужно) получить еще и обычный маршрут подписания
		мРез = ОпределитьРеквизитыВидаДокумента();   // Это можно только на сервере  
		ЭтаФорма.УИД = ЭтаФорма.УникальныйИдентификатор;
		Если ЭтаФорма.ЗапретДействий Тогда		  
			Элементы.Группа3.Видимость = Ложь;                      
			Если ДокументОтправлен(ЭтаФорма.ДокКЭДО) Тогда
				Элементы.Отправить.Видимость = Ложь;
			КонецЕсли;
		Иначе
			Элементы.Удалить.Видимость = Ложь;		
			Элементы.Отправить.Видимость = Ложь;		
		КонецЕсли;
		// Если сотрудников много, и форма несписочная, нужно сформировать табличные документы из областей
		// существующего табличного документа, и сохранить их в хранилище. Таблица значений (список сотрудников)
		// формы при этом подменяется на другую - список сотрудников с документами, которые можно просматривать
		// и редактировать.
		Если ЭтаФорма.Сотрудники.Количество()>1 И (НЕ ЭтаФорма.МК_Списочный) Тогда
			мАдресДок = СоздатьФайлыНаСервере(ЭтаФорма.ВладелецФормы.ТекущаяПечатнаяФорма);		
			Элементы.Сотрудники.Видимость = Ложь;
			Элементы.ДокументыСотрудников.Видимость = Истина;
		КонецЕсли;	
	КонецЕсли;	
КонецПроцедуры                                              


&НаСервере
Функция ДанныеТЗвТД()	
	ТЗ = ЭтаФорма.Протокол.Выгрузить();
	ТабДок = Новый ТабличныйДокумент;
	Построитель = Новый ПостроительОтчета;  
	Построитель.ТекстЗаголовка = "Список сотрудников без согласия на участие в КЭДО. Нужно удалить их из этого документа, или обеспечить согласие.";
	Построитель.ИсточникДанных = Новый ОписаниеИсточникаДанных(ТЗ);       
	Построитель.Вывести(ТабДок);
	Построитель.Выполнить();    
	Возврат ТабДок;
КонецФункции 

&НаКлиенте
Процедура Печать(ТабДок)
    // сформируем нужный нам табличный документ
	//    ТабДок = СформироватьТабДок();
    ТабДок.Область(1, , ТабДок.ВысотаТаблицы, ).Имя = "СписокCотрудниковБезСогласияКЭДО";
    // создадим коллекцию печатных форм, в которую надо будет добавить нужный нам табличный документ
    КПФ = УправлениеПечатьюКлиент.НоваяКоллекцияПечатныхФорм("Протокол");    
	
	//ПечатнаяФорма = УправлениеПечатьюКлиент.ОписаниеПечатнойФормы(КоллекцияПечатныхФорм, "Протокол"); 
    // Добавляем в коллекцию (тип массив) сформированный Табличный документ
    КПФ[0].ТабличныйДокумент = ТабДок;	
    
    КПФ[0].Экземпляров=1;
    КПФ[0].СинонимМакета = "Протокол";  // используется для формирования имени файла при сохранении из общей формы печати документов
    // .. и выводим стандартной процедурой БСП     
	
	ПараметрыВывода = УправлениеПечатьюКлиент.ПараметрыПечати(); 
	ПараметрыВывода.ЗаголовокФормы = "МояКоманда. Протокол проверки согласия на КЭДО сотрудников";    
	ПараметрыВывода.ВладелецФормы = ЭтаФорма;                                                        	
	Попытка
		УправлениеПечатьюКлиент.ПечатьДокументов(КПФ,Неопределено,ПараметрыВывода);
	Исключение  
		ПоказатьПредупреждение(,"Ошибка печати. Не удалось вывести список сотрудников без согласия на КЭДО.");
	КонецПопытки	
		
КонецПроцедуры



&НаСервере
Функция СоздатьФайлыНаСервере(мТД) 	
	мИндекс = 0;
	Для Каждого мОбласть Из ЭтаФорма.МК_Области Цикл
		мТабДок = мТД.ПолучитьОбласть(мОбласть);
		//мХранилище=Новый ХранилищеЗначения(мТабДок);
		мАдрес = ПоместитьВоВременноеХранилище(мТабДок, ЭтаФорма.УИД); 
		НоваяСтрока = ЭтаФорма.ДокументыСотрудников.Добавить();		
		НоваяСтрока.Сотрудник = ЭтаФорма.Сотрудники.Получить(мИндекс).Сотрудник;
		НоваяСтрока.АдресДокумента = мАдрес;
		мИндекс = мИндекс + 1;
	КонецЦикла;
	Возврат мАдрес;
КонецФункции	


Функция ПолучитьСостояниеДокумента(мДКЭДО)
	мВозврат = Неопределено;
	Если НЕ мДКЭДО.Отправлен Тогда
		Если ЗначениеЗаполнено(мДКЭДО.ИмяФайлаПодписи) Тогда
			мВозврат = "Документ создан. Подписан. Не отправлен";     
		Иначе	
			мВозврат = "Документ создан. Не подписан. Не отправлен";     
		КонецЕсли;	
	Иначе
		Если ЗначениеЗаполнено(мДКЭДО.ИмяФайлаПодписи) Тогда
			мВозврат = "Документ подписан и отправлен по маршруту";
		ИначеЕсли мДКЭДО.СтатусДокумента = Перечисления.МК_СтатусыДокументов.С1 Тогда 
			мВозврат = "Документ отправлен как черновик";     
		Иначе	                                                   
			мВозврат = "Документ отправлен по маршруту";
		КонецЕсли;
	КонецЕсли;	            
	Возврат мВозврат;
КонецФункции	


